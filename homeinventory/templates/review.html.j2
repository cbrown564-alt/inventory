            { source: room.name, into: mergeSelect.value })
          .then(function () { location.reload(); })
          .catch(function (e) { mergeBtn.disabled = false; toast(e.message); });
      });
    });
    mergeRow.appendChild(mergeSelect);
    mergeRow.appendChild(mergeBtn);
    panelBody.appendChild(disclosure("Name & boundaries", "Rename or merge",
      function (body) {
        body.appendChild(el("p", { "class": "panel-note",
          text: "Segmentation sometimes merges or misnames a room — fix it "
                + "here before signing." }));
        body.appendChild(renameRow);
        body.appendChild(mergeRow);
      }, false));

    var ta = el("textarea", { "class": "room-summary" });
    ta.value = room.summary || "";
    var roomSnap = null;
    ta.addEventListener("focus", function () {
      roomSnap = room.summary || "";
    });
    ta.addEventListener("blur", function () {
      if (roomSnap !== null && roomSnap !== room.summary) {
        var prevVal = roomSnap;
        undoStack.push({ label: "edit summary of " + room.name,
          apply: function () { room.summary = prevVal; } });
        if (undoStack.length > 50) undoStack.shift();
      }
      roomSnap = null;
    });
    ta.addEventListener("input", function () {
      room.summary = ta.value; markDirty();
    });
    panelBody.appendChild(disclosure("Room summary",
      room.summary ? "Has text" : "Empty",
      function (body) { body.appendChild(ta); },
      !!room.summary));

    // coverage: photos no item cites
    var cited = {};
    room.items.forEach(function (it) {
      (it.photo_ids || []).forEach(function (p) { cited[p] = true; });
    });
    var orphans = (room.photos || []).filter(function (p) {
      return !cited[p.id] && photoSrc[p.id];
    });
    panelBody.appendChild(disclosure("Coverage",
      orphans.length ? orphans.length + " uncited frames" : "All frames cited",
      function (body) {
        if (orphans.length) {
          var strip = el("div", { "class": "uncited" });
          orphans.forEach(function (p) {
            var fig = el("figure", {});
            var b = el("button", { type: "button",
              "aria-label": "Inspect " + p.id,
              onclick: function () {
                ui.photoViewer({ photos: orphans.map(function (o) {
                  return { label: o.id, src: photoSrc[o.id] }; }),
                  index: orphans.indexOf(p) });
              } });
            b.appendChild(el("img", { src: photoSrc[p.id], alt: p.id,
                                      loading: "lazy" }));
            fig.appendChild(b);
            fig.appendChild(el("figcaption", { text: p.id +
              (photoTime[p.id] ? " · " + fmtT(photoTime[p.id].t) : "") }));
            strip.appendChild(fig);
          });
          body.appendChild(strip);
          body.appendChild(el("p", { "class": "panel-note",
            text: "Wasted shots, or items the AI missed — check before signing." }));
        } else {
          body.appendChild(el("p", { "class": "panel-note",
            text: "Every embedded photo in this room is cited by at least one item." }));
        }
      }, orphans.length > 0));

    // add missing item
    var form = el("div", { "class": "add-form" });
    var fName = el("input", { type: "text", placeholder: "Item name *" });
    var fDesc = el("input", { type: "text",
      placeholder: "Description (material, colour, brand)" });
    var fCond = el("select", {});
    fCond.appendChild(el("option", { value: "", text: "Condition —" }));
    CONDITIONS.forEach(function (c) {
      fCond.appendChild(el("option", { value: c, text: c }));
    });
    var fPhoto = el("input", { type: "file", accept: "image/*",
      capture: "environment" });
    var fBtn = el("button", { "class": "btn primary", text: "Add item" });
    fBtn.addEventListener("click", function () {
      if (!fName.value.trim()) { toast("Name the item first"); return; }
      fBtn.disabled = true;
      var send = function (b64) {
        api("POST", "/api/items", {
          room: room.name, name: fName.value.trim(),
          description: fDesc.value.trim(), condition: fCond.value || null,
          photo_b64: b64, author: inv.inspected_by || "reviewer"
        }).then(function () {
          toast("Item added — reloading");
          return reload();
        }).catch(function (e) {
          fBtn.disabled = false; toast("Add failed: " + e.message);
        });
      };
      var file = fPhoto.files && fPhoto.files[0];
      if (!file) { send(null); return; }
      var rd = new FileReader();
      rd.onload = function () { send(rd.result.split(",", 2)[1]); };
      rd.readAsDataURL(file);
    });
    [fName, fDesc, fCond, fPhoto, fBtn].forEach(function (n) {
      form.appendChild(n);
    });
    panelBody.appendChild(disclosure("Add missed item", "Manual entry",
      function (body) { body.appendChild(form); }, false));

    // re-describe
    var rBtn = el("button", { "class": "btn", text: "Re-describe " + room.name });
    var rStatus = el("div", { id: "redesc-status" });
    function watchRedescribe() {
      rStatus.textContent =
        "Re-describing — this can take a few minutes…";
      var t = setInterval(function () {
        api("GET", "/api/redescribe").then(function (s) {
          if (s.status === "done") {
            clearInterval(t);
            rBtn.disabled = false;
            rStatus.textContent = "Done — reloading…";
            reload();
          } else if (s.status === "failed") {
            clearInterval(t);
            rBtn.disabled = false;
            rStatus.innerHTML = "";
            rStatus.appendChild(el("span",
              { text: "Re-describe failed." }));
            if (s.detail) {
              var det = el("details", {}, [
                el("summary", { text: "Show error output" }),
                el("pre", { text: s.detail })]);
              rStatus.appendChild(det);
            }
          }
        }).catch(function () { /* poll again */ });
      }, 2500);
    }
    rBtn.addEventListener("click", function () {
      ui.confirmDialog({
        title: "Re-describe " + room.name + "?",
        message: (payload.spend ? payload.spend.label + " — est. "
                  + payload.spend.estimate + ". " : "") +
                 "Re-runs the AI over this room's photos.",
        note: "Review decisions for this room are replaced. Unsaved edits " +
              "are saved first.",
        confirmLabel: "Re-describe"
      }).then(function (yes) {
        if (!yes) return;
        rBtn.disabled = true;
        flush({ manual: true }).then(function () {
          return api("POST", "/api/redescribe",
                     { room: room.name,
                       confirm: payload.build_confirm || "yes" });
        }).then(watchRedescribe).catch(function (e) {
          rBtn.disabled = false; toast(e.message);
        });
      });
    });
    panelBody.appendChild(disclosure("Re-describe room",
      "Re-run AI on this room's photos",
      function (body) {
        body.appendChild(el("p", { "class": "panel-note",
          text: "Useful after fixing capture problems. Review decisions for "
                + "this room are replaced." }));
        body.appendChild(rBtn);
        body.appendChild(rStatus);
      }, false));
  }

  /* ---------- finish helpers (reload / PDF poll) ---------- */
  function reload() {
    return api("GET", "/api/inventory").then(function (p) {
      inv = p.inventory; photoSrc = p.photo_src || {};
      cropSrc = p.crop_src || {};
      videos = p.videos || videos;
      photoTime = p.photo_time || photoTime;
      ix = index();
      dirty = false;
      undoStack = [];
      setSaveState("All changes saved");
      renderProgress(); renderQueue();
      if (sel && sel.type === "item" && ix.byId[sel.id]) {
        renderItem(ix.byId[sel.id]);
      } else if (sel && sel.type === "room") {
        var room = inv.rooms.find(function (r) { return r.name === sel.name; });
        if (room) renderRoom(room);
      } else if (viewMode === "finish") {
        renderFinish();
      } else if (viewMode === "overview") {
        renderOverview();
      } else if (ix.items.length) {
        showOverview();
      }
    });
  }
  pollPdf();

  /* ---------- filters / sort / bulk ---------- */
  document.getElementById("filters").addEventListener("click", function (e) {
    var b = e.target.closest("button");
    if (!b) return;
    filter = b.getAttribute("data-f");
    this.querySelectorAll("button").forEach(function (x) {
      x.setAttribute("aria-pressed", x === b ? "true" : "false");
    });
    renderQueue();
  });
  document.getElementById("sort").addEventListener("change", function () {
    sortMode = this.value; renderQueue();
  });
  var searchBox = document.getElementById("q-search");
  if (!window.matchMedia("(hover: none), (pointer: coarse)").matches &&
      searchBox.getAttribute("data-placeholder-kbd")) {
    searchBox.placeholder = searchBox.getAttribute("data-placeholder-kbd");
  }
  var headerMore = document.querySelector(".header-more");
  if (headerMore) {
    headerMore.querySelectorAll("a").forEach(function (node) {
      node.addEventListener("click", function () {
        headerMore.removeAttribute("open");
      });
    });
    document.addEventListener("click", function (e) {
      if (headerMore.hasAttribute("open") && !headerMore.contains(e.target)) {
        headerMore.removeAttribute("open");
      }
    });
  }
  var searchTimer = null;
  function applySearch() {
    query = searchBox.value.trim().toLowerCase();
    renderQueue();
  }
  searchBox.addEventListener("input", function () {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(applySearch, 150);
  });
  searchBox.addEventListener("keydown", function (e) {
    e.stopPropagation();
    if (e.key === "Escape") {
      searchBox.value = "";
      clearTimeout(searchTimer);
      applySearch();
      searchBox.blur();
    } else if (e.key === "Enter") {
      clearTimeout(searchTimer);
      applySearch();
      var entries = queueEntries();
      if (entries.length) {
        select({ type: "item", id: entries[0].id });
        searchBox.blur();
      }
    }
  });
  document.getElementById("bulk").addEventListener("click", function () {
    var open = queueEntries().filter(function (i) { return !isDone(i); });
    if (!open.length) { toast("Nothing left to accept"); return; }
    var bands = confidenceBands(open);
    var bandLine = formatConfidenceBands(bands);
    ui.confirmDialog({
      title: "Accept " + open.length + " remaining item" +
             (open.length > 1 ? "s" : "") + "?",
      message: "Every visible unreviewed item is marked as confirmed by you.",
      note: (bandLine ? bandLine + ". " : "") +
            "You can undo this with ⌘Z / Ctrl+Z.",
      confirmLabel: "Accept all"
    }).then(function (yes) {
      if (!yes) return;
      pushUndo("accept " + open.length + " items", open);
      open.forEach(function (i) { i.reviewed = true; });
      markDirty(); renderQueue();
      if (sel && sel.type === "item") renderItem(ix.byId[sel.id]);
    });
  });

  /* ---------- keyboard ---------- */
  document.addEventListener("keydown", function (e) {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "z") {
      var t0 = e.target;
      if (t0 && (t0.tagName === "INPUT" || t0.tagName === "TEXTAREA")) return;
      e.preventDefault();
      undo();
      return;
    }
    if (lightbox.isOpen()) return;
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
      e.preventDefault();
      if (window.matchMedia("(max-width: 900px)").matches) setRail(true);
      searchBox.focus(); searchBox.select();
      return;
    }
    var t = e.target;
    if (t && (t.tagName === "INPUT" || t.tagName === "TEXTAREA" ||
              t.tagName === "SELECT" || t.isContentEditable)) return;
    // stage keys first: v (play the moment), , . (frame step), Esc (exit)
    if (stageCtl && stageCtl.key && !e.metaKey && !e.ctrlKey &&
        stageCtl.key(e.key)) {
      e.preventDefault();
      return;
    }
    var it = sel && sel.type === "item" ? ix.byId[sel.id] : null;
    if (e.key === "/") {
      e.preventDefault();
      if (window.matchMedia("(max-width: 900px)").matches) setRail(true);
      searchBox.focus(); searchBox.select();
    }
    else if (viewMode === "room" && sel && sel.type === "room") {
      if (e.key === "j" || e.key === "ArrowRight") { e.preventDefault(); stepRoom(1); }
      else if (e.key === "k" || e.key === "ArrowLeft") { e.preventDefault(); stepRoom(-1); }
    }
    else if (viewMode === "items" && sel && sel.type === "item") {
      if (e.key === "j" || e.key === "ArrowRight") { e.preventDefault(); step(1); }
      else if (e.key === "k" || e.key === "ArrowLeft") { e.preventDefault(); step(-1); }
    }
    else if (e.key === "j") { e.preventDefault(); step(1); }
    else if (e.key === "k") { e.preventDefault(); step(-1); }
    else if (e.key === " " && it) {
      e.preventDefault();
      confirmItem(it);
    } else if (e.key === "x" && it) {
      e.preventDefault();
      rejectItem(it);
    } else if (it && "12345".indexOf(e.key) >= 0) {
      e.preventDefault();
      pushUndo("condition of " + it.id, [it]);
      it.condition = CONDITIONS[Number(e.key) - 1];
      it.not_inspected = null;
      markDirty(); renderItem(it);
    } else if (e.key === "Escape") closeAnnoForm();
  });

  /* ---------- deep links from the report (#item-<id>, #moment=<pid>) --- */
  function handleHash() {
    var h;
    try { h = decodeURIComponent(location.hash.replace(/^#/, "")); }
    catch (e) { h = location.hash.replace(/^#/, ""); }
    if (!h || h === "overview") {
      if (ix.items.length) showOverview();
      return h === "overview" || (!h && ix.items.length > 0);
    }
    if (h === "items") {
      startReview();
      return true;
    }
    if (h === "rooms") {
      showLastRoom();
      return true;
    }
    if (h === "finish") {
      if (ix.items.length) showFinish();
      return true;
    }
    var m = /^item-(.+)$/.exec(h);
    if (m && ix.byId[m[1]]) {
      select({ type: "item", id: m[1] });
      return true;
    }
    m = /^room-(.+)$/.exec(h);
    if (m) {
      var rname;
      try { rname = decodeURIComponent(m[1]); }
      catch (e2) { rname = m[1]; }
      var room = inv.rooms.find(function (r) { return r.name === rname; });
      if (room) {
        select({ type: "room", name: room.name });
        return true;
      }
    }
    m = /^moment=(.+)$/.exec(h);
    if (m && ix.photoById[m[1]]) {
      var pid = m[1];
      // prefer the live item citing this frame; fall back to its room
      var citing = ix.items.filter(function (i) {
        return !i.rejected && (i.photo_ids || []).indexOf(pid) >= 0;
      })[0];
      if (citing) select({ type: "item", id: citing.id });
      else select({ type: "room", name: ix.photoById[pid].room,
                    focusPid: pid });
      if (stageCtl && stageCtl.focusPid) stageCtl.focusPid(pid, true);
      return true;
    }
    return false;
  }
  window.addEventListener("hashchange", handleHash);

  /* ---------- boot ---------- */
  if (/\/finish\/?$/.test(location.pathname)) {
    var base = location.pathname.replace(/\/?finish\/?$/, "/") || "/";
    history.replaceState(null, "", base + location.search + "#finish");
  }
  renderProgress();
  renderQueue();
  if (handleHash()) {
    // deep link or explicit overview/items hash
  } else if (ix.items.length) {
    showOverview();
  } else {
    document.getElementById("detail").appendChild(el("div", {
      "class": "ev-missing",
      text: "No items in this inventory yet — run a build first." }));
  }
})();
</script>
</body>
</html>
