<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Homeinventory · Start</title>
<style>
  :root {
    --ink: #1a1a1a; --muted: #5a5f6a; --rule: #d8dbe0; --accent: #15406b;
    --band: #f3f5f8; --paper: #ffffff; --confirm: #0e6b46; --reject: #a3231f;
    --ui: "Segoe UI Variable Text", "Segoe UI", "Avenir Next", "Helvetica Neue", sans-serif;
    --mono: "Cascadia Code", "JetBrains Mono", Consolas, monospace;
  }
  * { box-sizing: border-box; }
  body { font-family: var(--ui); color: var(--ink); margin: 0;
         background: var(--band); font-size: 15px; line-height: 1.5; }
  header { background: var(--accent); color: #fff; padding: 10px 20px;
           display: flex; align-items: baseline; gap: 14px; }
  .wordmark { font-weight: 700; letter-spacing: .02em; }
  .chip { font-size: 12px; background: rgba(255,255,255,.15);
          padding: 2px 10px; border-radius: 10px; }
  main { max-width: 720px; margin: 24px auto; padding: 0 16px; }
  section { background: var(--paper); border: 1px solid var(--rule);
            border-radius: 8px; padding: 18px 20px; margin-bottom: 18px; }
  h2 { margin: 0 0 8px; font-size: 17px; color: var(--accent); }
  p { margin: 6px 0; } .muted { color: var(--muted); font-size: 13px; }
  pre { background: var(--band); padding: 10px 12px; border-radius: 6px;
        font-family: var(--mono); font-size: 12.5px; overflow-x: auto; }
  table { border-collapse: collapse; width: 100%; font-size: 14px; }
  th, td { text-align: left; padding: 6px 10px;
           border-bottom: 1px solid var(--rule); }
  th { color: var(--muted); font-weight: 600; font-size: 12.5px;
       text-transform: uppercase; letter-spacing: .05em; }
  input[type=text] { padding: 7px 9px; border: 1px solid var(--rule);
                     border-radius: 6px; font: inherit; min-width: 180px; }
  .btn { font: 600 14px var(--ui); padding: 8px 16px; border-radius: 6px;
         border: 1px solid var(--accent); background: #fff;
         color: var(--accent); cursor: pointer; }
  .btn.primary { background: var(--accent); color: #fff; }
  .btn[disabled] { opacity: .5; cursor: default; }
  .row { display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
         margin: 10px 0; }
  #build-backend { font-size: 13px; color: var(--muted); }
  #build-status, #upload-status { font-family: var(--mono); font-size: 12px;
    white-space: pre-wrap; margin-top: 8px; }
  .banner { background: #e7f3ed; border: 1px solid var(--confirm);
            border-radius: 8px; padding: 12px 16px; margin-bottom: 18px; }
  .err { color: var(--reject); }
  .cards { display: grid; gap: 12px; margin-top: 12px; }
  .card { text-align: left; padding: 14px 16px; display: flex;
          flex-direction: column; gap: 6px; width: 100%; }
  .card strong { font-size: 15px; color: var(--accent); }
</style>
</head>
<body>
<header>
  <span class="wordmark">Homeinventory · Start</span>
  <span class="chip">backend: {{ backend_label }}</span>
  {% if not show_picker %}<span class="chip" id="use-case-chip">{{ use_case_label }}</span>{% endif %}
</header>
<main>

{% if show_picker %}
<section id="use-case-picker">
  <h2>Choose a use case</h2>
  <p class="muted">Pick the workflow that matches this job. You can upload
  photos and build once a use case is selected.</p>
  <div class="cards">
  {% for u in use_cases %}
    <button class="card btn" data-use-case="{{ u.key }}" type="button">
      <strong>{{ u.name }}</strong>
      <span class="muted">{{ u.description }}</span>
    </button>
  {% endfor %}
  </div>
  <div id="picker-status"></div>
</section>
{% endif %}

{% if has_inventory %}
<div class="banner">A report already exists —
  <a href="/">open the review app</a>. Building again re-describes every room
  but keeps reviewed and hand-added items (<code>--from-json</code>).</div>
{% endif %}

{% if rooms %}
<section>
  <h2>Rooms in the capture folder</h2>
  <p class="muted">{{ capture_dir }}</p>
  <table id="room-list">
    <thead><tr><th>Room</th><th>Photos</th><th>Videos</th></tr></thead>
    <tbody>
    {% for r in rooms %}
      <tr data-room="{{ r.name }}"><td>{{ r.name }}</td>
        <td class="n-photos">{{ r.photos }}</td>
        <td class="n-videos">{{ r.videos }}</td></tr>
    {% endfor %}
    </tbody>
  </table>
</section>
{% else %}
<section id="empty-state">
  <h2>No photos yet</h2>
  <p>The capture folder is empty. Photos live in <strong>one folder per
  room</strong> — upload them from this page (name a room below), or copy
  files straight into the folder and refresh:</p>
  <pre>{{ capture_dir }}/
  Living Room/   Kitchen/   Bedroom 1/   Bathroom/ ...</pre>
  <p class="muted">Run <code>homeinventory guide</code> for the room-by-room
  shot list (walls, floor, ceiling, appliances, meters, every defect
  close-up).</p>
</section>
{% endif %}

<section id="upload">
  <h2>Upload photos</h2>
  <p class="muted">JPEG, PNG or HEIC, up to 64 MiB each. Files are stored
  byte-for-byte in the capture folder; the extension is set from the file's
  own bytes.</p>
  <div class="row">
    <input type="text" id="up-room" list="room-names" placeholder="Room name">
    <datalist id="room-names">
      {% for r in rooms %}<option value="{{ r.name }}">{% endfor %}
    </datalist>
    <input type="file" id="up-files" multiple
           accept=".jpg,.jpeg,.png,.heic,.heif,image/*">
    <button class="btn" id="btn-upload">Upload</button>
  </div>
  <div id="upload-status"></div>
</section>

<section id="build">
  <h2>Build the report</h2>
  <p class="muted">Runs the full pipeline (ingest &rarr; describe &rarr;
  report) over every room folder on the server.</p>
  <div class="row">
    <button class="btn primary" id="btn-build">Build report</button>
    <span id="build-backend">will run backend: {{ backend_label }}</span>
  </div>
  <div id="build-status"></div>
</section>

<script>
"use strict";
(function () {
  var BACKEND = {{ backend | tojson }};
  var BACKEND_LABEL = {{ backend_label | tojson }};
  var PREFIX = {{ route_prefix | tojson }};

  function api(method, url, body) {
    return fetch(url, {
      method: method,
      headers: { "Content-Type": "application/json" },
      body: body === undefined ? undefined : JSON.stringify(body)
    }).then(function (r) {
      return r.json().catch(function () { return {}; }).then(function (j) {
        if (!r.ok) throw new Error(j.error || (r.status + ""));
        return j;
      });
    });
  }

  /* ---------- upload ---------- */
  var upStatus = document.getElementById("upload-status");
  document.getElementById("btn-upload").addEventListener("click", function () {
    var room = document.getElementById("up-room").value.trim();
    var files = document.getElementById("up-files").files;
    if (!room) { upStatus.textContent = "Name a room first."; return; }
    if (!files.length) { upStatus.textContent = "Choose photo files."; return; }
    var i = 0, done = 0, failed = 0;
    upStatus.textContent = "";
    (function next() {
      if (i >= files.length) {
        upStatus.textContent += "\n" + done + " uploaded" +
          (failed ? (", " + failed + " failed") : "") + " — refreshing…";
        if (done) setTimeout(function () { location.reload(); }, 800);
        return;
      }
      var f = files[i++];
      var rd = new FileReader();
      rd.onload = function () {
        api("POST", PREFIX + "/api/photos", {
          room: room, filename: f.name,
          photo_b64: rd.result.split(",", 2)[1]
        }).then(function (r) {
          done++;
          upStatus.textContent += "ok  " + r.path + "  sha256 " +
            r.sha256.slice(0, 12) + "…\n";
          next();
        }).catch(function (e) {
          failed++;
          upStatus.textContent += "ERR " + f.name + ": " + e.message + "\n";
          next();
        });
      };
      rd.readAsDataURL(f);
    })();
  });

  /* ---------- build (spend guard: confirm names the backend) ---------- */
  var bBtn = document.getElementById("btn-build");
  var bStatus = document.getElementById("build-status");
  function pollBuild() {
    api("GET", PREFIX + "/api/build").then(function (s) {
      if (s.status === "running") {
        bBtn.disabled = true;
        bStatus.textContent = "building… (backend: " + BACKEND_LABEL + ")";
        setTimeout(pollBuild, 2000);
      } else if (s.status === "done") {
        bStatus.textContent = "done — opening the review app…";
        location.href = PREFIX + "/" || "/";
      } else if (s.status === "failed") {
        bBtn.disabled = false;
        bStatus.textContent = "build failed:\n" + (s.detail || "");
        bStatus.className = "err";
      }
    });
  }
  bBtn.addEventListener("click", function () {
    if (!window.confirm("Run a full build with backend " + BACKEND_LABEL +
                        "? Paid backends spend API money.")) return;
    bBtn.disabled = true;
    api("POST", PREFIX + "/api/build", { confirm: BACKEND }).then(function () {
      pollBuild();
    }).catch(function (e) {
      bBtn.disabled = false;
      bStatus.textContent = "could not start: " + e.message;
      bStatus.className = "err";
    });
  });
  pollBuild();   // reflect a build already in flight on page load

  /* ---------- use-case picker ---------- */
  var picker = document.getElementById("use-case-picker");
  if (picker) {
    var pStatus = document.getElementById("picker-status");
    picker.querySelectorAll("[data-use-case]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var key = btn.getAttribute("data-use-case");
        btn.disabled = true;
        api("POST", "/api/project", { use_case: key }).then(function () {
          location.reload();
        }).catch(function (e) {
          btn.disabled = false;
          pStatus.textContent = e.message;
          pStatus.className = "err";
        });
      });
    });
  }
})();
</script>
</main>
</body>
</html>
