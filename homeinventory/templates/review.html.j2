  /* ---------- lightbox (inspect + pin) ---------- */
  var lightbox = (function () {
    var box = document.getElementById("lightbox");
    var stage = document.getElementById("lb-stage");
    var canvas = document.getElementById("lb-canvas");
    var img = document.getElementById("lb-img");
    var pinBtn = document.getElementById("lb-pin");
    var playBtn = document.getElementById("lb-play");
    var zoomLbl = document.getElementById("lb-zoom");
    var cur = null;   // {it, pid, src, label, pids: [...]}
    var scale = 1, minScale = 1, tx = 0, ty = 0;
    var pinning = false;

    function apply() {
      canvas.style.transform = "translate(" + tx + "px," + ty + "px) " +
                               "scale(" + scale + ")";
      zoomLbl.textContent = Math.round(100 * scale / minScale) + "%";
    }
    function fit() {
      var sw = stage.clientWidth, sh = stage.clientHeight;
      var iw = img.naturalWidth || 1, ih = img.naturalHeight || 1;
      minScale = Math.min(sw / iw, sh / ih, 1);
      scale = minScale;
      tx = (sw - iw * scale) / 2;
      ty = (sh - ih * scale) / 2;
      apply();
    }
    function clampPan() {
      var sw = stage.clientWidth, sh = stage.clientHeight;
      var iw = (img.naturalWidth || 1) * scale;
      var ih = (img.naturalHeight || 1) * scale;
      if (iw <= sw) tx = (sw - iw) / 2;
      else tx = Math.min(0, Math.max(sw - iw, tx));
      if (ih <= sh) ty = (sh - ih) / 2;
      else ty = Math.min(0, Math.max(sh - ih, ty));
    }
    function zoomAt(factor, cx, cy) {
      var next = Math.min(Math.max(scale * factor, minScale), minScale * 12);
      var r = stage.getBoundingClientRect();
      var px = (cx - r.left - tx) / scale, py = (cy - r.top - ty) / scale;
      scale = next;
      tx = cx - r.left - px * scale;
      ty = cy - r.top - py * scale;
      clampPan();
      apply();
    }
    function drawRegions() {
      canvas.querySelectorAll(".box").forEach(function (b) { b.remove(); });
      if (!cur || !cur.pid || !cur.it) return;
      var iw = img.naturalWidth || 1, ih = img.naturalHeight || 1;
      (cur.it.defect_regions || []).forEach(function (reg, ri) {
        if (reg.photo_id !== cur.pid) return;
        var b = el("div", { "class": "box",
          title: "Double-click to remove this pin",
          ondblclick: function () {
            pushUndo("remove pin", [cur.it]);
            cur.it.defect_regions.splice(ri, 1);
            markDirty(); drawRegions();
            if (stageCtl && stageCtl.refreshPins) stageCtl.refreshPins();
          } });
        b.style.left = (reg.x * iw) + "px";
        b.style.top = (reg.y * ih) + "px";
        b.style.width = (reg.w * iw) + "px";
        b.style.height = (reg.h * ih) + "px";
        var lbl = el("span", { "class": "lbl" });
        lbl.appendChild(el("span", { "class": "ex",
          text: "Ex " + pinExhibitIndex(cur.it, reg) }));
        lbl.appendChild(document.createTextNode(reg.defect || "defect"));
        b.appendChild(lbl);
        canvas.appendChild(b);
      });
    }
    function setPinning(on) {
      if (on && !(cur && cur.pid && cur.it)) {
        toast("Pins need a cited photo — this image can't be annotated");
        return;
      }
      pinning = on;
      pinBtn.setAttribute("aria-pressed", on ? "true" : "false");
      stage.classList.toggle("pinning", on);
      document.getElementById("lb-hint").textContent = on
        ? "Drag on the photo to mark the defect area"
        : "Scroll to zoom · drag to pan · double-click a pin to remove it";
    }
    function show() {
      var pidEl = document.getElementById("lb-pid");
      pidEl.innerHTML = "";
      var pt = cur.pid && photoTime[cur.pid] ? photoTime[cur.pid] : null;
      var room = cur.it && ix.roomOf[cur.it.id] ? ix.roomOf[cur.it.id].name : "";
      if (pt || cur.pid || room) {
        pidEl.appendChild(exhibitCaption({
          t: pt ? pt.t : null, room: room, pid: cur.pid || cur.label
        }));
      } else {
        pidEl.textContent = cur.label || "";
      }
      document.getElementById("lb-title").textContent =
        cur.it ? cur.it.name || "" : "";
      playBtn.hidden = !(cur.pid && photoTime[cur.pid] &&
        videos[photoTime[cur.pid].video] &&
        !videoFail[photoTime[cur.pid].video]);
      img.onload = function () { fit(); drawRegions(); };
      img.src = cur.src;
      if (img.complete && img.naturalWidth) { fit(); drawRegions(); }
    }
    function open(it, pid, src, label) {
      cur = { it: it, pid: pid, src: src, label: label };
      cur.pids = it ? (it.photo_ids || []).filter(function (p) {
        return photoSrc[p]; }) : [];
      box.classList.add("on");
      setPinning(false);
      show();
    }
    function close() {
      box.classList.remove("on");
      closeAnnoForm();
      cur = null;
      if (stageCtl && stageCtl.refreshPins) stageCtl.refreshPins();
    }
    function stepPhoto(delta) {
      if (!cur || !cur.pids.length) return;
      var i = cur.pids.indexOf(cur.pid);
      var next = cur.pids[(Math.max(0, i) + delta + cur.pids.length)
                          % cur.pids.length];
      cur.pid = next; cur.src = photoSrc[next]; cur.label = next;
      setPinning(false);
      show();
    }

    document.getElementById("lb-close").addEventListener("click", close);
    playBtn.addEventListener("click", function () {
      if (!cur || !cur.pid || !photoTime[cur.pid]) return;
      close();
      if (stageCtl && stageCtl.key) stageCtl.key("v");
    });
    document.getElementById("lb-in").addEventListener("click", function () {
      var r = stage.getBoundingClientRect();
      zoomAt(1.4, r.left + r.width / 2, r.top + r.height / 2);
    });
    document.getElementById("lb-out").addEventListener("click", function () {
      var r = stage.getBoundingClientRect();
      zoomAt(1 / 1.4, r.left + r.width / 2, r.top + r.height / 2);
    });
    document.getElementById("lb-fit").addEventListener("click", fit);
    document.getElementById("lb-prev").addEventListener("click", function () {
      stepPhoto(-1); });
    document.getElementById("lb-next").addEventListener("click", function () {
      stepPhoto(1); });
    pinBtn.addEventListener("click", function () { setPinning(!pinning); });
    stage.addEventListener("wheel", function (e) {
      e.preventDefault();
      zoomAt(e.deltaY < 0 ? 1.18 : 1 / 1.18, e.clientX, e.clientY);
    }, { passive: false });

    var drag = null, draft = null, draftStart = null;
    stage.addEventListener("pointerdown", function (e) {
      if (e.target.closest(".box") && !pinning) return;
      stage.setPointerCapture(e.pointerId);
      if (pinning) {
        var iw = img.naturalWidth || 1, ih = img.naturalHeight || 1;
        var r = stage.getBoundingClientRect();
        draftStart = { x: (e.clientX - r.left - tx) / scale / iw,
                       y: (e.clientY - r.top - ty) / scale / ih };
        draft = el("div", { "class": "box draft" });
        canvas.appendChild(draft);
      } else {
        drag = { x: e.clientX - tx, y: e.clientY - ty };
        stage.classList.add("dragging");
      }
    });
    stage.addEventListener("pointermove", function (e) {
      if (pinning && draft && draftStart) {
        var iw = img.naturalWidth || 1, ih = img.naturalHeight || 1;
        var r = stage.getBoundingClientRect();
        var curPt = { x: (e.clientX - r.left - tx) / scale / iw,
                      y: (e.clientY - r.top - ty) / scale / ih };
        var boxN = norm(draftStart, curPt);
        draft.style.left = (boxN.x * iw) + "px";
        draft.style.top = (boxN.y * ih) + "px";
        draft.style.width = (boxN.w * iw) + "px";
        draft.style.height = (boxN.h * ih) + "px";
      } else if (drag) {
        tx = e.clientX - drag.x;
        ty = e.clientY - drag.y;
        clampPan();
        apply();
      }
    });
    stage.addEventListener("pointerup", function (e) {
      stage.classList.remove("dragging");
      if (pinning && draft && draftStart) {
        var iw = img.naturalWidth || 1, ih = img.naturalHeight || 1;
        var r = stage.getBoundingClientRect();
        var endPt = { x: (e.clientX - r.left - tx) / scale / iw,
                      y: (e.clientY - r.top - ty) / scale / ih };
        var boxN = norm(draftStart, endPt);
        draftStart = null;
        if (boxN.w < 0.01 || boxN.h < 0.01) {
          draft.remove(); draft = null;
          return;
        }
        pendingRegion = { item: cur.it, photo_id: cur.pid, box: boxN,
                          draftEl: draft, redraw: function () {
                            drawRegions();
                            if (stageCtl && stageCtl.refreshPins) {
                              stageCtl.refreshPins();
                            }
                          } };
        draft = null;
        openAnnoForm(e.clientX, e.clientY);
      }
      drag = null;
    });
    document.addEventListener("keydown", function (e) {
      if (!box.classList.contains("on")) return;
      if (e.key === "Escape") {
        e.stopPropagation();
        if (pendingRegion) closeAnnoForm();
        else close();
      }
      else if (e.key === "ArrowRight") stepPhoto(1);
      else if (e.key === "ArrowLeft") stepPhoto(-1);
    }, true);

    return { open: open, close: close, drawRegions: drawRegions,
             isOpen: function () { return box.classList.contains("on"); } };
  })();

  /* ---------- defect-pin label form ---------- */
  var pendingRegion = null;
  function norm(a, b) {
    function clamp(v) { return Math.max(0, Math.min(1, v)); }
    var x1 = clamp(Math.min(a.x, b.x)), y1 = clamp(Math.min(a.y, b.y));
    var x2 = clamp(Math.max(a.x, b.x)), y2 = clamp(Math.max(a.y, b.y));
    return { x: x1, y: y1, w: x2 - x1, h: y2 - y1 };
  }
  function openAnnoForm(px, py) {
    var f = document.getElementById("anno-form");
    var pick = document.getElementById("anno-pick");
    pick.innerHTML = "";
    pick.appendChild(el("option", { value: "", text: "Pin which defect?" }));
    (pendingRegion.item.defects || []).forEach(function (t) {
      pick.appendChild(el("option", { value: t, text: t }));
    });
    document.getElementById("anno-new").value = "";
    f.style.display = "block";
    f.style.left = Math.min(px, window.innerWidth - 300) + "px";
    f.style.top = Math.min(py + 8, window.innerHeight - 170) + "px";
  }
  function closeAnnoForm() {
    document.getElementById("anno-form").style.display = "none";
    if (pendingRegion && pendingRegion.draftEl) pendingRegion.draftEl.remove();
    pendingRegion = null;
  }
  document.getElementById("anno-cancel").addEventListener("click", closeAnnoForm);
  document.getElementById("anno-ok").addEventListener("click", function () {
    if (!pendingRegion) return;
    var label = document.getElementById("anno-new").value.trim() ||
                document.getElementById("anno-pick").value;
    if (!label) { toast("Pick or describe the defect first"); return; }
    var it = pendingRegion.item;
    pushUndo("pin defect on " + it.id, [it]);
    if ((it.defects || []).indexOf(label) === -1 &&
        (it.rejected_defects || []).indexOf(label) === -1) {
      (it.defects = it.defects || []).push(label);
    }
    (it.defect_regions = it.defect_regions || []).push({
      defect: label, photo_id: pendingRegion.photo_id,
      x: pendingRegion.box.x, y: pendingRegion.box.y,
      w: pendingRegion.box.w, h: pendingRegion.box.h });
    var redraw = pendingRegion.redraw;
    if (pendingRegion.draftEl) pendingRegion.draftEl.remove();
    pendingRegion = null;
    document.getElementById("anno-form").style.display = "none";
    markDirty();
    if (redraw) redraw();
    if (sel && sel.type === "item" && !lightbox.isOpen()) {
      renderItem(ix.byId[sel.id]);
    }
  });

  /* ---------- room view ---------- */
  function renderRoom(room) {
    var d = document.getElementById("detail");
    d.innerHTML = "";
    stageCtl = null;
    overviewHost = null;

    var ri = roomIndex(room.name);
    var prevRoom = ri > 0 ? inv.rooms[ri - 1] : null;
    var nextRoom = ri >= 0 && ri < inv.rooms.length - 1 ? inv.rooms[ri + 1] : null;

    d.appendChild(buildReviewNav({
      ariaLabel: "Room navigation",
      title: room.name,
      subtitle: ri >= 0 ? (ri + 1) + " of " + inv.rooms.length : "",
      prev: prevRoom ? {
        label: prevRoom.name,
        onClick: function () { select({ type: "room", name: prevRoom.name }); }
      } : null,
      next: nextRoom ? {
        label: nextRoom.name,
        onClick: function () { select({ type: "room", name: nextRoom.name }); }
      } : null
    }));

    var grid = el("div", { "class": "room-grid" });
    d.appendChild(grid);

    // left: the room's footage on the stage — the curated hero set by
    // default (docs/15 M2), the full frame record one click behind it
    var allPids = (room.photos || []).map(function (p) { return p.id; })
      .filter(function (pid) { return photoSrc[pid]; });
    var heroPids = (room.photos || [])
      .filter(function (p) { return p.hero && photoSrc[p.id]; })
      .sort(function (a, b) { return a.hero - b.hero; })
      .map(function (p) { return p.id; });
    var curated = heroPids.length > 0 && heroPids.length < allPids.length;
    var showAll = !curated || !!roomShowAll[room.name] ||
      (sel && sel.focusPid && heroPids.indexOf(sel.focusPid) < 0);
    function photoOf(pid) {
      return (room.photos || []).filter(function (p) {
        return p.id === pid; })[0] || null;
    }
    var ctl = buildStage(grid, {
      pids: showAll ? allPids : heroPids,
      crop: null, item: null, roomName: room.name,
      curate: {
        isHero: function (pid) {
          var p = photoOf(pid);
          return !!(p && p.hero);
        },
        toggle: function (pid) {
          var p = photoOf(pid);
          if (!p) return;
          var action = p.hero ? "demote" : "promote";
          api("POST", "/api/curation", { photo_id: pid, action: action })
            .then(function (res) {
              p.hero = res.hero;
              toast(action === "promote"
                ? pid + " added to this room's highlights"
                : pid + " removed from highlights — it stays under "
                  + "All frames");
              if (stageCtl && stageCtl.refreshPins) stageCtl.refreshPins();
            })
            .catch(function (e) { toast("Could not save: " + e.message); });
        }
      } });
    if (curated && ctl && ctl.host) {
      ctl.host.appendChild(el("button", {
        "class": "btn ghost stage-toggle",
        text: showAll
          ? "Highlights only (" + heroPids.length + " frames)"
          : "All " + allPids.length + " frames — blurred passes included",
        onclick: function () {
          roomShowAll[room.name] = !showAll;
          renderRoom(room);
        } }));
    }

    var panel = el("div", { "class": "room-panel" });
    var panelBody = el("div", { "class": "room-panel-body" });
    panel.appendChild(panelBody);
    grid.appendChild(panel);

    var renameRow = el("div", { "class": "add-form" });
    var renameInput = el("input", { type: "text", value: room.name,
      placeholder: "Room name" });
    var renameBtn = el("button", { "class": "btn", text: "Rename room" });
    renameBtn.addEventListener("click", function () {
      var nm = renameInput.value.trim();
      if (!nm || nm === room.name) return;
      renameBtn.disabled = true;
      api("POST", "/api/rooms/rename", { from: room.name, to: nm })
        .then(function () { location.reload(); })
        .catch(function (e) { renameBtn.disabled = false; toast(e.message); });
    });
    renameRow.appendChild(renameInput);
    renameRow.appendChild(renameBtn);
    var mergeRow = el("div", { "class": "add-form" });
    var mergeSelect = el("select", {});
    mergeSelect.appendChild(el("option", { value: "", text: "Merge into…" }));
    inv.rooms.forEach(function (r) {
      if (r.name !== room.name) {
        mergeSelect.appendChild(el("option", { value: r.name, text: r.name }));
      }
    });
    var mergeBtn = el("button", { "class": "btn", text: "Merge into neighbour" });
    mergeBtn.addEventListener("click", function () {
      if (!mergeSelect.value) { toast("Pick a room to merge into"); return; }
      ui.confirmDialog({
        title: "Merge rooms?",
        message: "Move every item and photo from " + room.name + " into "
