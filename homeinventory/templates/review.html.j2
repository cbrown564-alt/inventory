  function buildStage(host, opts) {
    // opts: {pids: [pid…] with sources, crop: url|null, item: item|null,
    //        roomName: str}
    var pids = opts.pids || [];
    var entries = [];             // {kind:"photo"|"crop", pid, src, label}
    if (opts.crop) entries.push({ kind: "crop", pid: null, src: opts.crop,
