    var box = el("div", { "class": "stage-col" });
    host.appendChild(box);

    if (!entries.length) {
      var stage0 = el("div", { id: "stage" });
      stage0.appendChild(el("div", { "class": "media" }, [
        el("div", { "class": "stage-empty" }, [
          el("b", { text: "No footage cited for this item" }),
          el("span", { text: "Confirm it only if you can vouch for it " +
            "yourself, or reject it. You can add a photo from the room view." })
