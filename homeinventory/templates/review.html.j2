    // keyboard hints — hidden until requested
    var foot = el("div", { "class": "claim-foot" });
    foot.appendChild(disclosure("Keyboard shortcuts", "", function (body) {
      var kb = el("div", { "class": "kbd-row" });
      [["space", "confirm + next"], ["x", "reject"], ["j k", "move"],
       ["v", "play moment"], ["/", "search"], ["⌘Z", "undo"]]
        .forEach(function (pair) {
