<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ use_case_label }} — Homeinventory</title>
{% include "_favicon.j2" %}
<style>
{% include "_theme.css.j2" %}

  main { max-width: 820px; margin: 0 auto; padding: 0 20px 60px; }
  h1 { font: 600 clamp(26px, 3.4vw, 34px)/1.15 var(--display);
       letter-spacing: -.01em; margin: 40px 0 8px; }
  .lede { color: var(--muted); margin: 0 0 28px; max-width: 56ch; }

  .slots { display: grid; gap: 16px; }
  @media (min-width: 620px) { .slots { grid-template-columns: 1fr 1fr; } }
  .slot { background: var(--panel); border: 1px solid var(--line-strong);
          border-radius: 12px; padding: 16px 18px 18px;
          border-top: 3px solid var(--brass); }
  .slot h3 { margin: 0 0 2px; font: 600 18px/1.3 var(--display); }
  .slot .state { font-size: 12.5px; margin: 0 0 12px; }
  .slot .state.ok { color: var(--confirm); font-weight: 600; }
  .slot .state.pending { color: var(--faint); }
  .drop { background:
      radial-gradient(240px 120px at 50% -40px, #1a2029 0%, #0e1116 70%);
    border: 2px dashed rgba(200, 163, 92, .45); border-radius: 9px;
    padding: 20px 12px; text-align: center; color: #94a1b2;
    cursor: pointer; font-size: 13px;
    transition: border-color .18s; }
  .drop:hover { border-color: #e5c47f; }
  .up-status { font-size: 12.5px; margin-top: 8px; min-height: 1.2em;
               color: var(--muted); }
  .up-status.ok { color: var(--confirm); }
  .up-status.err { color: var(--danger); }
  .slot .row { display: flex; gap: 8px; margin-top: 12px; }
  .slot .btn { text-decoration: none; display: inline-block; }

  #compare { margin-top: 26px; background: var(--panel);
             border: 1px solid var(--line); border-radius: 12px;
             padding: 18px 20px; }
  #compare h2 { margin: 0 0 6px; font: 600 18px/1.3 var(--display); }
  #compare .ok { color: var(--confirm); font-weight: 600; }
  #compare .btn { text-decoration: none; display: inline-block;
                  margin-top: 8px; }
  #compare-status { font-size: 13px; margin-top: 6px; }
  .muted { color: var(--muted); font-size: 13.5px; }
  .err { color: var(--danger); }
</style>
</head>
<body>
<header class="app-header">
  <span class="wordmark">Homeinventory</span>
  <span class="header-chip">{{ use_case_label }}</span>
</header>
<main>

<h1>{{ use_case_label }}</h1>
<p class="lede">Drop a walkthrough video for each visit. When both reports
are built, the comparison sheet appears automatically.</p>

<section class="slots">
  {% for s in sessions %}
  <div class="slot" data-session="{{ s.key }}">
    <h3>{{ s.label }}</h3>
    <p class="state {% if s.built %}ok{% else %}pending{% endif %}">
      {% if s.built %}Report ready{% else %}Waiting for video{% endif %}
    </p>
    <div class="drop" data-prefix="{{ s.prefix }}" tabindex="0" role="button"
         aria-label="Upload {{ s.label|lower }} video">
      Drop the {{ s.label|lower }} video here
    </div>
    <input type="file" class="up-input" accept="video/*" hidden>
    <div class="up-status"></div>
    <div class="row">
      <a class="btn" href="{{ s.prefix }}/start">Open session</a>
      {% if s.built %}<a class="btn primary" href="{{ s.prefix }}/">Review</a>{% endif %}
    </div>
  </div>
  {% endfor %}
</section>

<section id="compare">
  <h2>Comparison</h2>
  {% if compare_built %}
  <p class="ok">Comparison ready.</p>
  <a class="btn primary" href="/compare/">Open comparison sheet</a>
  {% elif compare_running %}
  <p id="compare-status">Building comparison…</p>
  {% elif compare_ready %}
  <p class="muted">Both reports are built — comparison runs automatically.</p>
  {% else %}
  <p class="muted">Upload and build both videos to see the comparison.</p>
  {% endif %}
</section>

<script>
"use strict";
(function () {
  var WALK = "__walkthrough__";

  function upload(prefix, file, statusEl, dropEl) {
    statusEl.textContent = "Uploading…";
    statusEl.className = "up-status";
    var xhr = new XMLHttpRequest();
    xhr.open("POST", prefix + "/api/upload");
    xhr.setRequestHeader("X-Room", encodeURIComponent(WALK));
    xhr.setRequestHeader("X-Filename", encodeURIComponent(file.name));
    xhr.onload = function () {
      if (xhr.status === 200) {
        statusEl.textContent = "Uploaded — open the session to build.";
        statusEl.className = "up-status ok";
      } else {
        var resp = {};
        try { resp = JSON.parse(xhr.responseText || "{}"); } catch (e) {}
        statusEl.textContent = resp.error || "Upload failed";
        statusEl.className = "up-status err";
      }
    };
    xhr.onerror = function () {
      statusEl.textContent = "Network error";
      statusEl.className = "up-status err";
    };
    xhr.send(file);
  }

  document.querySelectorAll(".slot").forEach(function (slot) {
    var drop = slot.querySelector(".drop");
    var input = slot.querySelector(".up-input");
    var statusEl = slot.querySelector(".up-status");
    var prefix = drop.getAttribute("data-prefix") || "";
    drop.addEventListener("click", function () { input.click(); });
    input.addEventListener("change", function () {
      if (input.files && input.files[0]) {
        upload(prefix, input.files[0], statusEl, drop);
        input.value = "";
      }
    });
    drop.addEventListener("keydown", function (e) {
      if (e.key === "Enter" || e.key === " ") { e.preventDefault(); input.click(); }
    });
  });

  function pollCompare() {
    var el = document.getElementById("compare-status");
    if (!el) return;
    fetch("/api/compare").then(function (r) { return r.json(); })
      .then(function (s) {
        if (s.status === "running") {
          el.textContent = "Building comparison…";
          setTimeout(pollCompare, 2000);
        } else if (s.status === "done") {
          location.href = "/compare/";
        } else if (s.status === "failed") {
          el.textContent = "Comparison failed: " + (s.detail || "");
          el.className = "err";
        }
      }).catch(function () {});
  }
  pollCompare();
})();
</script>
</main>
</body>
</html>
