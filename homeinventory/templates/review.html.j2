    }

    // pick the first entry that has a timestamp, else the first photo
    var startIdx = 0;
    for (var i = 0; i < entries.length; i++) {
      if (entries[i].pid && photoTime[entries[i].pid]) { startIdx = i; break; }
    }

    var stage = el("div", { id: "stage" });
    var media = el("div", { "class": "media" });
    stage.appendChild(media);
    var hudTL = el("div", { "class": "hud tl" });
    var hudTR = el("div", { "class": "hud tr" });
    var hudBL = el("div", { "class": "hud bl" });
    stage.appendChild(hudTL); stage.appendChild(hudTR);
    stage.appendChild(hudBL);
    box.appendChild(stage);

    var strip, spine, prov;
    var foot = el("div", { "class": "stage-foot" });
    prov = el("div", { "class": "prov" });
    foot.appendChild(prov);

    strip = entries.length > 1
      ? el("div", { "class": "strip", role: "listbox",
                    "aria-label": "Evidence frames" })
      : null;
    var spinePinned = !!opts.item;
    spine = el("div", { id: "spine", hidden: "hidden",
      "class": spinePinned ? "spine-pinned" : "" });
    if (spinePinned) foot.appendChild(spine);
    var extraHint = el("span", { "class": "disclosure-hint", text: "" });
