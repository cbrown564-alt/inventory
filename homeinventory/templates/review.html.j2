      text: "Walkthrough spine" }));
    var spine = el("div", { id: "spine" });
    var meta = wt.meta;
    var segs = meta.segments || [];
    var chapters = el("div", { "class": "chapters" });
    segs.forEach(function (s) {
      var w = Math.max(4, 100 * ((s.end - s.start) / meta.duration));
      var chap = el("div", { "class": "chap",
        title: (s.room || "Room") + " \u00b7 " + fmtT(s.start),
        style: "flex:" + w,
        onclick: function () {
          showWalkthroughPlayer(overviewHost, wt, s.start);
        } });
      chap.appendChild(el("span", { text: s.room || "" }));
      chapters.appendChild(chap);
    });
    spine.appendChild(chapters);
    var scrub = el("div", { "class": "scrub" });
    scrub.appendChild(el("div", { "class": "rail-line" }));
    Object.keys(photoTime).forEach(function (pid) {
      var pt = photoTime[pid];
      if (!pt || pt.video !== wt.rel || meta.duration <= 0) return;
      var left = (100 * pt.t / meta.duration);
      var tick = el("div", { "class": "tick cited",
        style: "left:" + left + "%",
        title: "seen at " + fmtT(pt.t) });
      scrub.appendChild(tick);
    });
    var playhead = el("div", { "class": "playhead", style: "left:0%" });
    scrub.appendChild(playhead);
    scrub.addEventListener("click", function (e) {
      var r = scrub.getBoundingClientRect();
      var t = Math.max(0, Math.min(1, (e.clientX - r.left) / r.width))
              * meta.duration;
      showWalkthroughPlayer(overviewHost, wt, t);
    });
    spine.appendChild(scrub);
    wrap.appendChild(spine);
