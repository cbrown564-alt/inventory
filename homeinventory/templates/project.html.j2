<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Before &amp; after — Homeinventory</title>
<style>
  :root {
    --ink: #1a1a1a; --muted: #5a5f6a; --rule: #d8dbe0; --accent: #15406b;
    --band: #f3f5f8; --paper: #ffffff; --confirm: #0e6b46; --reject: #a3231f;
    --ui: "Segoe UI Variable Text", "Segoe UI", "Avenir Next", "Helvetica Neue", sans-serif;
    --mono: "Cascadia Code", "JetBrains Mono", Consolas, monospace;
  }
  * { box-sizing: border-box; }
  body { font-family: var(--ui); color: var(--ink); margin: 0;
         background: var(--band); font-size: 15px; line-height: 1.5; }
  header { background: var(--accent); color: #fff; padding: 10px 20px;
           display: flex; align-items: baseline; gap: 14px; flex-wrap: wrap; }
  .wordmark { font-weight: 700; letter-spacing: .02em; }
  .chip { font-size: 12px; background: rgba(255,255,255,.15);
          padding: 2px 10px; border-radius: 10px; }
  main { max-width: 760px; margin: 24px auto; padding: 0 16px; }
  section { background: var(--paper); border: 1px solid var(--rule);
            border-radius: 8px; padding: 18px 20px; margin-bottom: 18px; }
  h2 { margin: 0 0 8px; font-size: 17px; color: var(--accent); }
  p { margin: 6px 0; } .muted { color: var(--muted); font-size: 13px; }
  .slots { display: grid; gap: 16px; }
  @media (min-width: 560px) { .slots { grid-template-columns: 1fr 1fr; } }
  .slot { border: 1px solid var(--rule); border-radius: 8px; padding: 14px; }
  .slot h3 { margin: 0 0 6px; font-size: 15px; }
  .drop { border: 2px dashed var(--rule); border-radius: 8px; padding: 18px 12px;
          text-align: center; color: var(--muted); cursor: pointer; font-size: 13px; }
  .drop:hover { border-color: var(--accent); background: #f0f4f8; }
  .ok { color: var(--confirm); font-weight: 600; }
  .pending { color: var(--muted); }
  .btn { font: 600 14px var(--ui); padding: 8px 16px; border-radius: 6px;
         border: 1px solid var(--accent); background: #fff;
         color: var(--accent); cursor: pointer; text-decoration: none;
         display: inline-block; margin-top: 8px; }
  .btn.primary { background: var(--accent); color: #fff; }
  .btn[disabled] { opacity: .5; cursor: default; }
  #compare-status { font-size: 13px; margin-top: 8px; }
  .err { color: var(--reject); }
</style>
</head>
<body>
<header>
  <span class="wordmark">Homeinventory</span>
  <span class="chip">{{ use_case_label }}</span>
</header>
<main>

<section>
  <h2>Before &amp; after clean</h2>
  <p class="muted">Drop a walkthrough video for each visit. When both reports
  are built, the comparison sheet appears automatically.</p>
</section>

<section class="slots">
  {% for s in sessions %}
  <div class="slot" data-session="{{ s.key }}">
    <h3>{{ s.label }}</h3>
    <p class="{% if s.built %}ok{% else %}pending{% endif %}">
      {% if s.built %}Report ready{% else %}Waiting for video{% endif %}
    </p>
    <div class="drop" data-prefix="{{ s.prefix }}" tabindex="0" role="button"
         aria-label="Upload {{ s.label|lower }} video">
      Drop {{ s.label|lower }} video
    </div>
    <input type="file" class="up-input" accept="video/*" hidden>
    <div class="up-status muted"></div>
    <a class="btn" href="{{ s.prefix }}/start">Open session</a>
    {% if s.built %}<a class="btn" href="{{ s.prefix }}/">Review</a>{% endif %}
  </div>
  {% endfor %}
</section>

<section id="compare">
  <h2>Comparison</h2>
  {% if compare_built %}
  <p class="ok">Comparison ready.</p>
  <a class="btn primary" href="/compare/">Open comparison sheet</a>
  {% elif compare_running %}
  <p id="compare-status">Building comparison…</p>
  {% elif compare_ready %}
  <p class="muted">Both reports are built — comparison runs automatically.</p>
  {% else %}
  <p class="muted">Upload and build both videos to see the comparison.</p>
  {% endif %}
</section>

<script>
"use strict";
(function () {
  var WALK = "__walkthrough__";

  function upload(prefix, file, statusEl, dropEl) {
    statusEl.textContent = "Uploading…";
    var xhr = new XMLHttpRequest();
    xhr.open("POST", prefix + "/api/upload");
    xhr.setRequestHeader("X-Room", encodeURIComponent(WALK));
    xhr.setRequestHeader("X-Filename", encodeURIComponent(file.name));
    xhr.onload = function () {
      if (xhr.status === 200) {
        statusEl.textContent = "Uploaded — open the session to build.";
        statusEl.className = "ok";
      } else {
        var resp = {};
        try { resp = JSON.parse(xhr.responseText || "{}"); } catch (e) {}
        statusEl.textContent = resp.error || "Upload failed";
        statusEl.className = "err";
      }
    };
    xhr.onerror = function () {
      statusEl.textContent = "Network error";
      statusEl.className = "err";
    };
    xhr.send(file);
  }

  document.querySelectorAll(".slot").forEach(function (slot) {
    var drop = slot.querySelector(".drop");
    var input = slot.querySelector(".up-input");
    var statusEl = slot.querySelector(".up-status");
    var prefix = drop.getAttribute("data-prefix") || "";
    drop.addEventListener("click", function () { input.click(); });
    input.addEventListener("change", function () {
      if (input.files && input.files[0]) {
        upload(prefix, input.files[0], statusEl, drop);
        input.value = "";
      }
    });
    drop.addEventListener("keydown", function (e) {
      if (e.key === "Enter" || e.key === " ") { e.preventDefault(); input.click(); }
    });
  });

  function pollCompare() {
    var el = document.getElementById("compare-status");
    if (!el) return;
    fetch("/api/compare").then(function (r) { return r.json(); })
      .then(function (s) {
        if (s.status === "running") {
          el.textContent = "Building comparison…";
          setTimeout(pollCompare, 2000);
        } else if (s.status === "done") {
          location.href = "/compare/";
        } else if (s.status === "failed") {
          el.textContent = "Comparison failed: " + (s.detail || "");
          el.className = "err";
        }
      }).catch(function () {});
  }
  pollCompare();
})();
</script>
</main>
</body>
</html>
