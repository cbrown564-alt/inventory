<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Review — {{ inv.property_address or "Property inventory" }}</title>
<style>
{% include "_theme.css.j2" %}

  html, body { height: 100%; }
  body { display: flex; flex-direction: column; }

  /* ---------- header ---------- */
  .addr { font-weight: 500; color: var(--muted); font-size: 13px;
          max-width: 300px; overflow: hidden; text-overflow: ellipsis;
          white-space: nowrap; }
  #progress { flex: 1 1 170px; min-width: 140px; }
  #progress .label { font-size: 12px; color: var(--muted);
                     font-variant-numeric: tabular-nums; }
  #progress .track { height: 4px; background: var(--line); border-radius: 2px;
                     overflow: hidden; margin-top: 3px; }
  #progress .fill { height: 100%; width: 0; background: var(--confirm);
                    transition: width .35s cubic-bezier(.16,1,.3,1); }
  #save-state { font-size: 12px; color: var(--muted); white-space: nowrap;
                min-width: 88px; text-align: right; }
  #save-state.err { color: var(--danger); }
  .share { font-family: var(--mono); font-size: 11px; color: var(--muted); }
  .share a { color: var(--accent-ink); }
  #btn-queue { display: none; }

  /* ---------- layout ---------- */
  #app { flex: 1; display: grid; grid-template-columns: 360px 1fr;
         min-height: 0; }

  /* ---------- queue rail ---------- */
  #rail { border-right: 1px solid var(--line); background: var(--panel);
          overflow-y: auto; }
  #rail .tools { position: sticky; top: 0; background: var(--panel);
                 padding: 12px 16px 8px; border-bottom: 1px solid var(--line);
                 z-index: 5; }
  #q-search { width: 100%; font: 13px var(--ui); padding: 6px 10px;
              margin-bottom: 8px; border: 1px solid var(--line-strong);
              border-radius: 6px; background: #fff; color: var(--ink); }
  #q-search:focus { outline: 2px solid var(--accent); outline-offset: -1px; }
  .filters { display: flex; gap: 6px; flex-wrap: wrap; }
  .filters button {
    border: 1px solid var(--line); background: transparent; color: var(--muted);
    border-radius: 999px; font-size: 12px; padding: 3px 11px; cursor: pointer;
  }
  .filters button[aria-pressed="true"] { background: var(--accent);
    border-color: var(--accent); color: #fff; }
  .tools .row2 { display: flex; gap: 6px; margin-top: 8px; align-items: center; }
  .tools select { font: 12px var(--ui); border: 1px solid var(--line);
                  border-radius: 5px; padding: 3px 6px; background: #fff;
                  color: var(--muted); }
  #bulk { font-size: 12px; padding: 4px 10px; }

  .room-head {
    padding: 14px 16px 4px; font-size: 11px; font-weight: 600;
    letter-spacing: .12em; text-transform: uppercase; color: var(--muted);
    display: flex; justify-content: space-between; align-items: baseline;
    cursor: pointer;
  }
  .room-head:hover { color: var(--accent-ink); }
  .room-head .n { font-family: var(--mono); font-size: 10px; }
  .q-item {
    display: grid; grid-template-columns: 14px 1fr auto; gap: 10px;
    align-items: center; padding: 8px 16px; cursor: pointer;
    border-top: 1px solid var(--line);
  }
  .q-item:hover { background: var(--paper); }
  .q-item.active { background: var(--accent-soft); }
  .q-item .dot { width: 8px; height: 8px; border-radius: 50%;
                 border: 1.5px solid var(--line-strong); }
  .q-item.done .dot { background: var(--confirm); border-color: var(--confirm); }
  .q-item.bad .dot { background: var(--danger); border-color: var(--danger); }
  .q-item .name { font-weight: 500; font-size: 13px; overflow: hidden;
                  text-overflow: ellipsis; white-space: nowrap; }
  .q-item .name .ref { font-family: var(--mono); font-size: 10px;
                       color: var(--muted); margin-right: 6px; }
  .q-item .name .sub { display: block; font-size: 11px; color: var(--muted);
                       font-weight: 400; }
  .q-item.bad .name { text-decoration: line-through; color: var(--muted); }
  .conf { width: 44px; }
  .conf .t { height: 3px; background: var(--line); border-radius: 2px;
             overflow: hidden; }
  .conf .f { height: 100%; background: var(--pend); }
  .conf .v { font-family: var(--mono); font-size: 9px; color: var(--muted);
             text-align: right; display: block; }
  .empty-queue { padding: 28px 16px; color: var(--muted); font-size: 13px;
                 text-align: center; }
  #rail-backdrop { display: none; }

  /* ---------- detail pane ---------- */
  #detail { overflow-y: auto; padding: 26px 34px 140px; min-width: 0; }
  .crumb { font-family: var(--mono); font-size: 11px; color: var(--muted);
           display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
  .badge { font-size: 10px; font-weight: 600; letter-spacing: .08em;
           text-transform: uppercase; border-radius: 3px; padding: 2px 7px; }
  .badge.ok { color: var(--confirm); background: var(--confirm-soft); }
  .badge.no { color: var(--danger); background: var(--danger-soft); }
  .badge.pend { color: var(--pend); background: var(--pend-soft); }
  .badge.prov { color: var(--muted); background: var(--paper);
                border: 1px solid var(--line); text-transform: none;
                letter-spacing: 0; font-weight: 500; }
  #d-name {
    font: 600 26px/1.2 var(--ui); letter-spacing: -.02em; color: var(--ink);
    border: none; background: transparent; width: 100%; margin: 10px 0 2px;
    padding: 2px 0; border-bottom: 1px dashed transparent;
  }
  #d-name:hover, #d-name:focus { border-bottom-color: var(--line-strong);
                                 outline: none; }
  #d-desc {
    font: 14px/1.5 var(--ui); color: var(--ink); width: 100%; min-height: 54px;
    border: 1px solid transparent; background: transparent; resize: vertical;
    padding: 4px 0; border-radius: 5px;
  }
  #d-desc:hover { border-color: var(--line); }
  #d-desc:focus { border-color: var(--accent); outline: none; background: #fff;
                  padding: 4px 8px; }
  .grades { display: flex; gap: 26px; margin: 16px 0; flex-wrap: wrap; }
  .grades label { display: block; font-size: 11px; font-weight: 600;
    letter-spacing: .1em; text-transform: uppercase; color: var(--muted);
    margin-bottom: 4px; }
  .grades select { font: 13px var(--ui); padding: 6px 10px; min-width: 180px;
    border: 1px solid var(--line-strong); border-radius: 5px; background: #fff; }
  .sec { margin-top: 22px; padding-top: 14px; border-top: 1px solid var(--line); }
  .sec > h3 { margin: 0 0 8px; font-size: 11px; font-weight: 600;
    letter-spacing: .12em; text-transform: uppercase; color: var(--muted); }

  .chip {
    display: inline-flex; align-items: center; gap: 6px; margin: 2px 6px 2px 0;
    font-size: 13px; color: var(--danger); background: var(--danger-soft);
    border: 1px solid #e6c8c7; border-radius: 999px; padding: 3px 12px;
    cursor: pointer; user-select: none;
  }
  .chip:active { transform: scale(.97); }
  .chip.struck { color: var(--muted); background: var(--paper);
                 border-color: var(--line); text-decoration: line-through; }
  .chip .x { font-size: 11px; opacity: .6; }
  .def-add { display: flex; gap: 6px; margin-top: 8px; max-width: 460px; }
  .def-add input { flex: 1; font: 13px var(--ui); padding: 6px 10px;
    border: 1px solid var(--line-strong); border-radius: 5px; }

  /* evidence grid (click opens the lightbox) */
  .ev-grid { display: grid; grid-template-columns: repeat(auto-fill,
             minmax(220px, 1fr)); gap: 14px; }
  .ev-thumb { position: relative; border: 1px solid var(--line);
              background: #111; cursor: zoom-in; padding: 0; display: block;
              width: 100%; }
  .ev-thumb img { width: 100%; display: block; }
  .ev-thumb .pid { position: absolute; left: 0; top: 0; z-index: 3;
    background: rgba(28,36,48,.82); color: #fff; font: 10px var(--mono);
    padding: 2px 7px; }
  .ev-thumb .n-pins { position: absolute; right: 0; bottom: 0; z-index: 3;
    background: var(--danger); color: #fff; font: 10px var(--ui);
    padding: 1px 7px; }
  .ev-thumb:focus-visible { outline: 2px solid var(--accent);
                            outline-offset: 2px; }
  .ev-missing { color: var(--pend); background: var(--pend-soft);
    border: 1px solid #e8dcb2; border-radius: 5px; padding: 10px 14px;
    font-size: 13px; }

  /* ---------- lightbox ---------- */
  #lightbox { position: fixed; inset: 0; z-index: 70; background:
              rgba(16,20,26,.94); display: none; flex-direction: column; }
  #lightbox.on { display: flex; }
  #lb-top { display: flex; align-items: center; gap: 12px; padding: 10px 16px;
            color: #dfe3e8; font-size: 13px; }
  #lb-top .pid { font-family: var(--mono); font-size: 12px; color: #9aa3ad; }
  #lb-top .spacer { flex: 1; }
  .lb-btn { border: 1px solid rgba(255,255,255,.25); background: transparent;
            color: #eef1f4; border-radius: 6px; padding: 6px 12px;
            font-size: 13px; cursor: pointer; }
  .lb-btn:hover { border-color: #fff; }
  .lb-btn[aria-pressed="true"] { background: var(--danger);
                                 border-color: var(--danger); }
  #lb-stage { flex: 1; position: relative; overflow: hidden; cursor: grab; }
  #lb-stage.pinning { cursor: crosshair; }
  #lb-stage.dragging { cursor: grabbing; }
  #lb-canvas { position: absolute; transform-origin: 0 0; }
  #lb-canvas img { display: block; user-select: none; -webkit-user-drag: none; }
  #lb-canvas .box { position: absolute; border: 2px solid var(--danger);
    background: rgba(163,35,31,.12); }
  #lb-canvas .box .lbl { position: absolute; left: -2px; bottom: 100%;
    background: var(--danger); color: #fff; font: 11px var(--ui);
    padding: 1px 6px; white-space: nowrap; max-width: 260px; overflow: hidden;
    text-overflow: ellipsis; }
  #lb-canvas .box.draft { border-style: dashed;
                          background: rgba(163,35,31,.07); }
  #lb-bottom { display: flex; align-items: center; justify-content: center;
               gap: 10px; padding: 10px 16px; color: #9aa3ad; font-size: 12px;
               flex-wrap: wrap; }
  #lb-zoom { font-family: var(--mono); min-width: 46px; text-align: center; }
  #lb-hint { font-size: 12px; }

  /* annotation label popover (shared by lightbox pins) */
  #anno-form { position: fixed; z-index: 95; background: var(--panel);
    border: 1px solid var(--line-strong); border-radius: 8px; padding: 10px;
    box-shadow: 0 12px 32px -12px rgba(28,36,48,.4); display: none;
    width: 280px; }
  #anno-form select, #anno-form input { width: 100%; font: 13px var(--ui);
    padding: 6px 8px; margin-bottom: 6px; border: 1px solid var(--line-strong);
    border-radius: 5px; }
  #anno-form .row { display: flex; gap: 6px; justify-content: flex-end; }

  /* comments */
  .c-line { padding: 7px 0; border-top: 1px dotted var(--line); font-size: 13px; }
  .c-line .who { font-weight: 600; font-size: 12px; }
  .c-line .who.tenant { color: var(--tenant); }
  .c-line .who.landlord, .c-line .who.agent { color: var(--accent-ink); }
  .c-line .at { font-family: var(--mono); font-size: 10px; color: var(--muted);
                margin-left: 8px; }
  .c-add { display: flex; gap: 6px; margin-top: 8px; max-width: 560px; }
  .c-add input { flex: 1; font: 13px var(--ui); padding: 7px 10px;
    border: 1px solid var(--line-strong); border-radius: 5px; }

  /* sticky item actions */
  #actions {
    position: sticky; bottom: 0; margin: 30px -34px 0; padding: 12px 34px;
    background: var(--panel); border-top: 1px solid var(--line);
    display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
  }
  .kbd { font-family: var(--mono); font-size: 10px; color: var(--muted);
         background: var(--paper); border: 1px solid var(--line);
         border-radius: 3px; padding: 0 5px; }
  .kbd-label { font-size: 12px; color: var(--muted); }

  /* room view */
  .room-summary { width: 100%; min-height: 70px; font: 14px/1.5 var(--ui);
    border: 1px solid var(--line); border-radius: 5px; padding: 10px 12px;
    background: #fff; resize: vertical; }
  .add-form { display: grid; gap: 8px; max-width: 460px; }
  .add-form input, .add-form select { font: 13px var(--ui); padding: 7px 10px;
    border: 1px solid var(--line-strong); border-radius: 5px; }
  .add-form label { font-size: 11px; font-weight: 600; letter-spacing: .1em;
    text-transform: uppercase; color: var(--muted); }
  .uncited { display: flex; gap: 8px; flex-wrap: wrap; }
  .uncited .ev-thumb { width: auto; }
  .uncited img { height: 72px; width: auto; display: block; }
  .uncited figure { margin: 0; }
  .uncited figcaption { font: 9px var(--mono); color: var(--muted); }
  #redesc-status { font-size: 12px; color: var(--muted); margin-top: 8px; }
  #redesc-status details { margin-top: 6px; }
  #redesc-status pre { font: 11px var(--mono); white-space: pre-wrap;
    background: var(--paper); border: 1px solid var(--line); border-radius: 5px;
    padding: 8px 10px; max-height: 220px; overflow: auto; }

  /* ---------- mobile ---------- */
  @media (max-width: 900px) {
    #app { grid-template-columns: 1fr; }
    #btn-queue { display: inline-block; }
    #rail { position: fixed; top: 0; bottom: 0; left: 0; width: 82vw;
            max-width: 360px; z-index: 60; transform: translateX(-103%);
            transition: transform .22s ease; box-shadow: 12px 0 40px -20px
            rgba(16,20,26,.5); }
    #rail.open { transform: none; }
    #rail-backdrop { display: none; position: fixed; inset: 0; z-index: 55;
                     background: rgba(28,36,48,.4); }
    #rail-backdrop.on { display: block; }
    .addr { display: none; }
    #detail { padding: 18px 16px 150px; }
    #actions { position: fixed; left: 0; right: 0; bottom: 0; margin: 0;
               padding: 10px 14px calc(10px + env(safe-area-inset-bottom));
               z-index: 40; }
  }
  @media (hover: none), (max-width: 640px) {
    .kbd, .kbd-label { display: none; }
  }
</style>
</head>
<body>
<header class="app-header">
  <button class="btn ghost" id="btn-queue" aria-label="Show item list">☰ Items</button>
  <span class="wordmark">Homeinventory</span>
  <nav class="app-nav" aria-label="Sections">
    <a href="{{ route_prefix }}/" aria-current="page">Review</a>
    <a href="{{ route_prefix }}/report" target="_blank" rel="noopener">Report</a>
    <a href="{{ route_prefix }}/issue" target="_blank" rel="noopener"
       title="Clean copy for sending — no review controls">Final issue</a>
  </nav>
  <span class="addr" id="hdr-addr">{{ inv.property_address or "No address yet" }}</span>
  <button class="btn ghost" id="btn-details">Details</button>
  <div id="progress">
    <div class="label"><span id="prog-n">0</span> of <span id="prog-d">0</span>
      items confirmed</div>
    <div class="track"><div class="fill" id="prog-fill"></div></div>
  </div>
  {% if share_url %}<span class="share">{{ payload.share.link_noun }} link:
    <a href="{{ share_url }}" target="_blank">{{ share_url }}</a></span>{% endif %}
  <span id="save-state" role="status">All changes saved</span>
  <button class="btn" id="btn-pdf">Export PDF</button>
  <button class="btn primary" id="btn-sign">Sign</button>
</header>

<div id="app">
  <nav id="rail" aria-label="Item queue">
    <div class="tools">
      <input type="search" id="q-search" placeholder="Search items…"
             aria-label="Search items" autocomplete="off">
      <div class="filters" id="filters">
        <button data-f="all" aria-pressed="true">All</button>
        <button data-f="pending" aria-pressed="false">Unreviewed</button>
        <button data-f="defects" aria-pressed="false">Defects</button>
        <button data-f="noev" aria-pressed="false">No evidence</button>
      </div>
      <div class="row2">
        <select id="sort" aria-label="Sort order">
          <option value="room">By room</option>
          <option value="conf">Least confident first</option>
        </select>
        <button class="btn" id="bulk">Accept remaining</button>
      </div>
    </div>
    <div id="queue"></div>
  </nav>
  <div id="rail-backdrop"></div>
  <section id="detail"></section>
</div>

<div id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer">
  <div id="lb-top">
    <span class="pid" id="lb-pid"></span>
    <span id="lb-title"></span>
    <span class="spacer"></span>
    <button class="lb-btn" id="lb-pin" aria-pressed="false">Pin defect</button>
    <button class="lb-btn" id="lb-close" aria-label="Close">✕ Close</button>
  </div>
  <div id="lb-stage">
    <div id="lb-canvas"><img id="lb-img" alt=""></div>
  </div>
  <div id="lb-bottom">
    <button class="lb-btn" id="lb-prev" aria-label="Previous photo">‹</button>
    <button class="lb-btn" id="lb-out" aria-label="Zoom out">−</button>
    <span id="lb-zoom">100%</span>
    <button class="lb-btn" id="lb-in" aria-label="Zoom in">+</button>
    <button class="lb-btn" id="lb-fit">Fit</button>
    <button class="lb-btn" id="lb-next" aria-label="Next photo">›</button>
    <span id="lb-hint">Scroll to zoom · drag to pan · double-click a pin to remove it</span>
  </div>
</div>

<div id="anno-form">
  <select id="anno-pick"></select>
  <input id="anno-new" type="text" placeholder="…or describe a new defect">
  <div class="row">
    <button class="btn ghost" id="anno-cancel">Cancel</button>
    <button class="btn primary" id="anno-ok">Pin defect</button>
  </div>
</div>
<div id="toast" role="status"></div>

<script type="application/json" id="hi-data">{{ payload | tojson }}</script>
<script>
{% include "_ui.js.j2" %}
</script>
<script>
"use strict";
(function () {
  var payload = JSON.parse(document.getElementById("hi-data").textContent);
  var PREFIX = {{ route_prefix|default("", true) | tojson }};
  var inv = payload.inventory;
  var photoSrc = payload.photo_src || {};
  var cropSrc = payload.crop_src || {};
  var signingRoles = payload.signing_roles || ["landlord", "agent"];
  var coverFields = payload.cover_fields || [];

  var CONDITIONS = ["new", "excellent", "good", "fair", "poor"];
  var NOT_INSPECTED = ["not tested", "not visible"];
  var CLEANS = ["professionally cleaned", "cleaned to domestic standard",
                "requires cleaning"];

  var filter = "all";
  var sortMode = "room";
  var query = "";
  var sel = null;            // {type:"item", id} | {type:"room", name}
  var el = ui.el, toast = ui.toast;

  function index() {
    var items = [], byId = {}, roomOf = {}, photoById = {};
    inv.rooms.forEach(function (room) {
      (room.photos || []).forEach(function (p) { photoById[p.id] = p; });
      (room.items || []).forEach(function (it) {
        items.push(it); byId[it.id] = it; roomOf[it.id] = room;
      });
    });
    return { items: items, byId: byId, roomOf: roomOf, photoById: photoById };
  }
  var ix = index();

  function api(method, url, body) {
    return fetch(PREFIX + url, {
      method: method,
      headers: { "Content-Type": "application/json" },
      body: body === undefined ? undefined : JSON.stringify(body)
    }).then(function (r) {
      return r.json().catch(function () { return {}; }).then(function (j) {
        if (!r.ok) throw new Error(j.error || r.statusText);
        return j;
      });
    });
  }
  function isDone(it) { return it.reviewed || it.rejected; }
  function hasEvidence(it) {
    return (it.photo_ids || []).some(function (p) { return photoSrc[p]; });
  }

  /* ---------- autosave ---------- */
  var dirty = false;
  var saving = false;
  var saveTimer = null;
  var saveState = document.getElementById("save-state");
  function setSaveState(text, err) {
    saveState.textContent = text;
    saveState.classList.toggle("err", !!err);
  }
  function scheduleSave() {
    clearTimeout(saveTimer);
    saveTimer = setTimeout(function () { flush(); }, 800);
  }
  function flush(opts) {
    // returns a promise resolving once the current state is on disk
    opts = opts || {};
    clearTimeout(saveTimer);
    if (!dirty && !saving) return Promise.resolve();
    if (saving) {           // let the in-flight save finish, then re-check
      return new Promise(function (res) {
        setTimeout(function () { flush(opts).then(res); }, 250);
      });
    }
    saving = true;
    dirty = false;
    setSaveState("Saving…");
    var url = "/api/inventory" + (opts.manual ? "" : "?autosave=1");
    return api("PUT", url, inv).then(function () {
      saving = false;
      if (dirty) { scheduleSave(); return; }
      setSaveState("All changes saved");
    }).catch(function (e) {
      saving = false;
      dirty = true;
      setSaveState("Save failed — retrying", true);
      if (!flush._warned) {
        flush._warned = true;
        toast("Could not save: " + e.message + " — will keep retrying");
      }
      clearTimeout(saveTimer);
      saveTimer = setTimeout(function () { flush(opts); }, 4000);
    });
  }
  function markDirty() {
    dirty = true;
    setSaveState("Unsaved changes…");
    scheduleSave();
    renderProgress();
  }
  window.addEventListener("beforeunload", function (e) {
    if (dirty || saving) { e.preventDefault(); e.returnValue = ""; }
  });

  /* ---------- undo ---------- */
  var undoStack = [];
  function snapshotOf(obj) {
    var json = JSON.stringify(obj);
    return function restore() {
      var snap = JSON.parse(json);
      Object.keys(obj).forEach(function (k) { delete obj[k]; });
      Object.keys(snap).forEach(function (k) { obj[k] = snap[k]; });
    };
  }
  function pushUndo(label, objs) {
    var restores = (objs || []).map(snapshotOf);
    undoStack.push({ label: label, apply: function () {
      restores.forEach(function (r) { r(); });
    } });
    if (undoStack.length > 50) undoStack.shift();
  }
  function undo() {
    var entry = undoStack.pop();
    if (!entry) { toast("Nothing to undo"); return; }
    entry.apply();
    ix = index();
    markDirty();
    renderProgress(); renderQueue();
    if (sel && sel.type === "item" && ix.byId[sel.id]) renderItem(ix.byId[sel.id]);
    else if (sel && sel.type === "room") {
      var room = inv.rooms.find(function (r) { return r.name === sel.name; });
      if (room) renderRoom(room);
    }
    toast("Undid: " + entry.label);
  }

  /* ---------- progress ---------- */
  function renderProgress() {
    var done = ix.items.filter(isDone).length;
    document.getElementById("prog-n").textContent = done;
    document.getElementById("prog-d").textContent = ix.items.length;
    document.getElementById("prog-fill").style.width =
      ix.items.length ? (100 * done / ix.items.length) + "%" : "0";
  }

  /* ---------- queue rail ---------- */
  var rail = document.getElementById("rail");
  var railBackdrop = document.getElementById("rail-backdrop");
  function setRail(open) {
    rail.classList.toggle("open", open);
    railBackdrop.classList.toggle("on", open);
  }
  document.getElementById("btn-queue").addEventListener("click", function () {
    setRail(!rail.classList.contains("open"));
  });
  railBackdrop.addEventListener("click", function () { setRail(false); });

  function matchesQuery(it) {
    var room = ix.roomOf[it.id];
    var hay = [it.id, it.name, it.description, room ? room.name : ""]
      .concat(it.defects || []).concat(it.rejected_defects || [])
      .join(" ").toLowerCase();
    var words = query.split(/\s+/);
    for (var i = 0; i < words.length; i++) {
      if (hay.indexOf(words[i]) < 0) return false;
    }
    return true;
  }
  function visible(it) {
    if (query && !matchesQuery(it)) return false;
    if (filter === "pending") return !isDone(it);
    if (filter === "defects") {
      return (it.defects || []).length || (it.rejected_defects || []).length;
    }
    if (filter === "noev") return !hasEvidence(it);
    return true;
  }
  function queueEntries() {
    var entries = ix.items.filter(visible);
    if (sortMode === "conf") {
      entries = entries.slice().sort(function (a, b) {
        return (a.confidence == null ? 1.01 : a.confidence) -
               (b.confidence == null ? 1.01 : b.confidence);
      });
    }
    return entries;
  }
  function queueRowState(row, it) {
    row.className = "q-item" +
      (it.rejected ? " bad" : it.reviewed ? " done" : "") +
      (sel && sel.type === "item" && sel.id === it.id ? " active" : "");
  }
  function queueRow(it) {
    var room = ix.roomOf[it.id];
    var row = el("div", {
      onclick: function () { select({ type: "item", id: it.id }); } });
    queueRowState(row, it);
    row.setAttribute("data-qid", it.id);
    row.appendChild(el("span", { "class": "dot" }));
    var name = el("span", { "class": "name", title: it.name || "" });
    name.appendChild(el("span", { "class": "ref", text: it.id }));
    name.appendChild(document.createTextNode(it.name || "(unnamed)"));
    var bits = [];
    if ((it.defects || []).length) bits.push((it.defects.length) + " defect" +
      (it.defects.length > 1 ? "s" : ""));
    if (!hasEvidence(it)) bits.push("no evidence");
    if (sortMode === "conf") bits.unshift(room.name);
    if (bits.length) name.appendChild(el("span", { "class": "sub",
      text: bits.join(" · ") }));
    row.appendChild(name);
    var conf = el("span", { "class": "conf" });
    // confidence is only signal when it is low or when sorting by it
    if (typeof it.confidence === "number" &&
        (sortMode === "conf" || it.confidence < 0.6)) {
      var pct = Math.round(it.confidence * 100);
      conf.appendChild(el("span", { "class": "v", text: pct + "%" }));
      var t = el("span", { "class": "t" });
      var f = el("span", { "class": "f" });
      f.style.display = "block"; f.style.width = pct + "%";
      t.appendChild(f); conf.appendChild(t);
    }
    row.appendChild(conf);
    return row;
  }

  /* The rail renders in chunks: first paint is O(chunk) however many items
     exist, and scrolling (or selecting something deeper) renders more. */
  var Q_CHUNK = 120;
  var qview = null;   // {entries, next, lastRoom, box, sentinel}
  var qObserver = ("IntersectionObserver" in window)
    ? new IntersectionObserver(function (recs) {
        recs.forEach(function (r) { if (r.isIntersecting) renderMoreRows(); });
      }, { root: rail, rootMargin: "600px" })
    : null;
  function renderQueue() {
    var q = document.getElementById("queue");
    if (qObserver && qview) qObserver.unobserve(qview.sentinel);
    q.innerHTML = "";
    var entries = queueEntries();
    if (!entries.length) {
      qview = null;
      q.appendChild(el("div", { "class": "empty-queue",
        text: query ? "No items match “" + query + "”."
          : filter === "pending"
          ? "Nothing left to review here — every item is confirmed."
          : "No items match this filter." }));
      return;
    }
    qview = { entries: entries, next: 0, lastRoom: null, box: q,
              sentinel: el("div", {}) };
    q.appendChild(qview.sentinel);
    renderMoreRows();
  }
  function renderMoreRows() {
    if (!qview) return;
    var stop = Math.min(qview.entries.length, qview.next + Q_CHUNK);
    var frag = document.createDocumentFragment();
    for (; qview.next < stop; qview.next++) {
      var it = qview.entries[qview.next];
      var room = ix.roomOf[it.id];
      if (sortMode === "room" && room.name !== qview.lastRoom) {
        qview.lastRoom = room.name;
        var pend = room.items.filter(function (i) { return !isDone(i); }).length;
        frag.appendChild(el("div", {
          "class": "room-head",
          onclick: (function (name) { return function () {
            select({ type: "room", name: name });
          }; })(room.name)
        }, [
          el("span", { text: room.name }),
          el("span", { "class": "n",
            text: pend ? pend + " open" : "done" })
        ]));
      }
      frag.appendChild(queueRow(it));
    }
    qview.box.insertBefore(frag, qview.sentinel);
    if (qview.next >= qview.entries.length) {
      if (qObserver) qObserver.unobserve(qview.sentinel);
      qview.sentinel.remove();
    } else if (qObserver) {
      // re-observe so a still-visible sentinel fires again for the next chunk
      qObserver.unobserve(qview.sentinel);
      qObserver.observe(qview.sentinel);
    } else {
      renderMoreRows();   // no IntersectionObserver: render everything
    }
  }
  function ensureRowRendered(id) {
    if (!qview) return;
    for (var i = 0; i < qview.entries.length; i++) {
      if (qview.entries[i].id === id) {
        while (qview.next <= i) renderMoreRows();
        return;
      }
    }
  }
  function refreshQueueRow(it) {
    var row = document.querySelector('[data-qid="' + it.id + '"]');
    if (row) queueRowState(row, it);
  }

  /* ---------- selection ---------- */
  function select(s) {
    var prev = sel;
    sel = s;
    closeAnnoForm();
    if (prev && prev.type === "item" && ix.byId[prev.id]) {
      refreshQueueRow(ix.byId[prev.id]);
    }
    if (s.type === "item") {
      ensureRowRendered(s.id);
      refreshQueueRow(ix.byId[s.id]);
      renderItem(ix.byId[s.id]);
    } else {
      renderRoom(inv.rooms.find(function (r) { return r.name === s.name; }));
      renderQueue();
    }
    var row = document.querySelector('[data-qid="' + (s.id || "") + '"]');
    if (row) row.scrollIntoView({ block: "nearest" });
    if (window.matchMedia("(max-width: 900px)").matches) setRail(false);
  }
  function step(delta) {
    var entries = queueEntries();
    if (!entries.length) return;
    var i = entries.findIndex(function (e) {
      return sel && sel.type === "item" && e.id === sel.id; });
    var next = entries[Math.max(0, Math.min(entries.length - 1,
      (i === -1 ? 0 : i + delta)))];
    select({ type: "item", id: next.id });
  }

  /* ---------- item detail ---------- */
  function badge(cls, text) { return el("span", { "class": "badge " + cls,
    text: text }); }
  function confirmItem(it) {
    pushUndo("confirm " + it.id, [it]);
    it.reviewed = true; it.rejected = false;
    markDirty(); refreshQueueRow(it); step(1);
  }
  function rejectItem(it) {
    pushUndo((it.rejected ? "restore " : "reject ") + it.id, [it]);
    it.rejected = !it.rejected;
    if (it.rejected) it.reviewed = false;
    markDirty(); refreshQueueRow(it); renderItem(it);
  }
  function renderItem(it) {
    var room = ix.roomOf[it.id];
    var d = document.getElementById("detail");
    d.innerHTML = "";

    var crumb = el("div", { "class": "crumb" });
    crumb.appendChild(el("span", { text: room.name + " · " + it.id }));
    crumb.appendChild(it.rejected ? badge("no", "rejected") :
      it.reviewed ? badge("ok", "reviewed") : badge("pend", "unreviewed"));
    var prov = it.added_by ? "added by " + it.added_by
                           : (inv.describe_backend || "AI") + " draft";
    crumb.appendChild(badge("prov", prov));
    if (typeof it.confidence === "number") {
      crumb.appendChild(el("span", { text:
        "confidence " + Math.round(it.confidence * 100) + "%" }));
    }
    d.appendChild(crumb);

    var editSnap = null;   // one undo entry per focus session on text fields
    function textUndo(node) {
      node.addEventListener("focus", function () {
        editSnap = JSON.stringify(it);
      });
      node.addEventListener("blur", function () {
        if (editSnap && editSnap !== JSON.stringify(it)) {
          var json = editSnap;
          undoStack.push({ label: "edit " + it.id, apply: function () {
            var snap = JSON.parse(json);
            Object.keys(it).forEach(function (k) { delete it[k]; });
            Object.keys(snap).forEach(function (k) { it[k] = snap[k]; });
          } });
          if (undoStack.length > 50) undoStack.shift();
        }
        editSnap = null;
      });
    }
    var name = el("input", { id: "d-name", value: it.name || "",
      "aria-label": "Item name",
      oninput: function () { it.name = name.value; markDirty(); },
      onchange: renderQueue });
    textUndo(name);
    d.appendChild(name);
    var desc = el("textarea", { id: "d-desc",
      "aria-label": "Item description",
      placeholder: "Material, colour, brand…",
      oninput: function () { it.description = desc.value; markDirty(); } });
    desc.value = it.description || "";
    textUndo(desc);
    d.appendChild(desc);

    var grades = el("div", { "class": "grades" });
    grades.appendChild(gradeBlock("Condition", CONDITIONS.concat(NOT_INSPECTED),
      it.not_inspected || it.condition || "",
      function (v) {
        pushUndo("condition of " + it.id, [it]);
        if (NOT_INSPECTED.indexOf(v) >= 0) {
          it.not_inspected = v; it.condition = null;
        } else { it.condition = v || null; it.not_inspected = null; }
        markDirty();
      }));
    grades.appendChild(gradeBlock("Cleanliness", CLEANS, it.cleanliness || "",
      function (v) {
        pushUndo("cleanliness of " + it.id, [it]);
        it.cleanliness = v || null; markDirty();
      }));
    d.appendChild(grades);

    // defects
    var secD = el("div", { "class": "sec" });
    secD.appendChild(el("h3", { text: "Defects" }));
    var chipWrap = el("div", {});
    function drawChips() {
      chipWrap.innerHTML = "";
      (it.defects || []).forEach(function (t) {
        chipWrap.appendChild(defChip(t, false));
      });
      (it.rejected_defects || []).forEach(function (t) {
        chipWrap.appendChild(defChip(t, true));
      });
      if (!(it.defects || []).length && !(it.rejected_defects || []).length) {
        chipWrap.appendChild(el("span", { "class": "c-line",
          text: "None noted." }));
      }
    }
    function defChip(text, struck) {
      var c = el("span", { "class": "chip" + (struck ? " struck" : ""),
        title: struck ? "Restore this defect"
                      : "Strike — kept in the report as “reviewer rejected”",
        onclick: function () {
          pushUndo((struck ? "restore" : "strike") + " defect", [it]);
          it.defects = it.defects || []; it.rejected_defects = it.rejected_defects || [];
          var from = struck ? it.rejected_defects : it.defects;
          var to = struck ? it.defects : it.rejected_defects;
          var i = from.indexOf(text);
          if (i >= 0) { from.splice(i, 1); to.push(text); }
          markDirty(); drawChips(); drawEvidence();
        } });
      c.appendChild(el("span", { text: text }));
      c.appendChild(el("span", { "class": "x", text: struck ? "↩" : "✕" }));
      return c;
    }
    drawChips();
    secD.appendChild(chipWrap);
    var addBox = el("div", { "class": "def-add" });
    var addIn = el("input", { type: "text",
      placeholder: "Add a defect (press Enter)…" });
    addIn.addEventListener("keydown", function (e) {
      e.stopPropagation();
      if (e.key === "Enter" && addIn.value.trim()) {
        pushUndo("add defect", [it]);
        (it.defects = it.defects || []).push(addIn.value.trim());
        addIn.value = ""; markDirty(); drawChips();
      }
    });
    addBox.appendChild(addIn);
    secD.appendChild(addBox);
    d.appendChild(secD);

    // evidence
    var secE = el("div", { "class": "sec" });
    secE.appendChild(el("h3",
      { text: "Evidence — click a photo to inspect and pin defects" }));
    var evGrid = el("div", { "class": "ev-grid" });
    function drawEvidence() {
      evGrid.innerHTML = "";
      var any = false;
      if (cropSrc[it.id]) {
        any = true;
        evGrid.appendChild(evThumb(it, null, cropSrc[it.id], "detector crop"));
      }
      (it.photo_ids || []).forEach(function (pid) {
        if (!photoSrc[pid]) return;
        any = true;
        evGrid.appendChild(evThumb(it, pid, photoSrc[pid], pid));
      });
      if (!any) {
        evGrid.appendChild(el("div", { "class": "ev-missing",
          text: "No evidence photos cited for this item. Confirm it only if " +
                "you can vouch for it yourself, or reject it." }));
      }
    }
    drawEvidence();
    secE.appendChild(evGrid);
    d.appendChild(secE);
    itemDrawEvidence = drawEvidence;

    // comments
    var secC = el("div", { "class": "sec" });
    secC.appendChild(el("h3", { text: "Comments" }));
    var cwrap2 = el("div", {});
    function drawComments() {
      cwrap2.innerHTML = "";
      (it.comments || []).forEach(function (c) {
        var line = el("div", { "class": "c-line" });
        line.appendChild(el("span", {
          "class": "who " + (c.role || "landlord"),
          text: (c.author || "?") + " (" + (c.role || "reviewer") + ")" }));
        if (c.at) line.appendChild(el("span", { "class": "at",
          text: (c.at + "").slice(0, 16).replace("T", " ") }));
        line.appendChild(el("div", { text: c.text || "" }));
        cwrap2.appendChild(line);
      });
    }
    drawComments();
    secC.appendChild(cwrap2);
    var cBox = el("div", { "class": "c-add" });
    var cIn = el("input", { type: "text", placeholder: "Add a comment…" });
    cIn.addEventListener("keydown", function (e) {
      e.stopPropagation();
      if (e.key === "Enter" && cIn.value.trim()) {
        pushUndo("comment on " + it.id, [it]);
        (it.comments = it.comments || []).push({
          author: inv.inspected_by || "reviewer", role: "landlord",
          text: cIn.value.trim(), at: new Date().toISOString() });
        cIn.value = ""; markDirty(); drawComments();
      }
    });
    cBox.appendChild(cIn);
    secC.appendChild(cBox);
    d.appendChild(secC);

    // actions
    var act = el("div", { id: "actions" });
    act.appendChild(el("button", {
      "class": "btn primary", text: it.reviewed ? "✓ Confirmed" : "✓ Confirm",
      onclick: function () { confirmItem(it); } }));
    act.appendChild(el("button", {
      "class": "btn danger",
      text: it.rejected ? "Restore item" : "✕ Reject item",
      onclick: function () { rejectItem(it); } }));
    act.appendChild(el("span", { "class": "kbd", text: "space" }));
    act.appendChild(el("span", { "class": "kbd-label", text: "confirm + next" }));
    act.appendChild(el("span", { "class": "kbd", text: "x" }));
    act.appendChild(el("span", { "class": "kbd-label", text: "reject" }));
    act.appendChild(el("span", { "class": "kbd", text: "j / k" }));
    act.appendChild(el("span", { "class": "kbd-label", text: "move" }));
    act.appendChild(el("span", { "class": "kbd", text: "/" }));
    act.appendChild(el("span", { "class": "kbd-label", text: "search" }));
    act.appendChild(el("span", { "class": "kbd", text: "⌘Z" }));
    act.appendChild(el("span", { "class": "kbd-label", text: "undo" }));
    d.appendChild(act);
  }
  var itemDrawEvidence = null;
  function gradeBlock(label, opts, current, onset) {
    var wrap = el("div", {});
    var s = el("select", { "aria-label": label });
    wrap.appendChild(el("label", { text: label }));
    s.appendChild(el("option", { value: "", text: "—" }));
    opts.forEach(function (o) {
      var op = el("option", { value: o, text: o });
      if (o === current) op.setAttribute("selected", "");
      s.appendChild(op);
    });
    s.addEventListener("change", function () { onset(s.value); });
    wrap.appendChild(s);
    return wrap;
  }
  function evThumb(it, pid, src, label) {
    var pins = pid ? (it && it.defect_regions || []).filter(function (r) {
      return r.photo_id === pid; }).length : 0;
    var b = el("button", { "class": "ev-thumb", type: "button",
      "aria-label": "Inspect " + label,
      onclick: function () { lightbox.open(it, pid, src, label); } });
    b.appendChild(el("img", { src: src, alt: label, loading: "lazy" }));
    b.appendChild(el("span", { "class": "pid", text: label }));
    if (pins) b.appendChild(el("span", { "class": "n-pins",
      text: pins + " pin" + (pins > 1 ? "s" : "") }));
    return b;
  }

  /* ---------- lightbox ---------- */
  var lightbox = (function () {
    var box = document.getElementById("lightbox");
    var stage = document.getElementById("lb-stage");
    var canvas = document.getElementById("lb-canvas");
    var img = document.getElementById("lb-img");
    var pinBtn = document.getElementById("lb-pin");
    var zoomLbl = document.getElementById("lb-zoom");
    var cur = null;   // {it, pid, src, label, pids: [...]}
    var scale = 1, minScale = 1, tx = 0, ty = 0;
    var pinning = false;

    function apply() {
      canvas.style.transform = "translate(" + tx + "px," + ty + "px) " +
                               "scale(" + scale + ")";
      zoomLbl.textContent = Math.round(100 * scale / minScale) + "%";
    }
    function fit() {
      var sw = stage.clientWidth, sh = stage.clientHeight;
      var iw = img.naturalWidth || 1, ih = img.naturalHeight || 1;
      minScale = Math.min(sw / iw, sh / ih, 1);
      scale = minScale;
      tx = (sw - iw * scale) / 2;
      ty = (sh - ih * scale) / 2;
      apply();
    }
    function clampPan() {
      var sw = stage.clientWidth, sh = stage.clientHeight;
      var iw = (img.naturalWidth || 1) * scale;
      var ih = (img.naturalHeight || 1) * scale;
      if (iw <= sw) tx = (sw - iw) / 2;
      else tx = Math.min(0, Math.max(sw - iw, tx));
      if (ih <= sh) ty = (sh - ih) / 2;
      else ty = Math.min(0, Math.max(sh - ih, ty));
    }
    function zoomAt(factor, cx, cy) {
      var next = Math.min(Math.max(scale * factor, minScale), minScale * 12);
      var r = stage.getBoundingClientRect();
      var px = (cx - r.left - tx) / scale, py = (cy - r.top - ty) / scale;
      scale = next;
      tx = cx - r.left - px * scale;
      ty = cy - r.top - py * scale;
      clampPan();
      apply();
    }
    function drawRegions() {
      canvas.querySelectorAll(".box").forEach(function (b) { b.remove(); });
      if (!cur || !cur.pid || !cur.it) return;
      var iw = img.naturalWidth || 1, ih = img.naturalHeight || 1;
      (cur.it.defect_regions || []).forEach(function (reg, ri) {
        if (reg.photo_id !== cur.pid) return;
        var b = el("div", { "class": "box",
          title: "Double-click to remove this pin",
          ondblclick: function () {
            pushUndo("remove pin", [cur.it]);
            cur.it.defect_regions.splice(ri, 1);
            markDirty(); drawRegions();
            if (itemDrawEvidence) itemDrawEvidence();
          } });
        b.style.left = (reg.x * iw) + "px";
        b.style.top = (reg.y * ih) + "px";
        b.style.width = (reg.w * iw) + "px";
        b.style.height = (reg.h * ih) + "px";
        b.appendChild(el("span", { "class": "lbl", text: reg.defect }));
        canvas.appendChild(b);
      });
    }
    function setPinning(on) {
      if (on && !(cur && cur.pid && cur.it)) {
        toast("Pins need a cited photo — this image can't be annotated");
        return;
      }
      pinning = on;
      pinBtn.setAttribute("aria-pressed", on ? "true" : "false");
      stage.classList.toggle("pinning", on);
      document.getElementById("lb-hint").textContent = on
        ? "Drag on the photo to mark the defect area"
        : "Scroll to zoom · drag to pan · double-click a pin to remove it";
    }
    function show() {
      document.getElementById("lb-pid").textContent = cur.label || "";
      document.getElementById("lb-title").textContent =
        cur.it ? cur.it.name || "" : "";
      img.onload = function () { fit(); drawRegions(); };
      img.src = cur.src;
      if (img.complete && img.naturalWidth) { fit(); drawRegions(); }
    }
    function open(it, pid, src, label) {
      cur = { it: it, pid: pid, src: src, label: label };
      cur.pids = it ? (it.photo_ids || []).filter(function (p) {
        return photoSrc[p]; }) : [];
      box.classList.add("on");
      setPinning(false);
      show();
    }
    function close() {
      box.classList.remove("on");
      closeAnnoForm();
      cur = null;
      if (itemDrawEvidence) itemDrawEvidence();
    }
    function stepPhoto(delta) {
      if (!cur || !cur.pids.length) return;
      var i = cur.pids.indexOf(cur.pid);
      var next = cur.pids[(Math.max(0, i) + delta + cur.pids.length)
                          % cur.pids.length];
      cur.pid = next; cur.src = photoSrc[next]; cur.label = next;
      setPinning(false);
      show();
    }

    document.getElementById("lb-close").addEventListener("click", close);
    document.getElementById("lb-in").addEventListener("click", function () {
      var r = stage.getBoundingClientRect();
      zoomAt(1.4, r.left + r.width / 2, r.top + r.height / 2);
    });
    document.getElementById("lb-out").addEventListener("click", function () {
      var r = stage.getBoundingClientRect();
      zoomAt(1 / 1.4, r.left + r.width / 2, r.top + r.height / 2);
    });
    document.getElementById("lb-fit").addEventListener("click", fit);
    document.getElementById("lb-prev").addEventListener("click", function () {
      stepPhoto(-1); });
    document.getElementById("lb-next").addEventListener("click", function () {
      stepPhoto(1); });
    pinBtn.addEventListener("click", function () { setPinning(!pinning); });
    stage.addEventListener("wheel", function (e) {
      e.preventDefault();
      zoomAt(e.deltaY < 0 ? 1.18 : 1 / 1.18, e.clientX, e.clientY);
    }, { passive: false });

    var drag = null, draft = null, draftStart = null;
    stage.addEventListener("pointerdown", function (e) {
      if (e.target.closest(".box") && !pinning) return;
      stage.setPointerCapture(e.pointerId);
      if (pinning) {
        var iw = img.naturalWidth || 1, ih = img.naturalHeight || 1;
        var r = stage.getBoundingClientRect();
        draftStart = { x: (e.clientX - r.left - tx) / scale / iw,
                       y: (e.clientY - r.top - ty) / scale / ih };
        draft = el("div", { "class": "box draft" });
        canvas.appendChild(draft);
      } else {
        drag = { x: e.clientX - tx, y: e.clientY - ty };
        stage.classList.add("dragging");
      }
    });
    stage.addEventListener("pointermove", function (e) {
      if (pinning && draft && draftStart) {
        var iw = img.naturalWidth || 1, ih = img.naturalHeight || 1;
        var r = stage.getBoundingClientRect();
        var curPt = { x: (e.clientX - r.left - tx) / scale / iw,
                      y: (e.clientY - r.top - ty) / scale / ih };
        var boxN = norm(draftStart, curPt);
        draft.style.left = (boxN.x * iw) + "px";
        draft.style.top = (boxN.y * ih) + "px";
        draft.style.width = (boxN.w * iw) + "px";
        draft.style.height = (boxN.h * ih) + "px";
      } else if (drag) {
        tx = e.clientX - drag.x;
        ty = e.clientY - drag.y;
        clampPan();
        apply();
      }
    });
    stage.addEventListener("pointerup", function (e) {
      stage.classList.remove("dragging");
      if (pinning && draft && draftStart) {
        var iw = img.naturalWidth || 1, ih = img.naturalHeight || 1;
        var r = stage.getBoundingClientRect();
        var endPt = { x: (e.clientX - r.left - tx) / scale / iw,
                      y: (e.clientY - r.top - ty) / scale / ih };
        var boxN = norm(draftStart, endPt);
        draftStart = null;
        if (boxN.w < 0.01 || boxN.h < 0.01) {
          draft.remove(); draft = null;
          return;
        }
        pendingRegion = { item: cur.it, photo_id: cur.pid, box: boxN,
                          draftEl: draft, redraw: function () {
                            drawRegions();
                            if (itemDrawEvidence) itemDrawEvidence();
                          } };
        draft = null;
        openAnnoForm(e.clientX, e.clientY);
      }
      drag = null;
    });
    document.addEventListener("keydown", function (e) {
      if (!box.classList.contains("on")) return;
      if (e.key === "Escape") {
        e.stopPropagation();
        if (pendingRegion) closeAnnoForm();
        else close();
      }
      else if (e.key === "ArrowRight") stepPhoto(1);
      else if (e.key === "ArrowLeft") stepPhoto(-1);
    }, true);

    return { open: open, close: close, drawRegions: drawRegions,
             isOpen: function () { return box.classList.contains("on"); } };
  })();

  /* ---------- defect-pin label form ---------- */
  var pendingRegion = null;
  function norm(a, b) {
    function clamp(v) { return Math.max(0, Math.min(1, v)); }
    var x1 = clamp(Math.min(a.x, b.x)), y1 = clamp(Math.min(a.y, b.y));
    var x2 = clamp(Math.max(a.x, b.x)), y2 = clamp(Math.max(a.y, b.y));
    return { x: x1, y: y1, w: x2 - x1, h: y2 - y1 };
  }
  function openAnnoForm(px, py) {
    var f = document.getElementById("anno-form");
    var pick = document.getElementById("anno-pick");
    pick.innerHTML = "";
    pick.appendChild(el("option", { value: "", text: "Pin which defect?" }));
    (pendingRegion.item.defects || []).forEach(function (t) {
      pick.appendChild(el("option", { value: t, text: t }));
    });
    document.getElementById("anno-new").value = "";
    f.style.display = "block";
    f.style.left = Math.min(px, window.innerWidth - 300) + "px";
    f.style.top = Math.min(py + 8, window.innerHeight - 170) + "px";
  }
  function closeAnnoForm() {
    document.getElementById("anno-form").style.display = "none";
    if (pendingRegion && pendingRegion.draftEl) pendingRegion.draftEl.remove();
    pendingRegion = null;
  }
  document.getElementById("anno-cancel").addEventListener("click", closeAnnoForm);
  document.getElementById("anno-ok").addEventListener("click", function () {
    if (!pendingRegion) return;
    var label = document.getElementById("anno-new").value.trim() ||
                document.getElementById("anno-pick").value;
    if (!label) { toast("Pick or describe the defect first"); return; }
    var it = pendingRegion.item;
    pushUndo("pin defect on " + it.id, [it]);
    if ((it.defects || []).indexOf(label) === -1 &&
        (it.rejected_defects || []).indexOf(label) === -1) {
      (it.defects = it.defects || []).push(label);
    }
    (it.defect_regions = it.defect_regions || []).push({
      defect: label, photo_id: pendingRegion.photo_id,
      x: pendingRegion.box.x, y: pendingRegion.box.y,
      w: pendingRegion.box.w, h: pendingRegion.box.h });
    var redraw = pendingRegion.redraw;
    if (pendingRegion.draftEl) pendingRegion.draftEl.remove();
    pendingRegion = null;
    document.getElementById("anno-form").style.display = "none";
    markDirty();
    if (redraw) redraw();
    if (sel && sel.type === "item" && !lightbox.isOpen()) {
      renderItem(ix.byId[sel.id]);
    }
  });

  /* ---------- room view ---------- */
  function renderRoom(room) {
    var d = document.getElementById("detail");
    d.innerHTML = "";
    d.appendChild(el("div", { "class": "crumb", text: "Room" }));
    d.appendChild(el("h2", { "class": "room-title", text: room.name }));

    var secFix = el("div", { "class": "sec" });
    secFix.appendChild(el("h3", { text: "Room name & boundaries" }));
    secFix.appendChild(el("p", { "class": "c-line",
      text: "Segmentation sometimes merges or misnames a room — fix it here "
            + "before signing." }));
    var renameRow = el("div", { "class": "add-form" });
    var renameInput = el("input", { type: "text", value: room.name,
      placeholder: "Room name" });
    var renameBtn = el("button", { "class": "btn", text: "Rename room" });
    renameBtn.addEventListener("click", function () {
      var nm = renameInput.value.trim();
      if (!nm || nm === room.name) return;
      renameBtn.disabled = true;
      api("POST", "/api/rooms/rename", { from: room.name, to: nm })
        .then(function () { location.reload(); })
        .catch(function (e) { renameBtn.disabled = false; toast(e.message); });
    });
    renameRow.appendChild(renameInput);
    renameRow.appendChild(renameBtn);
    secFix.appendChild(renameRow);
    var mergeRow = el("div", { "class": "add-form" });
    var mergeSelect = el("select", {});
    mergeSelect.appendChild(el("option", { value: "", text: "Merge into…" }));
    inv.rooms.forEach(function (r) {
      if (r.name !== room.name) {
        mergeSelect.appendChild(el("option", { value: r.name, text: r.name }));
      }
    });
    var mergeBtn = el("button", { "class": "btn", text: "Merge into neighbour" });
    mergeBtn.addEventListener("click", function () {
      if (!mergeSelect.value) { toast("Pick a room to merge into"); return; }
      ui.confirmDialog({
        title: "Merge rooms?",
        message: "Move every item and photo from " + room.name + " into "
                 + mergeSelect.value + ". This cannot be undone.",
        confirmLabel: "Merge"
      }).then(function (yes) {
        if (!yes) return;
        mergeBtn.disabled = true;
        api("POST", "/api/rooms/merge",
            { source: room.name, into: mergeSelect.value })
          .then(function () { location.reload(); })
          .catch(function (e) { mergeBtn.disabled = false; toast(e.message); });
      });
    });
    mergeRow.appendChild(mergeSelect);
    mergeRow.appendChild(mergeBtn);
    secFix.appendChild(mergeRow);
    d.appendChild(secFix);

    var secS = el("div", { "class": "sec" });
    secS.appendChild(el("h3", { text: "Room summary" }));
    var ta = el("textarea", { "class": "room-summary" });
    ta.value = room.summary || "";
    var roomSnap = null;
    ta.addEventListener("focus", function () {
      roomSnap = room.summary || "";
    });
    ta.addEventListener("blur", function () {
      if (roomSnap !== null && roomSnap !== room.summary) {
        var prevVal = roomSnap;
        undoStack.push({ label: "edit summary of " + room.name,
          apply: function () { room.summary = prevVal; } });
        if (undoStack.length > 50) undoStack.shift();
      }
      roomSnap = null;
    });
    ta.addEventListener("input", function () {
      room.summary = ta.value; markDirty();
    });
    secS.appendChild(ta);
    d.appendChild(secS);

    // coverage: photos no item cites
    var cited = {};
    room.items.forEach(function (it) {
      (it.photo_ids || []).forEach(function (p) { cited[p] = true; });
    });
    var orphans = (room.photos || []).filter(function (p) {
      return !cited[p.id] && photoSrc[p.id];
    });
    var secO = el("div", { "class": "sec" });
    secO.appendChild(el("h3", {
      text: "Coverage — photos no item cites (" + orphans.length + ")" }));
    if (orphans.length) {
      var strip = el("div", { "class": "uncited" });
      orphans.forEach(function (p) {
        var fig = el("figure", {});
        fig.appendChild(evThumb(null, null, photoSrc[p.id], p.id));
        fig.appendChild(el("figcaption", { text: p.id }));
        strip.appendChild(fig);
      });
      secO.appendChild(strip);
      secO.appendChild(el("p", { "class": "c-line",
        text: "Wasted shots, or items the AI missed — check before signing." }));
    } else {
      secO.appendChild(el("p", { "class": "c-line",
        text: "Every embedded photo in this room is cited by at least one item." }));
    }
    d.appendChild(secO);

    // add missing item
    var secA = el("div", { "class": "sec" });
    secA.appendChild(el("h3", { text: "Add a missed item" }));
    var form = el("div", { "class": "add-form" });
    var fName = el("input", { type: "text", placeholder: "Item name *" });
    var fDesc = el("input", { type: "text",
      placeholder: "Description (material, colour, brand)" });
    var fCond = el("select", {});
    fCond.appendChild(el("option", { value: "", text: "Condition —" }));
    CONDITIONS.forEach(function (c) {
      fCond.appendChild(el("option", { value: c, text: c }));
    });
    var fPhoto = el("input", { type: "file", accept: "image/*",
      capture: "environment" });
    var fBtn = el("button", { "class": "btn primary", text: "Add item" });
    fBtn.addEventListener("click", function () {
      if (!fName.value.trim()) { toast("Name the item first"); return; }
      fBtn.disabled = true;
      var send = function (b64) {
        api("POST", "/api/items", {
          room: room.name, name: fName.value.trim(),
          description: fDesc.value.trim(), condition: fCond.value || null,
          photo_b64: b64, author: inv.inspected_by || "reviewer"
        }).then(function () {
          toast("Item added — reloading");
          return reload();
        }).catch(function (e) {
          fBtn.disabled = false; toast("Add failed: " + e.message);
        });
      };
      var file = fPhoto.files && fPhoto.files[0];
      if (!file) { send(null); return; }
      var rd = new FileReader();
      rd.onload = function () { send(rd.result.split(",", 2)[1]); };
      rd.readAsDataURL(file);
    });
    [fName, fDesc, fCond, fPhoto, fBtn].forEach(function (n) {
      form.appendChild(n);
    });
    secA.appendChild(form);
    d.appendChild(secA);

    // re-describe
    var secR = el("div", { "class": "sec" });
    secR.appendChild(el("h3", { text: "Re-describe this room" }));
    secR.appendChild(el("p", { "class": "c-line",
      text: "Re-runs the AI over this room's photos — useful after fixing " +
            "capture problems. Your review decisions for this room are " +
            "replaced." }));
    var rBtn = el("button", { "class": "btn", text: "Re-describe " + room.name });
    var rStatus = el("div", { id: "redesc-status" });
    function watchRedescribe() {
      rStatus.textContent =
        "Re-describing — this can take a few minutes…";
      var t = setInterval(function () {
        api("GET", "/api/redescribe").then(function (s) {
          if (s.status === "done") {
            clearInterval(t);
            rBtn.disabled = false;
            rStatus.textContent = "Done — reloading…";
            reload();
          } else if (s.status === "failed") {
            clearInterval(t);
            rBtn.disabled = false;
            rStatus.innerHTML = "";
            rStatus.appendChild(el("span",
              { text: "Re-describe failed." }));
            if (s.detail) {
              var det = el("details", {}, [
                el("summary", { text: "Show error output" }),
                el("pre", { text: s.detail })]);
              rStatus.appendChild(det);
            }
          }
        }).catch(function () { /* poll again */ });
      }, 2500);
    }
    rBtn.addEventListener("click", function () {
      ui.confirmDialog({
        title: "Re-describe " + room.name + "?",
        message: (payload.spend ? payload.spend.label + " — est. "
                  + payload.spend.estimate + ". " : "") +
                 "Re-runs the AI over this room's photos.",
        note: "Review decisions for this room are replaced. Unsaved edits " +
              "are saved first.",
        confirmLabel: "Re-describe"
      }).then(function (yes) {
        if (!yes) return;
        rBtn.disabled = true;
        flush({ manual: true }).then(function () {
          return api("POST", "/api/redescribe",
                     { room: room.name,
                       confirm: payload.build_confirm || "yes" });
        }).then(watchRedescribe).catch(function (e) {
          rBtn.disabled = false; toast(e.message);
        });
      });
    });
    secR.appendChild(rBtn);
    secR.appendChild(rStatus);
    d.appendChild(secR);
  }

  /* ---------- details (report metadata) ---------- */
  document.getElementById("btn-details").addEventListener("click", function () {
    var fields = coverFields.length ? coverFields.map(function (f) {
      return { name: f.name, label: f.label, value: f.value || "",
               placeholder: f.placeholder || "" };
    }) : [
        { name: "property_address", label: "Property address",
          value: inv.property_address,
          placeholder: "12 Example Road, London N1 1AA" },
        { name: "property_type", label: "Property type",
          value: inv.property_type,
          placeholder: "1 bedroom furnished apartment" },
        { name: "inspected_by", label: "Prepared by",
          value: inv.inspected_by, placeholder: "Full name" },
        { name: "agent_name", label: "Agent / company",
          value: inv.agent_name },
        { name: "landlord_name", label: "Landlord", value: inv.landlord_name },
        { name: "tenant_name", label: "Tenant", value: inv.tenant_name },
        { name: "report_ref", label: "Report reference",
          value: inv.report_ref },
        { name: "inspected_at", label: "Date of inspection", type: "date",
          value: inv.inspected_at }
      ];
    ui.form({
      title: "Report details",
      note: "These appear on the report cover and in the declaration.",
      submitLabel: "Save details",
      fields: fields.concat(coverFields.length ? [
        { name: "inspected_by", label: "Prepared by",
          value: inv.inspected_by, placeholder: "Full name" },
        { name: "inspected_at", label: "Date of inspection", type: "date",
          value: inv.inspected_at }
      ] : [])
    }).then(function (values) {
      if (!values) return;
      pushUndo("edit report details", [inv]);
      Object.keys(values).forEach(function (k) {
        if (k in inv && k !== "parties") inv[k] = values[k];
        else {
          inv.parties = inv.parties || {};
          inv.parties[k] = values[k];
        }
      });
      document.getElementById("hdr-addr").textContent =
        inv.property_address || "No address yet";
      markDirty();
      toast("Details saved — they appear on the next report render");
    });
  });

  /* ---------- PDF export ---------- */
  var pdfBtn = document.getElementById("btn-pdf");
  function pollPdf() {
    api("GET", "/api/pdf").then(function (s) {
      if (s.status === "running") {
        pdfBtn.disabled = true;
        pdfBtn.textContent = "Preparing PDF…";
        setTimeout(pollPdf, 1500);
        return;
      }
      pdfBtn.disabled = false;
      pdfBtn.textContent = "Export PDF";
      if (s.status === "done" && pollPdf._started) {
        pollPdf._started = false;
        toast("PDF ready — opening");
        window.open(PREFIX + "/pdf", "_blank");
      } else if (s.status === "failed" && pollPdf._started) {
        pollPdf._started = false;
        var body = ui.el("div", {});
        body.appendChild(ui.el("p", { text: "The PDF could not be generated." }));
        if (s.detail) {
          body.appendChild(ui.el("p", { "class": "note", text: s.detail }));
        }
        ui.open({ title: "PDF export failed", body: body, actions: [
          { label: "Close", primary: true,
            onclick: function (close) { close(); } }] });
      }
    }).catch(function () { /* server gone; stop polling */ });
  }
  pdfBtn.addEventListener("click", function () {
    flush({ manual: true }).then(function () {
      return api("POST", "/api/pdf", {});
    }).then(function () {
      pollPdf._started = true;
      pollPdf();
    }).catch(function (e) {
      var body = ui.el("div", {});
      body.appendChild(ui.el("p", { text: e.message }));
      body.appendChild(ui.el("p", { "class": "note",
        text: "Without WeasyPrint you can still open the report and use " +
              "your browser's Print → Save as PDF; the server-generated " +
              "PDF adds page numbers in the contents and the tenant-" +
              "initials line on every page." }));
      ui.open({ title: "PDF export unavailable", body: body, actions: [
        { label: "Open report", onclick: function (close) {
            close(); window.open(PREFIX + "/report", "_blank"); } },
        { label: "Close", primary: true,
          onclick: function (close) { close(); } }] });
    });
  });
  pollPdf();   // reflect an export already in flight on page load

  /* ---------- sign / reload ---------- */
  function reload() {
    return api("GET", "/api/inventory").then(function (p) {
      inv = p.inventory; photoSrc = p.photo_src || {};
      cropSrc = p.crop_src || {};
      ix = index();
      dirty = false;
      undoStack = [];
      setSaveState("All changes saved");
      renderProgress(); renderQueue();
      if (sel && sel.type === "item" && ix.byId[sel.id]) {
        renderItem(ix.byId[sel.id]);
      } else if (sel && sel.type === "room") {
        var room = inv.rooms.find(function (r) { return r.name === sel.name; });
        if (room) renderRoom(room);
      } else if (ix.items.length) {
        select({ type: "item", id: ix.items[0].id });
      }
    });
  }
  document.getElementById("btn-sign").addEventListener("click", function () {
    var pend = ix.items.filter(function (i) { return !isDone(i); }).length;
    ui.form({
      title: "Sign this inventory",
      note: (pend ? pend + " items are still unreviewed. " : "") +
            "Signing pins the current content hash to your name in the " +
            "report's declaration.",
      submitLabel: "Sign",
      fields: [
        { name: "name", label: "Full name", value: inv.inspected_by || "",
          required: true },
        { name: "role", label: "Role", type: "select",
          value: signingRoles[0] || "landlord",
          options: signingRoles }
      ]
    }).then(function (values) {
      if (!values) return;
      flush({ manual: true }).then(function () {
        return api("POST", "/api/sign", values);
      }).then(function () {
        toast("Signed — the signature pins the saved inventory hash");
        return reload();
      }).catch(function (e) { toast(e.message); });
    });
  });

  /* ---------- filters / sort / bulk ---------- */
  document.getElementById("filters").addEventListener("click", function (e) {
    var b = e.target.closest("button");
    if (!b) return;
    filter = b.getAttribute("data-f");
    this.querySelectorAll("button").forEach(function (x) {
      x.setAttribute("aria-pressed", x === b ? "true" : "false");
    });
    renderQueue();
  });
  document.getElementById("sort").addEventListener("change", function () {
    sortMode = this.value; renderQueue();
  });
  var searchBox = document.getElementById("q-search");
  var searchTimer = null;
  function applySearch() {
    query = searchBox.value.trim().toLowerCase();
    renderQueue();
  }
  searchBox.addEventListener("input", function () {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(applySearch, 150);
  });
  searchBox.addEventListener("keydown", function (e) {
    e.stopPropagation();
    if (e.key === "Escape") {
      searchBox.value = "";
      clearTimeout(searchTimer);
      applySearch();
      searchBox.blur();
    } else if (e.key === "Enter") {
      clearTimeout(searchTimer);
      applySearch();
      var entries = queueEntries();
      if (entries.length) {
        select({ type: "item", id: entries[0].id });
        searchBox.blur();
      }
    }
  });
  document.getElementById("bulk").addEventListener("click", function () {
    var open = queueEntries().filter(function (i) { return !isDone(i); });
    if (!open.length) { toast("Nothing left to accept"); return; }
    ui.confirmDialog({
      title: "Accept " + open.length + " remaining item" +
             (open.length > 1 ? "s" : "") + "?",
      message: "Every visible unreviewed item is marked as confirmed by you.",
      note: "You can undo this with ⌘Z / Ctrl+Z.",
      confirmLabel: "Accept all"
    }).then(function (yes) {
      if (!yes) return;
      pushUndo("accept " + open.length + " items", open);
      open.forEach(function (i) { i.reviewed = true; });
      markDirty(); renderQueue();
      if (sel && sel.type === "item") renderItem(ix.byId[sel.id]);
    });
  });

  /* ---------- keyboard ---------- */
  document.addEventListener("keydown", function (e) {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "z") {
      var t0 = e.target;
      if (t0 && (t0.tagName === "INPUT" || t0.tagName === "TEXTAREA")) return;
      e.preventDefault();
      undo();
      return;
    }
    if (lightbox.isOpen()) return;
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
      e.preventDefault();
      if (window.matchMedia("(max-width: 900px)").matches) setRail(true);
      searchBox.focus(); searchBox.select();
      return;
    }
    var t = e.target;
    if (t && (t.tagName === "INPUT" || t.tagName === "TEXTAREA" ||
              t.tagName === "SELECT" || t.isContentEditable)) return;
    var it = sel && sel.type === "item" ? ix.byId[sel.id] : null;
    if (e.key === "/") {
      e.preventDefault();
      if (window.matchMedia("(max-width: 900px)").matches) setRail(true);
      searchBox.focus(); searchBox.select();
    }
    else if (e.key === "j") { e.preventDefault(); step(1); }
    else if (e.key === "k") { e.preventDefault(); step(-1); }
    else if (e.key === " " && it) {
      e.preventDefault();
      confirmItem(it);
    } else if (e.key === "x" && it) {
      e.preventDefault();
      rejectItem(it);
    } else if (it && "12345".indexOf(e.key) >= 0) {
      e.preventDefault();
      pushUndo("condition of " + it.id, [it]);
      it.condition = CONDITIONS[Number(e.key) - 1];
      it.not_inspected = null;
      markDirty(); renderItem(it);
    } else if (e.key === "Escape") closeAnnoForm();
  });

  /* ---------- boot ---------- */
  renderProgress();
  renderQueue();
  if (ix.items.length) {
    // start on the least confident unreviewed item: the queue's whole point
    var first = ix.items.filter(function (i) { return !isDone(i); })
      .sort(function (a, b) {
        return (a.confidence == null ? 1.01 : a.confidence) -
               (b.confidence == null ? 1.01 : b.confidence);
      })[0] || ix.items[0];
    select({ type: "item", id: first.id });
  } else {
    document.getElementById("detail").appendChild(el("div", {
      "class": "ev-missing",
      text: "No items in this inventory yet — run a build first." }));
  }
})();
</script>
</body>
</html>
