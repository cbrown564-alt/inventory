        if (s.detail) {
          body.appendChild(ui.el("p", { "class": "note", text: s.detail }));
        }
        ui.open({ title: "PDF export failed", body: body, actions: [
          { label: "Close", primary: true,
            onclick: function (close) { close(); } }] });
      }
    }).catch(function () { /* server gone; stop polling */ });
  }
  pdfBtn.addEventListener("click", function () {
