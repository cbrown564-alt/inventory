<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ inv.report_type }} — {{ inv.property_address or "Property" }}</title>
<style>
{% include "_theme.css.j2" %}

  /* The report is the document-world expression of the ONE shared system
     (docs/25): colour, type scale and components all come from
     _theme.css.j2. This block only aliases the report's own semantic token
     names onto the shared palette and sets document-specific values — no
     third palette. */
  :root {
    --paper: var(--panel);        /* the document is white paper, not the warm page bg */
    --rule: var(--line);
    --band: var(--panel-2);
    --accent: var(--ink);         /* headings & chrome are ink; brass stays the accent rule */
    --reject: var(--danger); --reject-soft: var(--danger-soft);
    --pend: var(--brass-bright); --pend-soft: var(--brass-soft);
    --serif: var(--display);
  }
  body {
    font-family: var(--serif);
    color: var(--ink); margin: 0; font-size: 11pt; line-height: 1.45;
    background: var(--paper);
  }
  main { max-width: 820px; margin: 0 auto; padding: 24px; }
  h1, h2, h3 { font-weight: 600; color: var(--accent); }
  .cover {
    text-align: center; padding: 120px 24px 60px; page-break-after: always;
  }
  .cover-logo {
    width: 48px;
    height: 48px;
    margin: 0 auto 24px;
    display: block;
  }
  .cover h1 { font-size: 27pt; margin-bottom: 4px; }
  .cover h1::after { content: ""; display: block; width: 72px;
    border-bottom: 2px solid var(--brass); margin: 18px auto 0; }
  .cover .addr { font-size: 16pt; margin: 18px 0 40px; }
  .cover table { margin: 0 auto; border-collapse: collapse; font-size: 11pt; }
  .cover td { padding: 5px 14px; text-align: left; }
  .cover td:first-child { color: var(--muted); }
  .kicker { letter-spacing: .3em; text-transform: uppercase; font-size: 9pt;
            color: var(--brass); font-family: var(--ui); font-weight: 600; }
  section.room { page-break-before: always; }
  h2 { font-size: 15pt; border-bottom: 2px solid var(--brass);
       padding-bottom: 4px; margin-top: 28px; }
  .summary { background: var(--band); padding: 10px 14px;
             border: 1px solid var(--rule); border-radius: 4px;
             margin: 12px 0 18px; }
  table.items { width: 100%; border-collapse: collapse; font-size: 9.5pt; }
  table.items th {
    text-align: left; background: var(--band); color: var(--ink);
    padding: 6px 8px; font: 600 8.5pt var(--ui); letter-spacing: .05em;
    text-transform: uppercase; border-bottom: 2px solid var(--brass);
  }
  table.items td { border-bottom: 1px solid var(--rule); padding: 6px 8px;
                   vertical-align: top; }
  table.items tr { page-break-inside: avoid; }
  /* detector close-up beside the item name (docs/15 M4) */
  .item-thumb { display: block; width: 100%; max-width: 96px; height: 44px;
                object-fit: cover; border: 1px solid var(--rule);
                border-radius: 2px; margin-bottom: 3px; }
  /* grades wear small-caps; defect text stays sentence case */
  .grade-word { white-space: nowrap; font-variant: small-caps; }
  .grade-word.poor { color: var(--reject); font-weight: 700; }
  .grade-word.fair { color: var(--brass-bright); }
  .defects { color: var(--reject); }
  .defects li { margin: 0; }
  .cond-cell .defects { margin-top: 3px; font-size: 8.5pt; }
  .ev-refs { font-family: var(--mono); font-size: 7.5pt; color: var(--muted);
             margin-top: 4px; }
  .addr-missing { color: var(--muted); font-style: italic; }
  ul { margin: 2px 0 2px 16px; padding: 0; }
  .photos { display: flex; flex-wrap: wrap; gap: 8px; margin: 14px 0; }
  .photos figure { margin: 0; width: 31%; page-break-inside: avoid; }
  .photos .frame { position: relative; }
  .photos img { width: 100%; height: 150px; object-fit: cover; display: block;
                border: 1px solid var(--rule); }
  .photos figcaption { font-size: 8pt; color: var(--muted);
                       font-family: var(--mono); }
  /* curation (docs/15 M2): the cover hero heads the room; the disclosed
     tier sits behind a quiet summary line */
  .room-cover { margin: 14px 0 4px; }
  .room-cover .frame { position: relative; }
  .room-cover img { width: 100%; height: auto; max-height: 340px;
                    object-fit: cover; display: block;
                    border: 1px solid var(--rule); }
  .room-cover figcaption { font-size: 8pt; color: var(--muted);
                           font-family: var(--mono); margin-top: 3px; }
  details.more-frames { margin: 4px 0 16px; }
  details.more-frames summary { cursor: pointer; list-style-position: outside;
    font: 500 9.5pt var(--ui); color: var(--muted); padding: 4px 0; }
  details.more-frames summary:hover { color: var(--brass); }
  .region { position: absolute; border: 2px solid var(--reject);
            background: rgba(163,35,31,.08); pointer-events: none; }
  .region::after {
    content: attr(data-label); position: absolute; left: -2px; bottom: 100%;
    background: var(--reject); color: #fff; font-family: var(--ui);
    font-size: 7.5pt; padding: 1px 5px; white-space: nowrap; max-width: 220px;
    overflow: hidden; text-overflow: ellipsis;
  }
  .meta { color: var(--muted); font-size: 9pt; }

  /* ---------- docs/16: the schedule as catalogue entries (screen) --------
     One markup, three renderings: the review layer grafts onto these cells
     by class and WeasyPrint needs real table semantics, so the table stays
     and the entry layout is screen-media only — print CSS is untouched. */
  @media screen {
    section.room table.items,
    section.room table.items tbody { display: block; width: 100%; }
    section.room table.items thead { display: none; }
    section.room table.items td { border: 0; padding: 0; }
    section.room tr.category-row { display: block; margin: 26px 0 2px; }
    section.room tr.category-row td { display: block; background: none;
      border-bottom: 1px solid var(--rule); padding: 0 0 3px;
      font: 600 8.5pt var(--ui); letter-spacing: .14em;
      text-transform: uppercase; color: var(--muted); }
    section.room tr.item-row {
      display: grid;
      grid-template-columns: 72px minmax(0, 1fr) minmax(132px, 168px);
      grid-template-areas:
        "ref name  cond"
        "ref desc  clean"
        "ref def   def"
        "ref photo photo";
      column-gap: 20px; row-gap: 4px; align-items: start;
      padding: 14px 4px 15px; border-bottom: 1px solid var(--rule);
    }
    section.room .ref-cell { grid-area: ref; align-self: start;
      display: flex; flex-direction: column; gap: 4px;
      padding-top: 2px; min-width: 0; }
    section.room .ref-cell > .ref-mono { display: block; font-size: 9pt; }
    section.room .ref-cell .ref-internal { display: block; font-size: 7.5pt;
      line-height: 1.35; }
    section.room .name-cell { grid-area: name; display: flex;
      align-items: center; gap: 10px; flex-wrap: wrap; min-width: 0; }
    section.room .name-cell .review-flag { flex-shrink: 0; }
    section.room .name-cell .item-name { font-size: 11.5pt; }
    section.room .name-cell .item-thumb { order: 9; margin: 0 0 0 auto;
      width: 46px; height: 46px; max-width: none; border-radius: 2px; }
    section.room .desc-cell { grid-area: desc; max-width: 62ch;
      font-size: 10pt; line-height: 1.5; padding-top: 2px; min-width: 0; }
    section.room .cond-cell { grid-area: cond; text-align: right;
      padding-top: 2px; min-width: 0; }
    section.room .cond-cell .grade-word { font-size: 10.5pt;
      letter-spacing: .02em; }
    section.room .clean-cell { grid-area: clean; text-align: right;
      font: 8.5pt/1.45 var(--ui); color: var(--muted); min-width: 0; }
    section.room .def-cell { grid-area: def; margin-top: 7px; }
    /* absence says "none noted" on screen; print keeps the words */
    section.room .def-cell > .meta { display: none; }
    section.room .def-cell .defects { list-style: none; margin: 0;
      padding: 6px 10px; background: var(--danger-soft); border-radius: 4px;
      max-width: 62ch; font-size: 9.5pt; line-height: 1.45; }
    section.room .photo-cell { grid-area: photo; margin-top: 8px;
      font-size: 8pt; min-width: 0; }
    section.room .photo-cell:not(:empty)::before { content: "Evidence";
      font: 600 7pt var(--ui); letter-spacing: .12em;
      text-transform: uppercase; color: var(--muted); margin-right: 7px; }
    section.room tr.comment-row { display: block; margin: 0 0 2px 92px; }
    section.room tr.comment-row td { display: block; }
    section.room tr.comment-row td:first-child { display: none; }
    section.room tr.rv-evidence { display: block; margin: 2px 0 10px; }
    section.room tr.rv-evidence td { display: block; }
    /* review-mode chrome, restated for the grid (row ring, not cell rims) */
    body.reviewing section.room tr.item-row.active td { background: none;
      border: none; }
    body.reviewing section.room tr.item-row.active { background: var(--brass-soft);
      box-shadow: inset 0 0 0 1px var(--accent); border-radius: 4px; }
    /* the frame around the entries (docs/16 R2) */
    .room-meta { font: 500 8.5pt var(--ui); letter-spacing: .08em;
      text-transform: uppercase; color: var(--muted); margin: 8px 0 14px; }
    section.room .summary, .summary { background: var(--band);
      border: 1px solid var(--rule); border-radius: 4px;
      padding: 10px 14px; font-style: italic; font-size: 10.5pt;
      line-height: 1.55; }
    section.room h3 { font: 600 8.5pt var(--ui); letter-spacing: .14em;
      text-transform: uppercase; color: var(--muted);
      border-bottom: 1px solid var(--rule); padding-bottom: 3px;
      margin: 30px 0 10px; }
  }
  @media screen and (max-width: 640px) {
    section.room tr.item-row {
      grid-template-columns: 56px minmax(0, 1fr);
      grid-template-areas:
        "ref name" "ref cond" "ref clean" "ref desc" "ref def" "ref photo";
      column-gap: 14px; padding-inline: 0;
    }
    section.room .cond-cell, section.room .clean-cell { text-align: left; }
  }

  .appendix table { width: 100%; border-collapse: collapse; font-size: 8pt;
                    font-family: var(--mono); }
  .appendix td, .appendix th { border-bottom: 1px solid var(--rule);
                               padding: 3px 6px; text-align: left; }
  .declaration { border: 1px solid var(--rule); padding: 16px; margin-top: 24px; }
  .sigline { display: inline-block; width: 250px; border-bottom: 1px solid
             var(--ink); margin: 28px 16px 4px 0; }
  .sigcard { border: 1px solid var(--confirm); background: var(--confirm-soft);
             border-radius: 6px; padding: 8px 12px; margin: 10px 0;
             font-size: 9.5pt; }
  .sigcard .hash { font-family: var(--mono); font-size: 7.5pt;
                   color: var(--muted); word-break: break-all; }
  footer { color: var(--muted); font-size: 8pt; text-align: center;
           margin-top: 40px; }

  /* mobile: full-bleed document, no side gutters */
  @media (max-width: 640px) {
    main { max-width: none; margin: 0; padding: 16px 12px 40px; }
    .cover { padding: 72px 12px 36px; }
    .app-header { padding: 8px 12px; gap: 8px; }
    .app-header .shell-addr { display: none; }
    .app-nav { overflow-x: auto; flex-wrap: nowrap; scrollbar-width: none;
               -webkit-overflow-scrolling: touch; }
    .app-nav::-webkit-scrollbar { display: none; }
    .app-nav a { flex-shrink: 0; }
    .photos figure { width: 48%; }
    body.reviewing main { padding-bottom: 88px; }
    #docket .bar { padding: 8px 12px; gap: 8px; }
    #docket .brand { display: none; }
  }
  @media (max-width: 480px) {
    main { padding: 12px 10px 32px; }
    .cover { padding: 56px 10px 28px; }
    .cover h1 { font-size: 22pt; }
  }

  /* ---------- PDF / clerk layout (WeasyPrint) ---------- */
  .print-only { display: none; }
  .screen-only { }
  .page-break { page-break-before: always; }
  .agent-name { font: 600 11pt var(--ui); letter-spacing: .08em;
                text-transform: uppercase; color: var(--brass); margin-bottom: 8px; }
  .property-type { font-size: 12pt; color: var(--muted); margin: 8px 0 24px; }
  .toc-list { list-style: none; padding: 0; margin: 16px 0; }
  .toc-list li { display: flex; justify-content: space-between; gap: 12px;
                 border-bottom: 1px dotted var(--rule); padding: 5px 0; font-size: 10pt; }
  .toc-list a { color: var(--ink); text-decoration: none; flex: 1; }
  .category-row td { background: var(--band); font: 600 9pt var(--ui);
                     text-transform: uppercase; letter-spacing: .06em; padding: 7px 8px; }
  .cond-merged { white-space: pre-line; line-height: 1.35; }
  .photo-sheet { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin: 14px 0; }
  .photo-sheet figure { margin: 0; page-break-inside: avoid; }
  .photo-sheet .frame { position: relative; display: block; }
  .photo-sheet img { width: 100%; height: auto; max-height: 170px; object-fit: contain;
                     border: 1px solid var(--rule); display: block; background: #fff; }
  /* annotated photos keep their natural aspect so the normalised defect
     regions land exactly on the image, not on letterbox padding */
  .photo-sheet figure.annotated img { max-height: none; }
  .photo-sheet figcaption { font: 8pt var(--ui); text-align: center; margin-top: 3px; }
  .photo-sheet .ref-tag { font-weight: 600; font-family: var(--mono); }
  .appendix td.hash { word-break: break-all; font-size: 6.5pt; }
  .initials-note { font-size: 9pt; color: var(--muted); margin-top: 18px; }
  .pdf-brand { font: 7.5pt var(--ui); color: var(--muted); text-align: center; }

  /* ---------- the one-app shell (paper mood; see _shell.html.j2) -------- */
  .app-header { display: flex; align-items: center; gap: 14px;
    padding: 9px 20px; background: var(--paper);
    border-bottom: 1px solid var(--rule); position: sticky; top: 0;
    z-index: 45; font-family: var(--ui); flex-wrap: wrap; }
  .wordmark { font: 600 12px/1 var(--serif); letter-spacing: .34em;
    text-transform: uppercase; color: var(--brass); white-space: nowrap;
    text-decoration: none; }
  .wordmark::after { content: "."; color: var(--muted); letter-spacing: 0; }
  .app-nav { display: flex; gap: 2px; }
  .app-nav a { font: 500 13px var(--ui); color: var(--muted);
    text-decoration: none; padding: 5px 11px; border-radius: 6px; }
  .app-nav a:hover { color: var(--ink); background: var(--band); }
  .app-nav a[aria-current="page"] { color: var(--brass);
    background: var(--band); }
  .app-header .shell-addr { margin-left: auto; font: 11px var(--mono);
    color: var(--muted); overflow: hidden; text-overflow: ellipsis;
    white-space: nowrap; max-width: 40%; }
  .ref-internal[href] { color: var(--muted); text-decoration: none;
    border-bottom: 1px dotted var(--rule); }
  .ref-internal[href]:hover { color: var(--brass); border-bottom-color:
    var(--brass); }
  .moment-link { color: inherit; text-decoration: none;
    border-bottom: 1px dotted var(--rule); }
  .moment-link:hover { color: var(--brass); border-bottom-color: var(--brass); }

  @page {
    size: A4;
    margin: 16mm 14mm 22mm 14mm;
    @bottom-center {
      content: "Page " counter(page) " of " counter(pages);
      font: 8pt var(--ui); color: #5a5f6a;
    }
    @bottom-right {
      content: "Tenant initials: __________";
      font: 8pt var(--ui); color: #5a5f6a;
    }
  }
  @page :first {
    margin: 0;
    @bottom-center { content: none; }
    @bottom-right { content: none; }
  }

  @media print {
    body { font-size: 10pt; }
    .item-thumb { height: 34px; max-width: 72px; }
    main { max-width: none; padding: 0; }
    .cover { min-height: 297mm; padding: 90px 24px 60px; }
    .screen-only, .review-flag, tr.comment-row, footer .tool-meta,
    tr.item-rejected, #docket, #toast, tr.rv-evidence { display: none !important; }
    .print-only { display: block !important; }
    table.items { font-family: var(--ui); font-size: 9pt; }
    table.items th { background: var(--band); color: var(--ink); border: 1px solid var(--rule); }
    table.items td { border: 1px solid var(--rule); }
    h2 { font-family: var(--ui); font-size: 13pt; border-bottom: 1px solid var(--ink); }
    h3 { font-family: var(--ui); }
    .photos.screen-only { display: none !important; }
    .photo-sheet { page-break-inside: auto; }
    .photo-sheet .sheet-break { page-break-after: always; }
    footer.doc-footer { margin-top: 24px; }
    .toc-list a::after {
      content: leader(".") target-counter(attr(href url), page);
      color: var(--muted);
    }
  }

  /* ---------- static review-state rendering ---------- */
  tr.item-rejected td, tr.item-rejected .defects { color: var(--muted); }
  tr.item-rejected td.name-cell .item-name { text-decoration: line-through; }
  .review-flag { display: inline-block; font-family: var(--ui); font-size: 7pt;
                 font-weight: 600; letter-spacing: .07em;
                 text-transform: uppercase; padding: 2px 7px; border-radius: 999px;
                 line-height: 1.35; white-space: nowrap; }
  .review-flag.ok { color: var(--confirm); background: var(--confirm-soft); }
  .review-flag.no { color: var(--reject); background: var(--reject-soft); }
  .review-flag.pending { color: var(--pend); background: var(--pend-soft); }
  .defects li.struck { text-decoration: line-through; color: var(--muted); }
  .defects li.struck::after { content: " — reviewer rejected"; font-size: 8pt;
                              text-decoration: none; font-style: italic; }
  tr.comment-row td { background: var(--band); font-size: 9pt; padding: 5px 10px; }
  tr.comment-row .who { font-family: var(--ui); font-weight: 600;
                        font-size: 8pt; color: var(--accent); }
  .ref-mono { font-family: var(--mono); font-size: 8.5pt; }

  /* ---------- the review docket (JS-revealed instrument layer) ---------- */
  #docket {
    display: none; position: fixed; left: 0; right: 0; bottom: 0; z-index: 40;
    font-family: var(--ui); font-size: 13px; color: var(--ink);
    background: var(--panel); border-top: 1px solid var(--line-strong);
    box-shadow: 0 -8px 24px -16px rgba(43, 36, 20, .35);
  }
  #docket.on { display: block; }
  #docket .bar { max-width: 1240px; margin: 0 auto; padding: 9px 18px;
                 display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
  #docket .brand { letter-spacing: .18em; text-transform: uppercase;
                   font-size: 10px; color: var(--accent); font-weight: 600; }
  #progress { flex: 1 1 180px; min-width: 140px; }
  #progress .track { height: 4px; background: var(--line); border-radius: 2px;
                     overflow: hidden; margin-top: 4px; }
  #progress .fill { height: 100%; width: 0; background: var(--confirm);
                    transition: width .35s cubic-bezier(.16,1,.3,1); }
  #progress .label { font-size: 11px; color: var(--muted);
                     font-variant-numeric: tabular-nums; }
  .dk-btn {
    font: 600 12px var(--ui); color: var(--ink); background: var(--panel);
    border: 1px solid var(--line-strong); border-radius: 6px; padding: 6px 12px;
    cursor: pointer; transition: border-color .15s, background .15s;
  }
  .dk-btn:hover { border-color: var(--brass); color: var(--brass-bright); }
  .dk-btn:active { transform: translateY(1px); }
  .dk-btn.primary { background: var(--brass); border-color: var(--brass);
                    color: #fffdf8; }
  .dk-btn.primary:hover { background: var(--brass-bright);
                          border-color: var(--brass-bright); color: #fffdf8; }
  .dk-btn[aria-pressed="true"] { background: var(--accent); color: var(--panel);
                                 border-color: var(--accent); }
  #dirty-dot { width: 8px; height: 8px; border-radius: 50%;
               background: transparent; }
  #dirty-dot.dirty { background: var(--pend); }
  .kbd-hint { font-size: 10px; color: var(--muted); }
  @media (hover: none), (pointer: coarse) { .kbd-hint { display: none; } }
  .kbd-hint kbd { font-family: var(--mono); background: var(--panel-2);
                  border: 1px solid var(--line); border-radius: 2px;
                  padding: 0 4px; font-size: 10px; }

  /* ---------- in-place review controls ---------- */
  body.reviewing main { padding-bottom: 96px; }
  body.reviewing tr.item-row { cursor: pointer; }
  body.reviewing tr.item-row.active td { background: var(--brass-soft);
      border-top: 1px solid var(--accent); border-bottom: 1px solid var(--accent); }
  body.reviewing tr.item-row.pending-mark td:first-child {
      box-shadow: inset 3px 0 0 var(--pend); }
  body.reviewing tr.item-row.done-mark td:first-child {
      box-shadow: inset 3px 0 0 var(--confirm); }
  body.reviewing tr.item-row.reject-mark td:first-child {
      box-shadow: inset 3px 0 0 var(--reject); }
  .rv-select { font: 12px var(--ui); padding: 2px 4px;
               border: 1px solid var(--line-strong);
               border-radius: 6px; background: var(--panel); max-width: 100%; }
  .rv-edit[contenteditable="true"] { outline: 1px dashed var(--line-strong);
      outline-offset: 2px; min-width: 40px; display: inline-block; }
  .rv-edit[contenteditable="true"]:focus { outline: 1.5px solid var(--accent); }
  /* .chip / .chip-add — shared components (see _theme.css.j2) */
  tr.rv-evidence td {
    background: var(--panel-2); border-bottom: 2px solid var(--accent);
    padding: 10px 12px;
  }
  .rv-actions { display: flex; gap: 8px; align-items: center; flex-wrap: wrap;
                font-family: var(--ui); margin-bottom: 8px; }
  .rv-actions .spacer { flex: 1; }
  .ev-strip { display: flex; gap: 8px; flex-wrap: wrap; }
  .ev-strip a { display: block; position: relative; }
  .ev-strip img { height: 96px; width: auto; border: 1px solid var(--rule);
                  display: block; }
  .ev-strip .pid { position: absolute; left: 0; bottom: 0; background:
                   rgba(26,26,26,.78); color: #fff; font: 9px var(--mono);
                   padding: 1px 5px; }
  .ev-none { font: italic 12px var(--ui); color: var(--muted); }
  .rv-comments { margin-top: 8px; font-family: var(--ui); font-size: 12px; }
  .rv-comments .c { padding: 3px 0; border-top: 1px dotted var(--rule); }
  .rv-comments .who { font-weight: 600; color: var(--accent); font-size: 11px; }
  .rv-comment-box { display: flex; gap: 6px; margin-top: 6px; }
  .rv-comment-box input { flex: 1; font: 12px var(--ui); padding: 5px 8px;
                          border: 1px solid var(--line-strong);
                          border-radius: 6px; }
  @keyframes ev-flash {
    0% { outline: 4px solid var(--accent); outline-offset: 3px; }
    100% { outline: 4px solid transparent; outline-offset: 3px; }
  }
  .flash { animation: ev-flash 1.6s ease-out 2; }
  #toast {
    position: fixed; bottom: 76px; left: 50%; transform: translateX(-50%) translateY(8px);
    background: var(--ink); color: #f4f1ea; font: 13px var(--ui); padding: 8px 16px;
    border-radius: 8px; border: 1px solid var(--brass-soft);
    opacity: 0; pointer-events: none;
    transition: opacity .25s, transform .25s; z-index: 50;
  }
  #toast.show { opacity: .96; transform: translateX(-50%) translateY(0); }

  /* .btn, .ui-modal, .ui-field — shared components (see _theme.css.j2) */

  @media print {
    .photos img { height: 130px; }
    #docket, #toast, tr.rv-evidence, .ui-modal-backdrop { display: none !important; }
    body.reviewing main { padding-bottom: 0; }
  }
</style>
</head>
<body>
{% if not final %}
<header class="app-header screen-only" id="app-shell">
  {% set shell_base = "./" %}{% set shell_active = "report" %}
  {%- include "_shell.html.j2" %}
  <span class="shell-addr">{{ inv.property_address or "" }}</span>
</header>
{% endif %}
<main>
<div class="cover">
  <svg class="cover-logo" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--brass)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
    <path d="M6 5v14" />
    <path d="M18 5v14" />
    <path d="M6 12l6-4 6 4" />
  </svg>
  {% if inv.agent_name %}<div class="agent-name">{{ inv.agent_name }}</div>{% endif %}
  <div class="kicker">Property Inventory</div>
  <h1>{{ inv.report_type }}</h1>
  {% if inv.property_address %}
  <div class="addr">{{ inv.property_address }}</div>
  {% else %}
  <div class="addr addr-missing">Address not yet specified</div>
  {% if not final %}<div class="meta screen-only"><a href="./#finish">Add address</a> in Review</div>{% endif %}
  {% endif %}
  {% if inv.property_type %}<div class="property-type">{{ inv.property_type }}</div>{% endif %}
  <table>
    <tr><td>Date of inspection</td><td><strong>{{ inv.inspected_at | human_date }}</strong></td></tr>
    {% if inv.inspected_by %}
    <tr><td>Prepared by</td><td><strong>{{ inv.inspected_by }}</strong></td></tr>
    {% endif %}
    {% if inv.landlord_name %}
    <tr><td>Landlord / agent</td><td><strong>{{ inv.landlord_name }}</strong></td></tr>
    {% endif %}
    {% if inv.tenant_name %}
    <tr><td>Tenant</td><td><strong>{{ inv.tenant_name }}</strong></td></tr>
    {% endif %}
    {% if inv.report_ref %}
    <tr><td>Report reference</td><td><strong>{{ inv.report_ref }}</strong></td></tr>
    {% endif %}
    <tr><td>Rooms inspected</td><td><strong>{{ inv.rooms | length }}</strong></td></tr>
    <tr><td>Items recorded</td><td><strong>{{ total_items }}</strong></td></tr>
    <tr><td>Photographs</td><td><strong>{{ total_photos }}</strong>{% if hero_total and hero_total < total_photos %}<span class="screen-only meta"> — {{ hero_total }} shown, every frame analysed &amp; hashed in Appendix A</span>{% endif %}</td></tr>
    {% if reviewed_items %}
    <tr class="screen-only"><td>Human-reviewed</td><td><strong>{{ reviewed_items }} of {{ total_items }} items</strong></td></tr>
    {% endif %}
  </table>
</div>

<section class="toc page-break">
  <h2>Contents</h2>
  <ol class="toc-list">
    <li><a href="#schedule">1. Schedule of Condition</a></li>
    {% for section in room_sections %}
    <li><a href="#room-{{ section.number }}">{{ section.number }}. {{ section.name }}</a></li>
    {% endfor %}
    <li><a href="#appendix-manifest">Appendix A — Photographic evidence manifest</a></li>
    {% if total_photos %}
    <li><a href="#appendix-photos">Appendix B — Room photographs</a></li>
    {% endif %}
    <li><a href="#declaration">Declaration</a></li>
  </ol>
</section>

<h2>Condition key &amp; basis of this report</h2>
<p><strong>Condition:</strong> New &middot; Excellent &middot; Good (sound, light wear)
&middot; Fair (visible wear or marks) &middot; Poor (damaged or heavily worn).
Items the inspection could not assess are marked <em>not tested</em> or
<em>not visible</em>.<br>
<strong>Cleanliness:</strong> Professionally cleaned &middot; Cleaned to domestic
standard &middot; Requires cleaning.</p>
<p>This report records the contents and internal condition of the property at the
date of inspection, supported by the embedded photographs. Original image files are
identified by SHA-256 checksum in Appendix A; any party holding the original files
can re-compute the checksums to confirm the photographic record is unaltered.
AI-drafted entries that the reviewer rejected remain visible, struck through,
rather than silently deleted.</p>
{% if inv.notes %}<p class="summary">{{ inv.notes }}</p>{% endif %}

<section class="schedule-summary page-break" id="schedule">
  <h2>1. Schedule of Condition</h2>
  <table class="items">
    <thead><tr><th style="width:9%">Ref</th><th style="width:28%">Name</th><th>Condition</th></tr></thead>
    <tbody>
    {% for row in schedule_summary %}
      <tr><td class="ref-mono">{{ row.ref }}</td><td>{{ row.name }}</td>
          <td class="cond-merged">{{ row.condition }}</td></tr>
    {% endfor %}
    </tbody>
  </table>
</section>

{% macro photo_figure(photo, cls="") -%}
    <figure id="photo-{{ photo.id }}" data-photo-id="{{ photo.id }}"{% if cls %} class="{{ cls }}"{% endif %}>
      <div class="frame">
        <img src="{{ photo_src[photo.id] }}" alt="{{ photo.id }}" loading="lazy">
        {% for reg in regions_by_photo.get(photo.id, []) %}
          <span class="region" data-label="Ex {{ reg.exhibit }} · {{ reg.item_id }} · {{ reg.defect }}"
                style="left:{{ '%.2f' | format(reg.x * 100) }}%;top:{{ '%.2f' | format(reg.y * 100) }}%;width:{{ '%.2f' | format(reg.w * 100) }}%;height:{{ '%.2f' | format(reg.h * 100) }}%;"></span>
        {% endfor %}
      </div>
      <figcaption>{{ photo.id }}{% if photo.captured_at %} &middot; {{ photo.captured_at }}{% endif %}
        {%- if photo_time.get(photo.id) %} &middot;
          {%- if final %} seen at {{ photo_time[photo.id].t | timecode }} in {{ photo.source_video | basename }}
          {%- else %} <a class="moment-link deep-link" href="./#moment={{ photo.id }}"
             title="Play this moment of the walkthrough in the review app">seen at {{ photo_time[photo.id].t | timecode }}</a> in {{ photo.source_video | basename }}{% endif %}
        {%- elif photo.source_video %} &middot; frame of {{ photo.source_video | basename }}{% endif %}</figcaption>
    </figure>
{%- endmacro %}

{% for section in room_sections %}
<section class="room" id="room-{{ section.number }}" data-room="{{ section.name }}">
  <h2>{{ section.number }}. {{ section.name }}</h2>
  {% set n_items = section.groups | map(attribute="rows") | map("length") | sum %}
  <p class="room-meta screen-only">{{ n_items }} item{{ "s" if n_items != 1 }} recorded
    &middot; {{ section.photos | length }} frame{{ "s" if section.photos | length != 1 }} analysed{% if section.more_photos %}, {{ section.hero_photos | length }} shown{% endif %}
    {%- if section.cover and section.cover.source_video %} &middot; footage {{ section.cover.source_video | basename }}{% endif %}</p>
  {% if section.cover and photo_src.get(section.cover.id) %}
  {{ photo_figure(section.cover, "room-cover screen-only") }}
  {% endif %}
  {% if section.summary %}<div class="summary">{{ section.summary }}</div>{% endif %}

  <table class="items">
    <thead>
      <tr><th style="width:9%">Ref</th><th style="width:18%">Item</th>
          <th>Description</th><th style="width:22%">Condition</th>
          <th class="screen-only" style="width:13%">Cleanliness</th>
          <th class="screen-only" style="width:18%">Defects noted</th>
          <th class="screen-only" style="width:8%">Photos</th></tr>
    </thead>
    <tbody>
    {% for group in section.groups %}
      {% if group.heading %}
      <tr class="category-row"><td colspan="7"><strong>{{ group.heading }}</strong></td></tr>
      {% endif %}
      {% for row in group.rows %}
      {% set item = row.item %}
      <tr class="item-row{% if item.rejected %} item-rejected{% endif %}"
          data-item-id="{{ item.id }}" data-ref="{{ row.ref }}" data-room="{{ section.name }}">
        <td class="ref-cell"><span class="ref-mono">{{ row.ref }}</span>
          {% if final %}<span class="screen-only ref-internal ref-mono">{{ item.id }}</span>
          {% else %}<a class="screen-only ref-internal ref-mono deep-link"
             href="./#item-{{ item.id }}" title="Open this item in the review app">{{ item.id }}</a>{% endif %}
          {% if item.added_by %}<span class="meta">added by {{ item.added_by }}</span>{% endif %}
        </td>
        <td class="name-cell">{% if item.rejected %}<span class="review-flag no">rejected</span>
          {% elif final %}
          {% elif item.reviewed %}<span class="review-flag ok">reviewed</span>
          {% elif reviewed_items %}<span class="review-flag pending">unreviewed</span>{% endif -%}
          {% if crop_src.get(item.id) %}<img class="item-thumb"
            src="{{ crop_src[item.id] }}" alt="" loading="lazy">{% endif -%}
          <strong class="item-name">{{ item.name }}</strong>{% if item.quantity > 1 %} &times;{{ item.quantity }}{% endif %}
          {% if item.rejected %}<br><span class="meta">AI suggested — reviewer rejected</span>{% endif %}
        </td>
        <td class="desc-cell"><span class="desc-text">{{ item.description }}</span>
          {%- if item.photo_ids %}
          <div class="ev-refs print-only">Evidence: {{ item.photo_ids | join(", ") }}</div>
          {%- endif %}
        </td>
        <td class="cond-cell">
          <span class="screen-only grade-word {{ item.condition or '' }}">{{ item.not_inspected or item.condition or "—" }}</span>
          <div class="print-only">
            <span class="grade-word {{ item.condition or '' }}">{{ row.grades_line }}</span>
            {%- if item.defects or item.rejected_defects %}
            <ul class="defects">
              {% for d in item.defects %}<li>{{ d }}</li>{% endfor %}
              {% for d in item.rejected_defects %}<li class="struck">{{ d }}</li>{% endfor %}
            </ul>
            {%- endif %}
          </div>
        </td>
        <td class="clean-cell screen-only">{{ item.cleanliness or "—" }}</td>
        <td class="def-cell screen-only">
          {% if item.defects or item.rejected_defects %}<ul class="defects">
            {% for d in item.defects %}<li>{{ d }}</li>{% endfor %}
            {% for d in item.rejected_defects %}<li class="struck">{{ d }}</li>{% endfor %}
          </ul>{% else %}<span class="meta">None noted</span>{% endif %}
        </td>
        <td class="photo-cell screen-only meta ref-mono">{{ item.photo_ids | join(", ") }}</td>
      </tr>
      {% for c in item.comments %}
      <tr class="comment-row screen-only" data-for="{{ item.id }}">
        <td></td><td colspan="6"><span class="who">{{ c.author or "?" }}
          ({{ c.role or "reviewer" }}{% if c.at %}, {{ c.at[:10] }}{% endif %}):</span>
          {{ c.text }}</td>
      </tr>
      {% endfor %}
      {% endfor %}
    {% endfor %}
    </tbody>
  </table>

  {% if section.photos %}
  {% set cover_id = section.cover.id if section.cover else none %}
  {% set strip_photos = section.hero_photos | rejectattr("id", "equalto", cover_id) | list %}
  <h3 class="screen-only">Photographs — {{ section.name }}</h3>
  {% if strip_photos %}
  <div class="photos screen-only">
    {% for photo in strip_photos %}{{ photo_figure(photo) }}{% endfor %}
  </div>
  {% endif %}
  {% if section.more_photos %}
  <details class="more-frames screen-only">
    <summary>All {{ section.photos | length }} frames — every angle the
      walkthrough captured, blurred passes included</summary>
    <div class="photos">
      {% for photo in section.more_photos %}{{ photo_figure(photo) }}{% endfor %}
    </div>
  </details>
  {% endif %}
  {% endif %}
</section>
{% endfor %}

<section class="room appendix page-break" id="appendix-manifest">
  <h2>Appendix A — Photographic evidence manifest (SHA-256)</h2>
  <p class="meta">Paths are relative to the capture folder. Frames extracted
  from a walkthrough video are hashed as extracted and name their source
  video; the original video files are hashed in <code>manifest.json</code>.</p>
  <table>
    <thead><tr><th>ID</th><th>Room</th><th>File</th><th>Captured</th><th>SHA-256</th></tr></thead>
    <tbody>
    {% for room in inv.rooms %}{% for photo in room.photos %}
      <tr><td>{{ photo.id }}</td><td>{{ room.name }}</td>
          <td>{{ photo_display_path[photo.id] }}{% if photo.source_video %}<br>
            <span class="meta">{% if photo_time.get(photo.id) %}at {{ photo_time[photo.id].t | timecode }} in {% else %}frame of {% endif %}{{ photo.source_video | basename }}</span>{% endif %}</td>
          <td>{{ photo.captured_at or "—" }}</td>
          <td class="hash">{{ photo.sha256 or "—" }}</td></tr>
    {% endfor %}{% endfor %}
    </tbody>
  </table>
</section>

{% if total_photos %}
<section class="room appendix-photos print-only page-break" id="appendix-photos">
  <h2>Appendix B — Room photographs</h2>
  {% for section in room_sections %}
  {% if section.appendix_photos %}
  <h3>{{ section.number }}. {{ section.name }}</h3>
  <div class="photo-sheet">
    {% for photo in section.appendix_photos %}
    <figure id="pdf-photo-{{ photo.id }}" data-photo-id="{{ photo.id }}"
            class="{% if regions_by_photo.get(photo.id) %}annotated {% endif %}{% if loop.index % 12 == 0 %}sheet-break{% endif %}">
      <span class="frame">
        <img src="{{ photo_print_src[photo.id] }}" alt="{{ photo.id }}">
        {% for reg in regions_by_photo.get(photo.id, []) %}
          <span class="region" data-label="Ex {{ reg.exhibit }} · {{ reg.item_id }} · {{ reg.defect }}"
                style="left:{{ '%.2f' | format(reg.x * 100) }}%;top:{{ '%.2f' | format(reg.y * 100) }}%;width:{{ '%.2f' | format(reg.w * 100) }}%;height:{{ '%.2f' | format(reg.h * 100) }}%;"></span>
        {% endfor %}
      </span>
      <figcaption>
        <div class="ref-tag">{{ photo.id }} — Ref {{ section.number }}</div>
        <div>{% if photo.captured_at %}{{ photo.captured_at | human_date }}
          {%- elif photo_time.get(photo.id) %}seen at {{ photo_time[photo.id].t | timecode }} in {{ photo.source_video | basename }}
          {%- elif photo.source_video %}frame of {{ photo.source_video | basename }}
          {%- else %}{{ inv.inspected_at | human_date }}{% endif %}</div>
      </figcaption>
    </figure>
    {% endfor %}
  </div>
  {% if section.appendix_pruned %}
  <p class="meta">{{ section.appendix_pruned }} further
  frame{{ "s" if section.appendix_pruned != 1 }} of this room
  {{ "was" if section.appendix_pruned == 1 else "were" }} analysed but not
  reproduced here (near-duplicate or lower-quality walkthrough frames cited
  by no item); every file remains listed with its checksum in Appendix A.</p>
  {% endif %}
  {% endif %}
  {% endfor %}
</section>
{% endif %}

<section class="declaration page-break" id="declaration">
  <h3>Declaration</h3>
  <p>This inventory was prepared with AI assistance and has been reviewed for
  accuracy by the undersigned. It provides a fair and accurate record of the
  contents and internal condition of the property on the date stated. Unless
  amendments are notified in writing within 7 days of receipt, this inventory
  will be deemed accepted by all parties.</p>
  <p class="initials-note print-only">Tenant: please initial each page to confirm you have read this report.</p>
  {% if inv.signatures %}
  <div id="signatures">
    {% for sig in inv.signatures %}
    <div class="sigcard">
      <strong>{{ sig.name }}</strong> — {{ sig.role }} — signed {{ sig.signed_at }}
      {% if sig.via %}<span class="meta">({{ sig.via }})</span>{% endif %}
      {% if sig.inventory_sha256 %}<div class="hash">attests content sha256
        {{ sig.inventory_sha256 }}</div>{% endif %}
    </div>
    {% endfor %}
  </div>
  {% else %}<div id="signatures"></div>{% endif %}
  <div>
    <span class="sigline"></span><span class="sigline"></span><br>
    <span class="meta">Landlord / Agent &nbsp; — date</span>
    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
    <span class="meta">Tenant &nbsp; — date</span>
  </div>
</section>

<footer class="doc-footer">
  <div class="pdf-brand print-only">{{ agent_display }}{% if inv.agent_phone %} &middot; {{ inv.agent_phone }}{% endif %}</div>
  <span class="tool-meta screen-only">Generated by homeinventory v{{ inv.tool_version }}
  &middot; AI drafting: {{ inv.describe_backend or "none" }}
  &middot; {{ inv.inspected_at | human_date }}</span>
</footer>
</main>

{% if not final %}
<div id="docket" aria-label="Review progress">
  <div class="bar">
    <span class="brand">Review progress</span>
    <div id="progress">
      <div class="label"><span id="prog-n">0</span> of <span id="prog-d">0</span> items confirmed</div>
      <div class="track"><div class="fill" id="prog-fill"></div></div>
    </div>
    <a class="dk-btn primary deep-link" id="btn-continue-review"
       href="./#overview">Continue in Review</a>
  </div>
</div>
<div id="toast" role="status"></div>

<script type="application/json" id="hi-data">{{ payload | tojson }}</script>
<script>
{% include "_ui.js.j2" %}
</script>
<script>
"use strict";
/* Read-only review progress (docs/17 X3). Grading lives in the review app only. */
(function () {
  var dataEl = document.getElementById("hi-data");
  if (!dataEl) return;
  var payload = JSON.parse(dataEl.textContent);
  var inv = payload.inventory;
  var itemsById = {};
  inv.rooms.forEach(function (room) {
    (room.items || []).forEach(function (it) { itemsById[it.id] = it; });
  });

  function counts() {
    var total = 0, done = 0;
    Object.keys(itemsById).forEach(function (id) {
      total += 1;
      if (itemsById[id].reviewed || itemsById[id].rejected) done += 1;
    });
    return { total: total, done: done };
  }
  function updateProgress() {
    var c = counts();
    document.getElementById("prog-n").textContent = c.done;
    document.getElementById("prog-d").textContent = c.total;
    document.getElementById("prog-fill").style.width =
      c.total ? (100 * c.done / c.total) + "%" : "0";
    /* "Continue in Review" always opens at Overview; the progress meter above
       is what signals that items still need reviewing (docs/24 F2). */
  }

  /* file://: strip shell links that would dead-end */
  if (location.protocol === "file:") {
    var shell = document.getElementById("app-shell");
    if (shell) shell.remove();
    Array.prototype.forEach.call(
      document.querySelectorAll("a.deep-link"), function (a) {
        var span = document.createElement("span");
        span.className = a.className.replace("deep-link", "").trim();
        span.textContent = a.textContent;
        a.parentNode.replaceChild(span, a);
      });
  }

  /* Force Overview (docs/24 F2) — avoid stale #item-* from bfcache/history. */
  var cont = document.getElementById("btn-continue-review");
  if (cont) {
    cont.addEventListener("click", function (e) {
      e.preventDefault();
      var path = location.pathname.replace(/\/?report\/?$/, "/") || "/";
      location.assign(path + "#overview");
    });
  }

  document.getElementById("docket").classList.add("on");
  updateProgress();
})();
</script>
{% endif %}
</body>
</html>
