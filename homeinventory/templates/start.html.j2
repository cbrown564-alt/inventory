<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>New report — Homeinventory</title>
{% include "_favicon.j2" %}
<style>
{% include "_theme.css.j2" %}

  main { max-width: 1080px; margin: 0 auto; padding: 0 24px 64px; }
  .banner { background: var(--brass-soft); border: 1px solid var(--brass);
            border-radius: 10px; padding: 12px 16px; margin: 22px 0 0;
            font-size: 14px; }
  .banner a { color: var(--brass-bright); font-weight: 600; }

  .hero { display: grid; grid-template-columns: minmax(0, 1.05fr)
          minmax(0, 1fr); gap: 56px; align-items: start;
          padding-top: 54px; }
  h1 { font: 600 clamp(30px, 4.2vw, 44px)/1.12 var(--display);
       letter-spacing: -.015em; margin: 0 0 14px; color: var(--ink); }
  h1 em { font-style: italic; color: var(--brass); }
  .sub { font-size: 15.5px; line-height: 1.65; color: var(--muted);
         margin: 0 0 30px; max-width: 46ch; }

  /* the filming sequence — order matters, hence the numerals */
  .guide { list-style: none; margin: 0; padding: 0; counter-reset: film; }
  .guide li { counter-increment: film; display: flex; gap: 14px;
              padding: 11px 0; border-top: 1px solid var(--line);
              font-size: 14px; align-items: baseline; }
  .guide li::before { content: counter(film); flex: 0 0 26px; height: 26px;
    border: 1px solid var(--brass); border-radius: 50%; color: var(--brass);
    font: 600 12px/24px var(--display); text-align: center;
    position: relative; top: 3px; }
  .guide li b { font-weight: 600; }
  .guide-kicker { font-size: 11px; font-weight: 600; letter-spacing: .14em;
    text-transform: uppercase; color: var(--faint); margin: 0 0 6px; }

  /* the drop slate — a window into the evidence room */
  .slate { background:
      radial-gradient(420px 200px at 50% -60px, #1a2029 0%, #0e1116 70%);
    border: 1px solid #2a3340; border-radius: 14px; padding: 18px;
    box-shadow: var(--shadow); }
  #drop { border: 2px dashed rgba(200, 163, 92, .45); border-radius: 10px;
    padding: 44px 20px; text-align: center; color: #94a1b2;
    cursor: pointer; transition: border-color .18s, background .18s;
    font-size: 13.5px; }
  #drop:hover, #drop.over { border-color: #e5c47f;
    background: rgba(200, 163, 92, .07); }
  #drop .play { width: 46px; height: 46px; border-radius: 50%; margin: 0
    auto 12px; border: 1.5px solid rgba(200, 163, 92, .55); display: flex;
    align-items: center; justify-content: center; }
  #drop .play svg { display: block; margin-left: 3px; }
  #drop strong { color: #e8ecf1; display: block; font-size: 15px;
                 margin-bottom: 3px; }
  .slate .formats { margin: 12px 4px 0; font: 11px var(--mono);
                    color: #5f6c7c; text-align: center; }
  #up-list { margin-top: 12px; display: grid; gap: 6px; }
  .up-row { display: grid; grid-template-columns: 1fr 90px; gap: 4px 12px;
            align-items: center; font-size: 13px; color: #c6cdd6; }
  .up-row .nm { overflow: hidden; text-overflow: ellipsis;
                white-space: nowrap; font-family: var(--mono);
                font-size: 12px; }
  .up-row .st { text-align: right; color: #94a1b2; font-size: 12px;
                font-variant-numeric: tabular-nums; }
  .up-row .st.err { color: #e06459; }
  .up-row .st.ok { color: #45b681; }
  .up-row .track { grid-column: 1 / -1; height: 3px; background: #232c38;
                   border-radius: 2px; overflow: hidden; }
  .up-row .fill { height: 100%; width: 0; background: var(--brass);
                  transition: width .2s; }
  .ready { margin-top: 12px; font-size: 12.5px; color: #94a1b2;
           text-align: center; }
  .ready b { color: #e5c47f; font-weight: 600; }

  .build { margin-top: 18px; display: flex; gap: 14px; align-items: center;
           flex-wrap: wrap; }
  .build .btn.primary { padding: 11px 26px; font-size: 14px; }
  .spend { font-size: 12.5px; color: var(--muted); }
  .spend b { color: var(--ink); font-weight: 600; }

  /* staged build progress */
  #build-status { margin-top: 16px; }
  #build-status.err .stage-now { color: var(--danger); }
  .stages { list-style: none; margin: 0; padding: 0; }
  .stages li { display: flex; gap: 10px; align-items: baseline;
               padding: 6px 0; font-size: 13.5px; color: var(--faint); }
  .stages li::before { content: "○"; flex: 0 0 16px; text-align: center; }
  .stages li.done { color: var(--muted); }
  .stages li.done::before { content: "✓"; color: var(--confirm); }
  .stages li.now { color: var(--ink); font-weight: 600; }
  .stages li.now::before { content: "●"; color: var(--brass);
    animation: pulse 1.4s ease-in-out infinite; }
  @keyframes pulse { 50% { opacity: .35; } }
  .stages li .note { font-weight: 400; color: var(--muted);
                     font-size: 12.5px; }
  .stage-now { font-weight: 600; font-size: 14px; }
  #build-status details { margin-top: 8px; font-size: 12.5px;
                          color: var(--muted); }
  #build-status pre { max-height: 240px; overflow: auto;
    white-space: pre-wrap; font: 11px var(--mono); background: var(--panel);
    border: 1px solid var(--line); border-radius: 7px; padding: 8px 10px; }

  /* report-type picker */
  #use-case-picker { max-width: 720px; margin: 60px auto 0; }
  #use-case-picker h1 { text-align: center; }
  #use-case-picker .lede { text-align: center; color: var(--muted);
    margin: 0 0 30px; }
  .cards { display: grid; grid-template-columns: repeat(auto-fit,
           minmax(280px, 1fr)); gap: 16px; }
  .card { text-align: left; background: var(--panel);
    border: 1px solid var(--line-strong); border-radius: 12px;
    padding: 22px 22px 20px; cursor: pointer;
    transition: border-color .15s, transform .15s, box-shadow .15s;
    border-top: 3px solid var(--brass); }
  .card:hover { border-color: var(--brass); transform: translateY(-2px);
                box-shadow: var(--shadow); }
  .card strong { display: block; font: 600 19px/1.25 var(--display);
                 margin-bottom: 7px; color: var(--ink); }
  .card span { color: var(--muted); font-size: 13.5px; line-height: 1.55; }
  #picker-status.err { color: var(--danger); margin-top: 12px;
                       text-align: center; }

  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; gap: 30px; padding-top: 30px; }
    .sub { margin-bottom: 20px; }
  }
</style>
</head>
<body>
<header class="app-header">
  <span class="wordmark">Homeinventory</span>
  <nav class="app-nav" aria-label="Sections">
    <a href="/start" aria-current="page">New report</a>
    {% if has_inventory %}
    <a href="/">Review</a>
    <a href="/report" target="_blank" rel="noopener">Report</a>
    {% endif %}
  </nav>
  {% if not show_picker|default(false) and use_case_label|default(none) %}
  <span class="header-chip" id="use-case-chip">{{ use_case_label }}</span>
  {% endif %}
</header>
<main>

{% if show_picker|default(false) %}
<section id="use-case-picker">
  <h1>What are you evidencing?</h1>
  <p class="lede">Pick the report type — it sets the sections, the grades
    and who signs.</p>
  <div class="cards">
  {% for u in use_cases|default([]) %}
    <button class="card" data-use-case="{{ u.key }}" type="button">
      <strong>{{ u.name }}</strong>
      <span>{{ u.description }}</span>
    </button>
  {% endfor %}
  </div>
  <div id="picker-status"></div>
</section>
{% endif %}

{% if not show_picker|default(false) %}
{% if has_inventory %}
<div class="banner">A report already exists —
  <a href="/">open review</a>. Building again re-describes every room but
  keeps your confirmed and hand-added items.</div>
{% endif %}

{% set cap = capture|default({"rooms": [], "walkthrough_videos": 0}) %}
<div class="hero">
  <section id="filming-guide" class="pitch">
    <h1>Walk the property once.<br>Leave with <em>evidence</em>.</h1>
    <p class="sub">Film one continuous walkthrough on your phone and drop
      it here. The rooms are found, every item is drafted, and each claim
      stays tied to the second of footage that proves it — you review
      and sign.</p>
    <p class="guide-kicker">Before you film</p>
    <ul class="guide">
      <li><span><b>Walk slowly</b> — steady pans, not rushed sweeps.</span></li>
      <li><span><b>Say each room's name aloud</b> as you enter
        (Kitchen, Bedroom 1…).</span></li>
      <li><span><b>Pause for a wide shot</b> in each room, then close-ups
        of any defects.</span></li>
      <li><span><b>Keep rolling</b> — one continuous video is fine; the
        rooms are found for you.</span></li>
    </ul>
  </section>

  <section id="upload" class="action">
    <div class="slate">
      <div id="drop" role="button" tabindex="0"
           aria-label="Choose or drop your walkthrough video">
        <div class="play">
          <svg width="16" height="18" viewBox="0 0 16 18" aria-hidden="true">
            <path d="M1 1.5v15l14-7.5z" fill="none" stroke="#c8a35c"
                  stroke-width="1.6" stroke-linejoin="round"/>
          </svg>
        </div>
        <strong>Drop your walkthrough video</strong>
        or click to choose a file
      </div>
      <input type="file" id="up-files" accept="video/*" hidden>
      <div id="up-list"></div>
      {% if cap.walkthrough_videos %}
      <p class="ready"><b>{{ cap.walkthrough_videos }}</b> walkthrough
        video{{ "s" if cap.walkthrough_videos != 1 }} ready to build.</p>
      {% endif %}
      <p class="formats">MP4 · MOV · MKV · WebM — up to 2 GiB. Stays on
        your machine.</p>
    </div>

    <div class="build" id="build">
      <button class="btn primary" id="btn-build"
              {% if not cap.walkthrough_videos and not cap.rooms %}disabled{% endif %}>
        Build the report</button>
      <span class="spend"><b>{{ spend.label }}</b> · est.
        {{ spend.estimate }}</span>
    </div>
    <div id="build-status" role="status" aria-live="polite"></div>
  </section>
</div>
{% endif %}

</main>
<div id="toast" role="status"></div>
<script>
{% include "_ui.js.j2" %}
</script>
<script>
"use strict";
(function () {
  var SPEND = {{ spend|default({"label":"Report","estimate":"varies","note":""}) | tojson }};
  var WALKTHROUGH = {{ walkthrough_room|default("__walkthrough__", true) | tojson }};
  var PREFIX = {{ route_prefix|default("", true) | tojson }};
  var el = ui.el, toast = ui.toast;

  function api(method, url, body) {
    return fetch(url, {
      method: method,
      headers: { "Content-Type": "application/json" },
      body: body === undefined ? undefined : JSON.stringify(body)
    }).then(function (r) {
      return r.json().catch(function () { return {}; }).then(function (j) {
        if (!r.ok) throw new Error(j.error || (r.status + ""));
        return j;
      });
    });
  }

  var drop = document.getElementById("drop");
  var fileInput = document.getElementById("up-files");
  var upList = document.getElementById("up-list");
  var bBtn = document.getElementById("btn-build");
  var active = 0;

  function fmtBytes(n) {
    if (n > 1e9) return (n / 1e9).toFixed(1) + " GB";
    if (n > 1e6) return (n / 1e6).toFixed(1) + " MB";
    return Math.max(1, Math.round(n / 1e3)) + " kB";
  }

  function startUpload(job) {
    active += 1;
    job.st.textContent = "uploading";
    var xhr = new XMLHttpRequest();
    xhr.open("POST", PREFIX + "/api/upload");
    xhr.setRequestHeader("X-Room", encodeURIComponent(WALKTHROUGH));
    xhr.setRequestHeader("X-Filename", encodeURIComponent(job.file.name));
    xhr.upload.onprogress = function (e) {
      if (e.lengthComputable) {
        job.fill.style.width = Math.round(100 * e.loaded / e.total) + "%";
      }
    };
    xhr.onload = function () {
      active -= 1;
      var resp = {};
      try { resp = JSON.parse(xhr.responseText || "{}"); } catch (e) {}
      if (xhr.status === 200) {
        job.fill.style.width = "100%";
        job.st.textContent = "done";
        job.st.className = "st ok";
        if (bBtn) bBtn.disabled = false;
      } else {
        job.st.textContent = resp.error || ("failed (" + xhr.status + ")");
        job.st.className = "st err";
      }
    };
    xhr.onerror = function () {
      active -= 1;
      job.st.textContent = "network error";
      job.st.className = "st err";
    };
    xhr.send(job.file);
  }

  function addFiles(files) {
    Array.prototype.forEach.call(files, function (f) {
      if (!f.type.startsWith("video/") && !/\.(mp4|mov|mkv|webm|avi|m4v)$/i.test(f.name)) {
        toast("Please upload a walkthrough video (MP4, MOV, MKV, WebM)");
        return;
      }
      var row = el("div", { "class": "up-row" });
      var nm = el("span", { "class": "nm",
        text: f.name + " · " + fmtBytes(f.size) });
      var st = el("span", { "class": "st", text: "queued" });
      var track = el("span", { "class": "track" });
      var fill = el("span", { "class": "fill" });
      fill.style.display = "block";
      track.appendChild(fill);
      row.appendChild(nm); row.appendChild(st); row.appendChild(track);
      upList.appendChild(row);
      startUpload({ file: f, st: st, fill: fill });
    });
  }

  if (drop) {
    drop.addEventListener("click", function () { fileInput.click(); });
    drop.addEventListener("keydown", function (e) {
      if (e.key === "Enter" || e.key === " ") { e.preventDefault();
        fileInput.click(); }
    });
    fileInput.addEventListener("change", function () {
      addFiles(fileInput.files);
      fileInput.value = "";
    });
    ["dragenter", "dragover"].forEach(function (ev) {
      drop.addEventListener(ev, function (e) {
        e.preventDefault(); drop.classList.add("over");
      });
    });
    ["dragleave", "drop"].forEach(function (ev) {
      drop.addEventListener(ev, function (e) {
        e.preventDefault(); drop.classList.remove("over");
      });
    });
    drop.addEventListener("drop", function (e) {
      if (e.dataTransfer && e.dataTransfer.files.length) {
        addFiles(e.dataTransfer.files);
      }
    });
  }

  /* Build progress as the journey's stages, not a spinner. */
  var STAGES = [
    { key: "segmenting", label: "Watching your video" },
    { key: "segmented", label: "Finding the rooms" },
    { key: "describing", label: "Drafting each room" },
    { key: "rendering", label: "Building your report" }
  ];
  function stageIndex(s) {
    if (s.stage === "done") return STAGES.length;
    for (var i = 0; i < STAGES.length; i++) {
      if (STAGES[i].key === s.stage) return i;
    }
    return s.status === "running" ? 0 : -1;
  }
  var bStatus = document.getElementById("build-status");
  function setBuildStatus(s, err, detail) {
    if (!bStatus) return;
    bStatus.className = err ? "err" : "";
    bStatus.innerHTML = "";
    if (err) {
      bStatus.appendChild(el("div", { "class": "stage-now",
        text: "The build failed — nothing was lost. Fix and build again." }));
    } else {
      var at = stageIndex(s);
      if (at < 0 && !s.stage) { return; }
      var list = el("ul", { "class": "stages" });
      STAGES.forEach(function (st, i) {
        var li = el("li", { "class": i < at ? "done" : i === at ? "now" : "" });
        var lbl = st.label;
        li.appendChild(el("span", { text: lbl }));
        if (i === at && s.stage_detail) {
          li.appendChild(el("span", { "class": "note",
            text: " — " + s.stage_detail }));
        } else if (st.key === "segmented" && i < at && s.rooms_found) {
          li.appendChild(el("span", { "class": "note",
            text: " — " + s.rooms_found + " rooms" }));
        }
        list.appendChild(li);
      });
      if (at >= STAGES.length) {
        list.appendChild(el("li", { "class": "now",
          text: "Your report is ready — opening the review…" }));
      }
      bStatus.appendChild(list);
    }
    if (detail) {
      bStatus.appendChild(el("details", {}, [
        el("summary", { text: "Show log" }),
        el("pre", { text: detail })]));
    }
  }
  function pollBuild() {
    if (!bBtn) return;
    api("GET", PREFIX + "/api/build").then(function (s) {
      if (s.status === "running") {
        bBtn.disabled = true;
        setBuildStatus(s, false, "");
        setTimeout(pollBuild, 1500);
      } else if (s.status === "done") {
        setBuildStatus({ stage: "done" }, false, "");
        location.href = PREFIX + "/";
      } else if (s.status === "failed") {
        bBtn.disabled = false;
        setBuildStatus(s, true, s.detail || "");
      }
    }).catch(function () {});
  }
  if (bBtn) {
    bBtn.addEventListener("click", function () {
      ui.confirmDialog({
        title: "Build your report?",
        message: SPEND.label + " — estimated " + SPEND.estimate + ". " +
                 (SPEND.note || ""),
        confirmLabel: "Build report"
      }).then(function (yes) {
        if (!yes) return;
        bBtn.disabled = true;
        api("POST", PREFIX + "/api/build", { confirm: "yes" }).then(function () {
          pollBuild();
        }).catch(function (e) {
          bBtn.disabled = false;
          setBuildStatus({}, true, e.message);
        });
      });
    });
    pollBuild();
  }

  var picker = document.getElementById("use-case-picker");
  if (picker) {
    var pStatus = document.getElementById("picker-status");
    picker.querySelectorAll("[data-use-case]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var key = btn.getAttribute("data-use-case");
        btn.disabled = true;
        api("POST", "/api/project", { use_case: key }).then(function () {
          location.reload();
        }).catch(function (e) {
          btn.disabled = false;
          pStatus.textContent = e.message;
          pStatus.className = "err";
        });
      });
    });
  }
})();
</script>
</body>
</html>
