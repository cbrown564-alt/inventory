<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>{% if prebuild %}New inspection{% else %}{{ inv.property_address or 'Inspection workspace' }}{% endif %} — Home Inventory</title>
{% include "_favicon.j2" %}
<style>
{% include "_theme.css.j2" %}

  :root { --field-max: 1180px; --field-blue: #1f465f; --field-blue-soft: #e9f0f4; --media: #0e1116; }
  body { min-height: 100svh; background: var(--paper); }
  button, input, select { font: inherit; }
  .field-header { height: 60px; padding: 0 max(20px, env(safe-area-inset-right)) 0 max(20px, env(safe-area-inset-left));
    border-bottom: 1px solid var(--line); background: rgba(255,253,248,.92);
    backdrop-filter: blur(14px); display: flex; align-items: center; justify-content: space-between;
    position: sticky; top: 0; z-index: 20; }
  .field-brand { display: inline-flex; gap: 9px; align-items: center; color: var(--ink); text-decoration: none;
    font: 600 16px/1 var(--display); letter-spacing: -.01em; }
  .field-mark { width: 27px; height: 27px; border: 1px solid var(--brass); border-radius: 50%; display: grid; place-items: center; color: var(--brass); }
  .field-mark svg { width: 15px; height: 15px; }
  .field-header-actions { display: flex; gap: 4px; align-items: center; }
  .field-header .btn { min-height: 38px; }
  .field-kicker { margin: 0 0 8px; color: var(--brass-bright); font: 600 11px/1.2 var(--ui); letter-spacing: .12em; text-transform: uppercase; }
  .field-main { width: min(100%, var(--field-max)); margin: 0 auto; padding: clamp(28px, 5vw, 72px) max(20px, env(safe-area-inset-right)) calc(100px + env(safe-area-inset-bottom)) max(20px, env(safe-area-inset-left)); }

  /* Capture: pick a record, then make the capture trade-off explicit. */
  .new-record { max-width: 920px; margin: 0 auto; }
  .new-record h1 { max-width: 13ch; margin: 0; font: 600 clamp(39px, 7vw, 74px)/.98 var(--display); letter-spacing: -.045em; }
  .new-record .lede { max-width: 47ch; margin: 20px 0 0; color: var(--muted); font-size: 16px; line-height: 1.6; }
  .method-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; margin-top: clamp(30px, 6vw, 64px); }
  .capture-method { min-height: 230px; padding: 22px; text-align: left; border: 1px solid var(--line-strong); border-radius: 14px; background: var(--panel); color: var(--ink); cursor: pointer; box-shadow: var(--e-1); transition: transform .16s cubic-bezier(.16,1,.3,1), border-color .16s, background .16s; }
  .capture-method:hover, .capture-method:focus-visible, .capture-method.active { border-color: var(--brass); transform: translateY(-2px); }
  .capture-method.active { background: var(--brass-soft); }
  .method-no { display: block; color: var(--brass-bright); font: 600 11px var(--mono); letter-spacing: .1em; }
  .capture-method h2 { margin: 42px 0 8px; font: 600 clamp(24px, 3vw, 31px)/1.1 var(--display); }
  .capture-method p { max-width: 33ch; margin: 0; color: var(--muted); font-size: 14px; line-height: 1.5; }
  .method-tag { display: inline-flex; margin-top: 18px; padding: 4px 8px; border: 1px solid var(--line-strong); border-radius: 999px; color: var(--ink); background: var(--panel); font-size: 12px; }
  .camera-first { display: grid; grid-template-columns: minmax(0, 1.25fr) minmax(260px, .75fr); gap: clamp(22px, 4vw, 56px); margin-top: clamp(30px, 6vw, 64px); padding-top: 24px; border-top: 1px solid var(--line-strong); }
  .camera-first h2 { max-width: 16ch; margin: 0; font: 600 clamp(28px, 4vw, 42px)/1.04 var(--display); letter-spacing: -.03em; }
  .camera-first > div > p { max-width: 53ch; color: var(--muted); line-height: 1.6; }
  .optional-guidance { margin-top: 22px; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .optional-guidance summary { min-height: 52px; display: flex; align-items: center; color: var(--muted); cursor: pointer; font-size: 13px; font-weight: 600; }
  .optional-guidance summary:hover { color: var(--ink); }
  .optional-guidance p { max-width: 62ch; margin: 0 0 17px; color: var(--muted); font-size: 13px; line-height: 1.6; }
  .photo-supplement { display: grid; grid-template-columns: minmax(0, 1.25fr) minmax(260px, .75fr); gap: clamp(22px, 4vw, 56px); margin-top: 30px; padding: 24px 0; border-bottom: 1px solid var(--line-strong); }
  .photo-supplement h2 { margin: 0; font: 600 24px/1.12 var(--display); }
  .photo-supplement p { max-width: 50ch; color: var(--muted); line-height: 1.55; }
  .capture-panel { display: grid; grid-template-columns: minmax(0, 1.25fr) minmax(260px, .75fr); gap: clamp(22px, 4vw, 56px); padding: clamp(24px, 4vw, 42px) 0 0; }
  .capture-brief { padding: 22px 0; border-top: 1px solid var(--line-strong); }
  .capture-brief h2 { margin: 0; font: 600 28px/1.12 var(--display); }
  .capture-brief p { max-width: 50ch; color: var(--muted); line-height: 1.6; }
  .capture-points { list-style: none; margin: 23px 0; padding: 0; }
  .capture-points li { display: grid; grid-template-columns: 24px 1fr; gap: 10px; padding: 11px 0; border-top: 1px solid var(--line); font-size: 14px; line-height: 1.45; }
  .capture-points b { color: var(--brass-bright); font: 600 11px/1.8 var(--mono); }
  .capture-points strong { font-weight: 600; }
  .capture-action { align-self: start; padding: 20px; border: 1px solid var(--line-strong); border-radius: 14px; background: var(--panel); box-shadow: var(--e-1); }
  .capture-action label { display: block; color: var(--muted); font-size: 12px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; }
  .capture-action input[type="text"] { box-sizing: border-box; width: 100%; min-height: 44px; margin: 8px 0 12px; padding: 8px 10px; border: 1px solid var(--line-strong); border-radius: 7px; background: var(--paper); color: var(--ink); }
  .capture-action .btn { width: 100%; min-height: 48px; }
  .capture-note { margin: 12px 0 0; color: var(--muted); font-size: 12.5px; line-height: 1.5; }
  .evidence-ledger { margin-top: 42px; border-top: 1px solid var(--line-strong); }
  .evidence-ledger-head { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; padding: 18px 0; }
  .evidence-ledger h2 { margin: 0; font: 600 19px/1.2 var(--display); }
  .evidence-ledger-head span { color: var(--muted); font-size: 13px; }
  .upload-row { display: grid; grid-template-columns: 38px minmax(0, 1fr) auto; gap: 12px; align-items: center; padding: 12px 0; border-top: 1px solid var(--line); }
  .upload-token { width: 30px; height: 30px; border-radius: 50%; background: var(--panel-2); color: var(--brass-bright); display: grid; place-items: center; font: 600 11px var(--mono); }
  .upload-name { overflow: hidden; color: var(--ink); font-size: 14px; font-weight: 600; text-overflow: ellipsis; white-space: nowrap; }
  .upload-meta { margin-top: 3px; color: var(--muted); font-size: 12px; }
  .upload-state { color: var(--muted); font: 11px var(--mono); }
  .upload-state.ok { color: var(--confirm); }
  .upload-state.err { color: var(--danger); }
  .upload-progress { height: 2px; margin-top: 7px; background: var(--line); overflow: hidden; }
  .upload-progress span { display: block; width: 0; height: 100%; background: var(--brass); transition: width .15s ease; }
  .field-build-bar { position: fixed; z-index: 18; right: 0; bottom: 0; left: 0; padding: 12px max(20px, env(safe-area-inset-right)) calc(12px + env(safe-area-inset-bottom)) max(20px, env(safe-area-inset-left)); background: rgba(255,253,248,.95); border-top: 1px solid var(--line-strong); backdrop-filter: blur(16px); }
  .field-build-inner { width: min(100%, var(--field-max)); margin: 0 auto; display: flex; align-items: center; justify-content: space-between; gap: 16px; }
  .build-summary { color: var(--muted); font-size: 13px; line-height: 1.4; }
  .build-summary b { display: block; color: var(--ink); font-weight: 600; }

  /* Review: room-led hierarchy, a single claim and one thumb-reachable action. */
  .workspace { display: grid; grid-template-columns: 232px minmax(0, 1fr); gap: clamp(32px, 5vw, 84px); align-items: start; }
  .workspace-side { position: sticky; top: 84px; }
  .property-label { padding-bottom: 20px; border-bottom: 1px solid var(--line-strong); }
  .property-label h1 { margin: 5px 0 0; font: 600 28px/1.1 var(--display); letter-spacing: -.02em; }
  .property-label p { margin: 8px 0 0; color: var(--muted); font-size: 13px; line-height: 1.45; }
  .workspace-nav { display: grid; gap: 2px; margin-top: 20px; }
  .workspace-nav button { display: flex; width: 100%; min-height: 42px; align-items: center; justify-content: space-between; padding: 8px 9px; border: 0; border-radius: 7px; color: var(--muted); background: transparent; text-align: left; cursor: pointer; }
  .workspace-nav button:hover, .workspace-nav button[aria-current="page"] { color: var(--ink); background: var(--brass-soft); }
  .workspace-nav b { font-size: 13px; font-weight: 600; }
  .workspace-nav span { color: var(--brass-bright); font: 11px var(--mono); }
  .side-footer { margin-top: 24px; color: var(--faint); font-size: 12px; line-height: 1.5; }
  .side-footer a { color: var(--muted); }
  .workspace-main { min-width: 0; }
  .workspace-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 18px; margin-bottom: 26px; }
  .workspace-top h2 { max-width: 16ch; margin: 0; font: 600 clamp(35px, 5vw, 59px)/.99 var(--display); letter-spacing: -.04em; }
  .workspace-top p { margin: 10px 0 0; color: var(--muted); font-size: 15px; }
  .top-actions { display: grid; gap: 8px; justify-items: end; }
  .top-actions .btn { min-height: 40px; white-space: nowrap; }
  .status-seal { flex: 0 0 auto; padding: 9px 11px; border: 1px solid var(--line-strong); border-radius: 999px; background: var(--panel); color: var(--muted); font: 11px var(--mono); white-space: nowrap; }
  .status-seal strong { color: var(--confirm); font-weight: 600; }
  .hero-room { position: relative; min-height: clamp(250px, 29vw, 370px); overflow: hidden; border-radius: 15px; background: var(--media); color: #fff; }
  .hero-room img { width: 100%; height: 100%; min-height: inherit; position: absolute; inset: 0; object-fit: cover; opacity: .88; }
  .hero-room::after { content: ""; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(9,12,15,.02) 25%, rgba(9,12,15,.76) 100%); }
  .hero-empty { position: absolute; inset: 0; display: grid; place-items: center; color: #b7c1c9; font: 500 14px var(--ui); }
  .hero-caption { position: absolute; z-index: 1; right: 20px; bottom: 18px; left: 20px; display: flex; align-items: end; justify-content: space-between; gap: 14px; }
  .hero-caption h3 { margin: 0; font: 600 clamp(28px, 5vw, 44px)/1 var(--display); }
  .hero-caption p { margin: 6px 0 0; color: rgba(255,255,255,.8); font-size: 13px; }
  .evidence-button { min-height: 40px; padding: 7px 12px; border: 1px solid rgba(255,255,255,.55); border-radius: 7px; background: rgba(10,12,15,.3); color: #fff; cursor: pointer; }
  .evidence-button:hover { background: rgba(10,12,15,.65); }
  .next-action { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 18px; align-items: center; padding: 22px 0; border-bottom: 1px solid var(--line-strong); }
  .next-action h3 { margin: 0; font: 600 22px/1.15 var(--display); }
  .next-action p { margin: 6px 0 0; color: var(--muted); line-height: 1.5; }
  .room-index { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0 22px; margin-top: 20px; }
  .room-line { display: grid; grid-template-columns: 54px minmax(0,1fr) auto; gap: 12px; align-items: center; min-height: 76px; padding: 10px 0; border-bottom: 1px solid var(--line); background: transparent; border-right: 0; border-left: 0; border-top: 0; color: var(--ink); text-align: left; cursor: pointer; }
  .room-line:hover .room-name { color: var(--brass-bright); }
  .room-thumb { width: 54px; height: 54px; overflow: hidden; border-radius: 5px; background: var(--panel-2); }
  .room-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .room-name { font: 600 18px/1.15 var(--display); transition: color .15s; }
  .room-detail { margin-top: 4px; color: var(--muted); font-size: 12.5px; }
  .room-progress { color: var(--brass-bright); font: 11px var(--mono); white-space: nowrap; }
  .claim-view { max-width: 820px; }
  .claim-back { margin: 0 0 16px; padding: 0; border: 0; background: transparent; color: var(--muted); cursor: pointer; font-size: 13px; }
  .claim-back:hover { color: var(--ink); }
  .claim-stage { display: grid; grid-template-columns: minmax(0, 1.1fr) minmax(260px, .9fr); background: var(--media); color: #f6f5f2; }
  .claim-media { min-height: 330px; position: relative; overflow: hidden; background: #151a20; }
  .claim-media img { width: 100%; height: 100%; position: absolute; inset: 0; object-fit: cover; }
  .claim-media button { position: absolute; z-index: 1; right: 13px; bottom: 13px; }
  .claim-copy { display: flex; flex-direction: column; padding: 26px; }
  .claim-copy .field-kicker { color: #d8b873; }
  .claim-copy h2 { margin: 0; font: 600 clamp(29px, 4vw, 42px)/1.05 var(--display); letter-spacing: -.03em; }
  .claim-copy .description { margin: 14px 0; color: #c4ccd1; line-height: 1.55; }
  .claim-copy .source { margin-top: auto; color: #9eacb5; font: 11px var(--mono); }
  .claim-details { display: grid; grid-template-columns: minmax(0, 1fr) minmax(200px, .7fr); gap: 36px; padding: 28px 0; border-bottom: 1px solid var(--line-strong); }
  .claim-details h3 { margin: 0 0 12px; font: 600 18px var(--display); }
  .grade-group { display: flex; flex-wrap: wrap; gap: 7px; }
  .grade-group button { min-height: 38px; padding: 5px 10px; border: 1px solid var(--line-strong); border-radius: 999px; background: var(--panel); color: var(--muted); text-transform: capitalize; cursor: pointer; }
  .grade-group button.selected { color: var(--ink); border-color: var(--brass); background: var(--brass-soft); }
  .defect-list { list-style: none; margin: 0; padding: 0; }
  .defect-list li { padding: 8px 0; border-top: 1px solid var(--line); color: var(--danger); font-size: 13px; line-height: 1.45; }
  .claim-tools { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
  .claim-tools .btn { min-height: 40px; }
  .review-dock { position: sticky; bottom: 0; z-index: 8; display: flex; justify-content: space-between; gap: 12px; margin: 24px -1px 0; padding: 12px 0 calc(12px + env(safe-area-inset-bottom)); background: linear-gradient(0deg, var(--paper) 78%, rgba(246,243,236,0)); }
  .review-dock .btn { min-height: 48px; }
  .review-dock .primary { flex: 1; }
  .finish-sheet { max-width: 730px; }
  .finish-sheet h2 { margin: 0; font: 600 clamp(36px, 5vw, 56px)/1 var(--display); letter-spacing: -.04em; }
  .finish-sheet > p { max-width: 48ch; color: var(--muted); line-height: 1.6; }
  .finish-step { display: grid; grid-template-columns: 34px minmax(0,1fr); gap: 14px; padding: 22px 0; border-top: 1px solid var(--line-strong); }
  .finish-step > b { display: grid; width: 27px; height: 27px; place-items: center; border-radius: 50%; background: var(--brass-soft); color: var(--brass-bright); font: 600 11px var(--mono); }
  .finish-step h3 { margin: 3px 0 5px; font: 600 21px var(--display); }
  .finish-step p { margin: 0 0 13px; color: var(--muted); line-height: 1.5; }
  .finish-field { box-sizing: border-box; width: min(100%, 480px); min-height: 45px; padding: 8px 10px; border: 1px solid var(--line-strong); border-radius: 7px; background: var(--panel); color: var(--ink); }
  .finish-actions { display: flex; flex-wrap: wrap; gap: 8px; }
  .empty-view { padding: 52px 0; text-align: center; color: var(--muted); }
  .build-sheet { position: fixed; z-index: 50; inset: 0; display: none; place-items: center; padding: 20px; background: rgba(14,17,22,.48); backdrop-filter: blur(4px); }
  .build-sheet.show { display: grid; }
  .build-sheet article { width: min(100%, 460px); padding: 28px; border: 1px solid var(--line-strong); border-radius: 14px; background: var(--panel); box-shadow: var(--shadow); }
  .build-sheet h2 { margin: 0; font: 600 29px/1.1 var(--display); }
  .build-sheet p { color: var(--muted); line-height: 1.5; }
  .build-stages { list-style: none; margin: 22px 0 0; padding: 0; }
  .build-stages li { padding: 9px 0 9px 22px; position: relative; color: var(--faint); font-size: 14px; }
  .build-stages li::before { content: ""; position: absolute; top: 14px; left: 1px; width: 9px; height: 9px; border: 1px solid var(--line-strong); border-radius: 50%; }
  .build-stages li.now { color: var(--ink); font-weight: 600; }
  .build-stages li.now::before, .build-stages li.done::before { border-color: var(--brass); background: var(--brass); }

  @media (max-width: 720px) {
    .field-header .desk-only { display: none; }
    .field-main { padding-top: 32px; }
    .new-record h1 { max-width: 12ch; }
    .method-grid, .camera-first, .photo-supplement, .capture-panel, .workspace, .claim-stage, .claim-details { grid-template-columns: 1fr; }
    .method-grid { gap: 9px; }
    .capture-method { min-height: 188px; padding: 17px; }
    .capture-method h2 { margin-top: 25px; }
    .capture-panel { gap: 0; }
    #video-action { order: -1; }
    .workspace-side { position: static; }
    .workspace-side .property-label { display: none; }
    .workspace-nav { display: flex; overflow-x: auto; margin: -12px -20px 28px; padding: 0 20px 8px; border-bottom: 1px solid var(--line); }
    .workspace-nav button { flex: 0 0 auto; width: auto; gap: 9px; }
    .side-footer { display: none; }
    .workspace-top { margin-bottom: 18px; }
    .workspace-top h2 { font-size: 38px; }
    .top-actions .btn { min-height: 38px; }
    .status-seal { padding: 7px 9px; }
    .hero-room { min-height: 330px; margin: 0 -20px; border-radius: 0; }
    .hero-caption { right: 20px; left: 20px; }
    .room-index { grid-template-columns: 1fr; }
    .next-action { grid-template-columns: 1fr; gap: 13px; }
    .next-action .btn { width: 100%; min-height: 48px; }
    .claim-media { min-height: 290px; }
    .claim-copy { padding: 22px 20px; }
    .claim-details { gap: 22px; }
    .review-dock { margin-right: -20px; margin-left: -20px; padding-right: 20px; padding-left: 20px; }
  }
  @media (prefers-reduced-motion: reduce) { .capture-method { transition: none; } }
</style>
</head>
<body id="field-workspace">
<header class="field-header">
  <a class="field-brand" href="{{ route_prefix }}/" aria-label="Home Inventory workspace">
    <span class="field-mark" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 20V9l7-5 7 5v11M9 20v-6h6v6"/></svg></span>
    Home Inventory
  </a>
  <div class="field-header-actions">
    {% if not prebuild %}<a class="btn ghost desk-only" href="{{ route_prefix }}/review">Full evidence desk</a>{% endif %}
    {% if not prebuild %}<a class="btn ghost desk-only" href="{{ route_prefix }}/report">Report</a>{% endif %}
    {% if not prebuild %}<a class="btn ghost" href="{{ route_prefix }}/issue">Final issue</a>{% endif %}
  </div>
</header>

{% if prebuild %}
<main class="field-main">
  {% if show_picker %}
  <section class="new-record" aria-labelledby="record-title">
    <p class="field-kicker">Home Inventory</p>
    <h1 id="record-title">What are you documenting today?</h1>
    <p class="lede">Start one evidence record. You can capture on this phone, review here, or move to a larger screen once the draft is ready.</p>
    <div class="method-grid" id="use-case-picker">
      {% for option in use_cases %}
      <button class="capture-method" type="button" data-use-case="{{ option.key }}">
        <span class="method-no">0{{ loop.index }}</span>
        <h2>{{ option.label }}</h2>
        <p>{{ option.description }}</p>
        <span class="method-tag">{{ option.outcome }}</span>
      </button>
      {% endfor %}
    </div>
    <p id="picker-status" role="status"></p>
  </section>
  {% else %}
  <section class="new-record" aria-labelledby="capture-title">
    <p class="field-kicker">{{ use_case_label }} · capture</p>
    <h1 id="capture-title">Take a walkthrough. We’ll take it from there.</h1>
    <p class="lede">Use your phone’s Camera exactly as you normally would. When you are done, choose the video here and we will keep the original, organise the rooms, draft the record, and bring back only the decisions that need you.</p>

    <section class="camera-first" aria-label="Walkthrough handoff">
      <div id="video-brief">
        <p class="field-kicker">The simple route</p>
        <h2>Film once. Hand it off.</h2>
        <p>No room folders, no capture checklist, and no need to wait around while we process it. Your unedited video remains the source behind every drafted claim.</p>
        <details class="optional-guidance">
          <summary>Want a stronger draft? Three optional filming tips</summary>
          <p>Landscape gives a better wide view. Saying a room name at the doorway and pausing briefly makes room matching easier. For an existing defect, take a moment to hold it in frame. None of these stops you from simply recording as normal.</p>
        </details>
      </div>
      <aside class="capture-action" id="video-action">
        <label>Walkthrough video</label>
        <button class="btn primary" type="button" id="choose-video">Choose video from Camera</button>
        <input id="video-input" type="file" accept="video/*" hidden>
        <p class="capture-note">Already recorded it? Choose it from your library. Large files are sent in resumable pieces so a connection hiccup does not mean starting again.</p>
      </aside>
    </section>

    <section class="photo-supplement" id="photo-brief">
      <div>
        <p class="field-kicker">Only if useful</p>
        <h2>Have one thing the video cannot show clearly?</h2>
        <p>Add a room photo for a meter reading, a small defect, or anything you want to make unmissable. It supplements the same walkthrough; it is not a second process.</p>
      </div>
      <aside class="capture-action" id="photo-action">
        <label for="photo-room">Which room?</label>
        <input id="photo-room" type="text" placeholder="For example, Kitchen" autocomplete="off">
        <button class="btn" type="button" id="choose-photos">Add room photos</button>
        <input id="photo-input" type="file" accept="image/*" capture="environment" multiple hidden>
        <p class="capture-note">We keep the original photo and its capture data alongside the walkthrough.</p>
      </aside>
    </section>

    <section class="evidence-ledger" aria-labelledby="evidence-title">
      <div class="evidence-ledger-head"><h2 id="evidence-title">Evidence collected</h2><span id="evidence-count">Nothing uploaded yet</span></div>
      <div id="upload-list" aria-live="polite"></div>
    </section>
  </section>
  {% endif %}
</main>

{% if not show_picker %}
<div class="field-build-bar">
  <div class="field-build-inner">
    <div class="build-summary"><b id="build-title">Add your first piece of evidence</b><span id="build-note">The draft will be prepared from the originals you keep here.</span></div>
    <button id="build-button" class="btn primary" type="button" disabled>Build the draft</button>
  </div>
</div>
{% endif %}

<div class="build-sheet" id="build-sheet" role="status" aria-live="polite" aria-hidden="true"><article>
  <h2 id="build-sheet-title">Preparing your draft</h2>
  <p id="build-sheet-note">You can keep this page open while the evidence is organised.</p>
  <ol class="build-stages" id="build-stages"></ol>
</article></div>

{% else %}
<main class="field-main">
  <div class="workspace">
    <aside class="workspace-side">
      <div class="property-label"><p class="field-kicker">{{ use_case_label }}</p><h1>{{ inv.property_address or 'Property record' }}</h1><p id="side-progress"></p></div>
      <nav class="workspace-nav" aria-label="Inspection sections">
        <button type="button" data-screen="overview" aria-current="page"><b>Overview</b><span id="nav-rooms"></span></button>
        <button type="button" data-screen="review"><b>Review</b><span id="nav-review"></span></button>
        <button type="button" data-screen="finish"><b>Finish</b><span id="nav-finish"></span></button>
      </nav>
      <p class="side-footer">Every decision is saved back to the evidence record. Need frame-by-frame controls, annotations, or room corrections? <a href="{{ route_prefix }}/review">Open the full evidence desk.</a></p>
    </aside>
    <section class="workspace-main" id="workspace-main" aria-live="polite"></section>
  </div>
</main>
{% endif %}

<div id="toast" role="status"></div>
<script>{% include "_ui.js.j2" %}</script>
<script>
"use strict";
(function () {
  var PREFIX = {{ route_prefix|default('', true)|tojson }};
  var PREBUILD = {{ 'true' if prebuild else 'false' }};
  var INITIAL_SCREEN = {{ initial_screen|default('overview', true)|tojson }};
  var WALKTHROUGH = {{ walkthrough_room|default('__walkthrough__', true)|tojson }};
  var SPEND = {{ spend|default({}, true)|tojson }};
  var CAPTURE = {{ capture|default({}, true)|tojson }};
  var SHARE_URL = {{ share_url|default('', true)|tojson }};
  var el = ui.el, toast = ui.toast;

  function api(method, path, body) {
    return fetch(PREFIX + path, { method: method, headers: { "Content-Type": "application/json" },
      body: body === undefined ? undefined : JSON.stringify(body) })
      .then(function (r) { return r.json().catch(function () { return {}; }).then(function (json) {
        if (!r.ok) throw new Error(json.error || ("Request failed (" + r.status + ")")); return json; }); });
  }
  function escapeText(value) { return String(value == null ? "" : value); }
  function plural(n, word) { return n + " " + word + (n === 1 ? "" : "s"); }
  function fmtBytes(bytes) { if (!bytes) return ""; return bytes > 1e9 ? (bytes / 1e9).toFixed(1) + " GB" : bytes > 1e6 ? (bytes / 1e6).toFixed(1) + " MB" : Math.ceil(bytes / 1e3) + " kB"; }

  if (PREBUILD) {
    var pickerOnly = !document.getElementById("build-button");
    if (pickerOnly) {
      var initialPicker = document.getElementById("use-case-picker");
      if (initialPicker) initialPicker.querySelectorAll("[data-use-case]").forEach(function (button) {
        button.addEventListener("click", function () {
          button.disabled = true;
          api("POST", "/api/project", { use_case: button.getAttribute("data-use-case") })
            .then(function () { location.reload(); })
            .catch(function (error) {
              button.disabled = false;
              document.getElementById("picker-status").textContent = error.message;
            });
        });
      });
      return;
    }
    var activeUploads = 0, uploadedCount = 0;
    var uploadList = document.getElementById("upload-list"), buildButton = document.getElementById("build-button");
    var initialFiles = (CAPTURE.root_files || []).slice();
    var initialRooms = (CAPTURE.rooms || []).slice();
    uploadedCount = initialFiles.length + initialRooms.reduce(function (sum, room) { return sum + room.photos + room.videos; }, 0);

    function updateBuild() {
      var count = uploadedCount;
      document.getElementById("evidence-count").textContent = count ? plural(count, "piece") + " ready for the draft" : "Nothing uploaded yet";
      buildButton.disabled = count === 0 || activeUploads > 0;
      document.getElementById("build-title").textContent = count ? plural(count, "piece") + " of evidence ready" : "Add your first piece of evidence";
      document.getElementById("build-note").textContent = count ? (SPEND.label || "Draft") + " · estimated " + (SPEND.estimate || "cost varies") : "The draft will be prepared from the originals you keep here.";
    }
    function uploadRow(name, type, detail) {
      var row = el("div", { "class": "upload-row" });
      row.appendChild(el("span", { "class": "upload-token", text: type === "video" ? "VID" : "IMG" }));
      var copy = el("div", {}); copy.appendChild(el("div", { "class": "upload-name", text: name })); copy.appendChild(el("div", { "class": "upload-meta", text: detail || "" }));
      var progress = el("div", { "class": "upload-progress" }); var fill = el("span", {}); progress.appendChild(fill); copy.appendChild(progress);
      row.appendChild(copy); row.appendChild(el("span", { "class": "upload-state", text: "Ready" })); uploadList.appendChild(row);
      return { row: row, fill: fill, state: row.querySelector(".upload-state") };
    }
    initialFiles.forEach(function (file) { uploadRow(file.name, file.kind === "walkthrough" ? "video" : "photo", [file.kind, fmtBytes(file.size)].filter(Boolean).join(" · ")); });
    initialRooms.forEach(function (room) { if (room.photos || room.videos) uploadRow(room.name, "photo", [plural(room.photos || 0, "photo"), plural(room.videos || 0, "clip")].join(" · ")); });

    function upload(file, room, type) {
      activeUploads += 1; updateBuild();
      var row = uploadRow(file.name, type, [type === "video" ? "Narrated walkthrough" : room, fmtBytes(file.size)].join(" · "));
      row.state.textContent = "Uploading";
      ui.uploadMedia(PREFIX, file, room, { onProgress: function (loaded, total) { row.fill.style.width = Math.round(100 * loaded / total) + "%"; },
        onDone: function () { activeUploads -= 1; uploadedCount += 1; row.fill.style.width = "100%"; row.state.textContent = "Saved"; row.state.className = "upload-state ok"; updateBuild(); },
        onError: function (message) { activeUploads -= 1; row.state.textContent = message; row.state.className = "upload-state err"; updateBuild(); } }).catch(function () {});
    }
    document.getElementById("choose-video").addEventListener("click", function () { document.getElementById("video-input").click(); });
    document.getElementById("video-input").addEventListener("change", function () { var file = this.files && this.files[0]; if (file) upload(file, WALKTHROUGH, "video"); this.value = ""; });
    document.getElementById("choose-photos").addEventListener("click", function () { var room = (document.getElementById("photo-room").value || "").trim(); if (!room) { toast("Name the room before taking photos"); document.getElementById("photo-room").focus(); return; } document.getElementById("photo-input").click(); });
    document.getElementById("photo-input").addEventListener("change", function () { var room = (document.getElementById("photo-room").value || "").trim(); Array.prototype.forEach.call(this.files || [], function (file) { upload(file, room, "photo"); }); this.value = ""; });

    var stages = ["Checking the originals", "Finding rooms", "Selecting evidence", "Drafting the record", "Preparing review"];
    function showBuild(status) { var sheet = document.getElementById("build-sheet"), list = document.getElementById("build-stages"); sheet.classList.add("show"); sheet.setAttribute("aria-hidden", "false"); list.innerHTML = ""; var current = status && status.stage || "starting"; var map = { starting: 0, segmenting: 1, segmented: 1, extracting: 2, describing: 3, rendering: 4, done: 5 }; var at = map[current] == null ? 0 : map[current]; stages.forEach(function (label, i) { list.appendChild(el("li", { "class": i < at ? "done" : i === at ? "now" : "", text: label })); }); if (status && status.stage_detail) document.getElementById("build-sheet-note").textContent = status.stage_detail; }
    function pollBuild() { api("GET", "/api/build").then(function (status) { showBuild(status); if (status.status === "running") { setTimeout(pollBuild, 1300); } else if (status.status === "done") { document.getElementById("build-sheet-title").textContent = "Your draft is ready"; document.getElementById("build-sheet-note").textContent = "Opening the room-by-room review…"; setTimeout(function () { location.href = PREFIX + "/"; }, 500); } else if (status.status === "failed") { document.getElementById("build-sheet-title").textContent = "The draft could not be prepared"; document.getElementById("build-sheet-note").textContent = status.detail || "Check the uploaded media, then try again."; buildButton.disabled = false; } }).catch(function () {}); }
    buildButton.addEventListener("click", function () { ui.confirmDialog({ title: "Prepare the draft?", message: (SPEND.label || "This build") + " is estimated at " + (SPEND.estimate || "the displayed cost") + ".", note: "The AI creates a draft; you review the evidence and decide what is issued.", confirmLabel: "Prepare draft" }).then(function (confirmed) { if (!confirmed) return; buildButton.disabled = true; api("POST", "/api/build", { confirm: "yes" }).then(pollBuild).catch(function (error) { buildButton.disabled = false; toast(error.message); }); }); });
    updateBuild();
    return;
  }

  var payload = {{ payload|default({}, true)|tojson }};
  var inv = payload.inventory || {};
  var photoSrc = payload.photo_src || {};
  var rooms = inv.rooms || [];
  var screen = "overview", activeRoom = 0, activeItemId = "";
  var root = document.getElementById("workspace-main");
  var CONDITIONS = ["new", "excellent", "good", "fair", "poor"];

  function allItems() { var list = []; rooms.forEach(function (room) { (room.items || []).forEach(function (item) { list.push({ room: room, item: item }); }); }); return list; }
  function done(item) { return !!(item.reviewed || item.rejected); }
  function reviewedCount() { return allItems().filter(function (entry) { return done(entry.item); }).length; }
  function attentionReasons(item) {
    var reasons = [];
    if (item.confidence == null || item.confidence < .8) reasons.push("draft confidence");
    if (!(item.photo_ids || []).length) reasons.push("linked evidence");
    if (!item.condition || !item.cleanliness) reasons.push("condition details");
    if ((item.defects || []).length) reasons.push("a drafted defect");
    if (item.category === "safety") reasons.push("a safety item");
    if (item.category === "meter") reasons.push("a meter reading");
    return reasons;
  }
  function needsAttention(item) { return !done(item) && attentionReasons(item).length > 0; }
  function pending() { return allItems().filter(function (entry) { return needsAttention(entry.item); }).sort(function (a, b) { return (a.item.confidence == null ? 1.1 : a.item.confidence) - (b.item.confidence == null ? 1.1 : b.item.confidence); }); }
  function findItem(id) { return allItems().filter(function (entry) { return entry.item.id === id; })[0] || null; }
  function hero(room) { var pictures = room.photos || []; return pictures.filter(function (photo) { return photo.hero === 1; })[0] || pictures[0] || null; }
  function imageFor(entry) { var ids = entry.item.photo_ids || []; for (var i = 0; i < ids.length; i++) if (photoSrc[ids[i]]) return { id: ids[i], src: photoSrc[ids[i]] }; var fallback = hero(entry.room); return fallback && photoSrc[fallback.id] ? { id: fallback.id, src: photoSrc[fallback.id] } : null; }
  function setNav() { var complete = reviewedCount(), total = allItems().length, remaining = pending().length; document.getElementById("side-progress").textContent = remaining ? plural(remaining, "decision") + " needs you" : "No decisions outstanding"; document.getElementById("nav-rooms").textContent = rooms.length; document.getElementById("nav-review").textContent = remaining; document.getElementById("nav-finish").textContent = inv.signatures && inv.signatures.length ? "ready" : ""; document.querySelectorAll("[data-screen]").forEach(function (button) { button.setAttribute("aria-current", button.getAttribute("data-screen") === screen ? "page" : "false"); }); }
  function save(note) { return api("PUT", "/api/inventory?autosave=1", inv).then(function () { if (note) toast(note); setNav(); }); }
  function openPhotos(room, startId) { var photos = (room.photos || []).filter(function (photo) { return photoSrc[photo.id]; }).map(function (photo) { return { src: photoSrc[photo.id], label: photo.id, title: room.name }; }); var index = Math.max(0, photos.map(function (p) { return p.label; }).indexOf(startId)); ui.photoViewer({ photos: photos, index: index }); }
  function showOverview() {
    var room = rooms[activeRoom] || rooms[0]; if (!room) { root.innerHTML = '<div class="empty-view">No rooms were found in this evidence set.</div>'; return; }
    var cover = hero(room), source = cover && photoSrc[cover.id]; var roomDone = (room.items || []).filter(done).length; var next = pending()[0];
    root.innerHTML = "";
    var top = el("div", { "class": "workspace-top" }); var copy = el("div", {}); copy.appendChild(el("p", { "class": "field-kicker", text: "Inspection overview" })); copy.appendChild(el("h2", { text: inv.property_address || "Your property record" })); copy.appendChild(el("p", { text: "Start with the rooms. Review only the claims that still need your judgement." })); top.appendChild(copy);
    var topActions = el("div", { "class": "top-actions" }); topActions.appendChild(el("div", { "class": "status-seal", text: next ? plural(pending().length, "decision") + " left" : "ready to issue" })); topActions.appendChild(el("button", { "class": "btn primary", type: "button", text: next ? "Review next" : "Finish record", onclick: function () { screen = next ? "review" : "finish"; activeItemId = next ? next.item.id : ""; render(); } })); top.appendChild(topActions); root.appendChild(top);
    var stage = el("section", { "class": "hero-room", "aria-label": room.name + " evidence" }); if (source) stage.appendChild(el("img", { src: source, alt: "Evidence for " + room.name })); else stage.appendChild(el("div", { "class": "hero-empty", text: "No display image was selected for this room" }));
    var caption = el("div", { "class": "hero-caption" }); var captionCopy = el("div", {}); captionCopy.appendChild(el("h3", { text: room.name })); captionCopy.appendChild(el("p", { text: plural(room.items.length, "claim") + " · " + roomDone + " checked" })); caption.appendChild(captionCopy); if (source) caption.appendChild(el("button", { "class": "evidence-button", type: "button", text: "Inspect evidence", onclick: function () { openPhotos(room, cover.id); } })); stage.appendChild(caption); root.appendChild(stage);
    var action = el("section", { "class": "next-action" }); var actionCopy = el("div", {}); actionCopy.appendChild(el("h3", { text: next ? "One claim is ready for a decision" : "No more decisions need your judgement" })); actionCopy.appendChild(el("p", { text: next ? next.item.name + " in " + next.room.name + " · " + attentionReasons(next.item).join(", ") : "Routine claims remain available in the full evidence desk, with their source evidence intact." })); action.appendChild(actionCopy); action.appendChild(el("button", { "class": "btn", type: "button", text: next ? "Open review" : "Finish the record", onclick: function () { screen = next ? "review" : "finish"; activeItemId = next ? next.item.id : ""; render(); } })); root.appendChild(action);
    var index = el("section", { "class": "room-index", "aria-label": "Rooms" }); rooms.forEach(function (candidate, indexNo) { var candidateHero = hero(candidate), candidateSource = candidateHero && photoSrc[candidateHero.id], count = candidate.items.length, checked = candidate.items.filter(done).length; var button = el("button", { "class": "room-line", type: "button" }); var thumb = el("span", { "class": "room-thumb" }); if (candidateSource) thumb.appendChild(el("img", { src: candidateSource, alt: "" })); button.appendChild(thumb); var roomCopy = el("span", {}); roomCopy.appendChild(el("span", { "class": "room-name", text: candidate.name })); roomCopy.appendChild(el("span", { "class": "room-detail", text: plural(count, "claim") + (candidate.summary ? " · " + candidate.summary : "") })); button.appendChild(roomCopy); button.appendChild(el("span", { "class": "room-progress", text: checked + "/" + count })); button.addEventListener("click", function () { activeRoom = indexNo; render(); }); index.appendChild(button); }); root.appendChild(index);
  }
  function showReview() {
    var entry = pending().filter(function (candidate) { return candidate.item.id === activeItemId; })[0] || pending()[0]; if (!entry) { screen = "finish"; render(); return; } activeItemId = entry.item.id; var item = entry.item, image = imageFor(entry); root.innerHTML = ""; var view = el("section", { "class": "claim-view" }); view.appendChild(el("button", { "class": "claim-back", type: "button", text: "← Back to rooms", onclick: function () { screen = "overview"; render(); } }));
    var stage = el("section", { "class": "claim-stage" }); var media = el("div", { "class": "claim-media" }); if (image) { media.appendChild(el("img", { src: image.src, alt: "Evidence for " + item.name })); media.appendChild(el("button", { "class": "evidence-button", type: "button", text: "Inspect", onclick: function () { openPhotos(entry.room, image.id); } })); } else media.appendChild(el("div", { "class": "hero-empty", text: "No linked image" })); stage.appendChild(media);
    var claimCopy = el("div", { "class": "claim-copy" }); claimCopy.appendChild(el("p", { "class": "field-kicker", text: entry.room.name + " · " + item.category })); claimCopy.appendChild(el("h2", { text: item.name })); claimCopy.appendChild(el("p", { "class": "description", text: item.description || "No additional description was drafted." })); claimCopy.appendChild(el("p", { "class": "source", text: image ? "Evidence " + image.id : "No linked evidence" })); claimCopy.appendChild(el("p", { "class": "source", text: "Needs your judgement: " + attentionReasons(item).join(", ") })); stage.appendChild(claimCopy); view.appendChild(stage);
    var details = el("section", { "class": "claim-details" }); var condition = el("div", {}); condition.appendChild(el("h3", { text: "Condition" })); var grades = el("div", { "class": "grade-group" }); CONDITIONS.forEach(function (grade) { grades.appendChild(el("button", { type: "button", "class": item.condition === grade ? "selected" : "", text: grade, onclick: function () { item.condition = grade; save("Condition updated"); render(); } })); }); condition.appendChild(grades); details.appendChild(condition);
    var defects = el("div", {}); defects.appendChild(el("h3", { text: "Defects" })); var list = el("ul", { "class": "defect-list" }); if ((item.defects || []).length) item.defects.forEach(function (defect) { list.appendChild(el("li", { text: defect })); }); else list.appendChild(el("li", { text: "None drafted" })); defects.appendChild(list); details.appendChild(defects); view.appendChild(details);
    var tools = el("div", { "class": "claim-tools" }); tools.appendChild(el("button", { "class": "btn", type: "button", text: "Add defect", onclick: function () { ui.form({ title: "Add a defect", note: "Describe only what this evidence clearly shows.", submitLabel: "Add defect", fields: [{ name: "defect", label: "Defect", required: true, placeholder: "For example, scuff beside the door handle" }] }).then(function (values) { if (!values) return; item.defects = item.defects || []; item.defects.push(values.defect); save("Defect added").then(render); }); } })); tools.appendChild(el("button", { "class": "btn ghost", type: "button", text: "Not visible", onclick: function () { item.not_inspected = "not visible"; item.reviewed = true; save("Marked not visible").then(function () { activeItemId = ""; render(); }); } })); tools.appendChild(el("button", { "class": "btn ghost", type: "button", text: "Reject draft", onclick: function () { ui.confirmDialog({ title: "Reject this drafted item?", message: "The item stays in the audit trail as reviewer rejected.", confirmLabel: "Reject draft", danger: true }).then(function (confirmed) { if (!confirmed) return; item.rejected = true; save("Draft rejected").then(function () { activeItemId = ""; render(); }); }); } })); view.appendChild(tools);
    var dock = el("div", { "class": "review-dock" }); dock.appendChild(el("button", { "class": "btn", type: "button", text: "Skip for now", onclick: function () { var next = pending().filter(function (candidate) { return candidate.item.id !== item.id; })[0]; if (next) { activeItemId = next.item.id; render(); } else { screen = "finish"; render(); } } })); dock.appendChild(el("button", { "class": "btn primary", type: "button", text: "Confirm and continue", onclick: function () { item.reviewed = true; item.rejected = false; save("Claim confirmed").then(function () { var next = pending()[0]; if (next) activeItemId = next.item.id; else screen = "finish"; render(); }); } })); view.appendChild(dock); root.appendChild(view);
  }
  function copyShare() { if (!SHARE_URL) return; if (navigator.clipboard && navigator.clipboard.writeText) navigator.clipboard.writeText(location.origin + SHARE_URL).then(function () { toast("Tenant link copied"); }).catch(function () { toast("Copy the tenant link from the full evidence desk"); }); else toast("Copy the tenant link from the full evidence desk"); }
  function showFinish() {
    var remaining = pending().length;
    root.innerHTML = ""; var finish = el("section", { "class": "finish-sheet" }); finish.appendChild(el("p", { "class": "field-kicker", text: "Issue the record" })); finish.appendChild(el("h2", { text: "Close the file calmly." })); finish.appendChild(el("p", { text: "A signature locks the content you have reviewed. The tenant then gets the same evidence record to inspect, comment on, and countersign." }));
    var property = el("section", { "class": "finish-step" }); property.appendChild(el("b", { text: "01" })); var propertyCopy = el("div", {}); propertyCopy.appendChild(el("h3", { text: "Name the property" })); propertyCopy.appendChild(el("p", { text: "This is required on the issued record." })); var address = el("input", { "class": "finish-field", type: "text", placeholder: "Property address", value: inv.property_address || "" }); address.addEventListener("change", function () { inv.property_address = address.value.trim(); save("Property details saved"); }); propertyCopy.appendChild(address); property.appendChild(propertyCopy); finish.appendChild(property);
    var review = el("section", { "class": "finish-step" }); review.appendChild(el("b", { text: "02" })); var reviewCopy = el("div", {}); reviewCopy.appendChild(el("h3", { text: "Review completeness" })); reviewCopy.appendChild(el("p", { text: remaining ? plural(remaining, "decision") + " still needs your judgement. You can issue with a deliberate review warning, but it remains visible in the record." : "No more decisions need your judgement. Routine claims remain available in the full evidence desk, with their source evidence intact." })); reviewCopy.appendChild(el("button", { "class": "btn", type: "button", text: remaining ? "Return to review" : "Open full evidence desk", onclick: function () { if (remaining) { screen = "review"; render(); } else { location.href = PREFIX + "/review"; } } })); review.appendChild(reviewCopy); finish.appendChild(review);
    var sign = el("section", { "class": "finish-step" });
    sign.appendChild(el("b", { text: "03" }));
    var signCopy = el("div", {});
    signCopy.appendChild(el("h3", { text: "Sign and share" }));
    signCopy.appendChild(el("p", { text: inv.signatures && inv.signatures.length ? "A signed version is on file. You may now send the tenant their review link." : "Sign the current version once the property address is complete." }));
    var actions = el("div", { "class": "finish-actions" });
    var signButton = el("button", { "class": "btn primary", type: "button", text: "Sign this version" });
    signButton.addEventListener("click", function () {
      ui.form({ title: "Sign this record", note: "Your signature pins the exact content of this version.", submitLabel: "Sign record", fields: [{ name: "name", label: "Your name", required: true }] }).then(function (values) {
        if (!values) return;
        api("POST", "/api/sign", { name: values.name, role: "landlord" })
          .then(function () { return api("GET", "/api/inventory"); })
          .then(function (fresh) { inv = fresh.inventory; rooms = inv.rooms || []; toast("Record signed"); render(); })
          .catch(function (error) { toast(error.message); });
      });
    });
    actions.appendChild(signButton);
    if (SHARE_URL) actions.appendChild(el("button", { "class": "btn", type: "button", text: "Copy tenant link", onclick: copyShare }));
    actions.appendChild(el("a", { "class": "btn ghost", href: PREFIX + "/issue", text: "Open final issue" }));
    signCopy.appendChild(actions); sign.appendChild(signCopy); finish.appendChild(sign); root.appendChild(finish);
  }
  function render() { setNav(); if (screen === "overview") showOverview(); else if (screen === "review") showReview(); else showFinish(); var hash = screen === "overview" ? "" : "#" + screen; if (location.hash !== hash) history.replaceState(null, "", location.pathname + location.search + hash); }
  document.querySelectorAll("[data-screen]").forEach(function (button) { button.addEventListener("click", function () { screen = button.getAttribute("data-screen"); render(); }); });
  if (INITIAL_SCREEN === "finish") screen = "finish";
  if (location.hash === "#review") screen = "review"; else if (location.hash === "#finish") screen = "finish";
  render();
})();
</script>
</body>
</html>
