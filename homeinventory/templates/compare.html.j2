<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ result.comparison.title }} — {{ result.checkin.address or "Property" }}</title>
<style>
{% include "_theme.css.j2" %}
{% for cls, tone in class_tones.items() %}
  .cls.{{ cls }} { color: var(--{{ tone }}); }
{% endfor %}
</style>
</head>
<body>
<main>
  <div class="kicker">{{ labels.baseline }} vs {{ labels.followup }} comparison</div>
  <h1>{{ result.checkin.address or "Property" }}</h1>
  <p class="meta">
    {{ labels.baseline }}: {{ result.checkin.inspected_at }} ({{ result.checkin.backend or "?" }})
    &middot; {{ labels.followup }}: {{ result.checkout.inspected_at }} ({{ result.checkout.backend or "?" }})<br>
    {% for param in context_params -%}
    {{ param.label }}: {{ result.params.context.get(param.key) or "not provided" }}{% if not loop.last %} &middot; {% endif %}
    {%- endfor %}
    &middot; Classification: {{ result.params.backend }}{{ " (" ~ result.params.model ~ ")" if result.params.model else "" }}
  </p>
  <p class="note">{{ result.comparison.intro_note }}
  Classifications marked “unclassified” mean no rubric ran (offline) or the
  rubric failed — review by hand.</p>

  <h2>1. Grade-delta summary</h2>
  <p class="meta">{{ result.totals.matched }} items matched
    ({{ result.totals.changed }} changed, {{ result.totals.unchanged }} unchanged)
    &middot; {{ result.totals.removed }} not located at {{ labels.followup | lower }}
    &middot; {{ result.totals.added }} new at {{ labels.followup | lower }}</p>
  <table class="delta">
    <thead><tr>
      <th>Item</th><th>Room</th><th>{{ labels.baseline }}</th><th>{{ labels.followup }}</th>
      <th>Δ</th><th>Classification</th><th>Evidence</th>
    </tr></thead>
    <tbody>
    {% for room in rooms %}{% for c in room.changed %}
      <tr>
        <td>{{ c.name }}{% if c.checkin_name != c.name %}
            <div class="meta">{{ labels.baseline | lower }}: “{{ c.checkin_name }}”</div>{% endif %}
          {% if c.new_defects %}<ul class="defects">
            {% for d in c.new_defects %}<li>{{ d }}</li>{% endfor %}
          </ul>{% endif %}
        </td>
        <td>{{ room.name }}</td>
        <td class="grade">{{ c.checkin_condition or "—" }}</td>
        <td class="grade">{{ c.checkout_condition or "—" }}</td>
        <td class="{{ 'worse' if c.grade_delta and c.grade_delta > 0 else 'better' if c.grade_delta and c.grade_delta < 0 else '' }}">
          {%- if c.grade_delta is none %}—
          {%- elif c.grade_delta > 0 %}▼{{ c.grade_delta }}
          {%- elif c.grade_delta < 0 %}▲{{ -c.grade_delta }}
          {%- else %}0{% endif %}</td>
        <td><span class="cls {{ c.classification or 'unclassified' }}">
            {{ class_labels.get(c.classification or "unclassified") }}</span></td>
        <td class="meta">{{ labels.baseline | lower }}: {{ c.checkin_photo_ids | join(", ") or "—" }}<br>
            {{ labels.followup | lower }}: {{ c.checkout_photo_ids | join(", ") or "—" }}</td>
      </tr>
    {% endfor %}{% endfor %}
    {% if not result.totals.changed %}
      <tr><td colspan="7" class="meta">No gated changes found on matched items.</td></tr>
    {% endif %}
    </tbody>
  </table>

  <h2>2. Paired photo evidence</h2>
  {% for room in rooms %}{% for c in room.changed %}
  <h3>{{ room.name }} — {{ c.name }}
    <span class="cls {{ c.classification or 'unclassified' }}">
      {{ class_labels.get(c.classification or "unclassified") }}</span></h3>
  <div class="pair">
    {% for side_label, photos, cond, defects in [
        (labels.baseline, c.checkin_photos, c.checkin_condition, c.checkin_defects),
        (labels.followup, c.checkout_photos, c.checkout_condition, c.checkout_defects)] %}
    <div class="side">
      <h4>{{ side_label }} — <span class="grade">{{ cond or "not graded" }}</span></h4>
      {% if defects %}<ul class="defects">
        {% for d in defects %}<li>{{ d }}</li>{% endfor %}</ul>{% endif %}
      <div class="photos">
        {% for p in photos %}
        {% if p.src %}
        <figure>
          <div class="frame">
            <img src="{{ p.src }}" alt="{{ p.id }}">
            {% for reg in p.regions %}
            <span class="region" data-label="{{ reg.defect }}"
                  style="left:{{ '%.2f' | format(reg.x * 100) }}%;top:{{ '%.2f' | format(reg.y * 100) }}%;width:{{ '%.2f' | format(reg.w * 100) }}%;height:{{ '%.2f' | format(reg.h * 100) }}%;"></span>
            {% endfor %}
          </div>
          <figcaption>{{ p.id }}{% if p.captured_at %} &middot; {{ p.captured_at }}{% endif %}</figcaption>
        </figure>
        {% else %}
        <div class="missing">{{ p.id }}: photo file not available</div>
        {% endif %}
        {% endfor %}
        {% if not photos %}<div class="missing">no photo evidence cited</div>{% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
  {% if c.rationale %}
  <p class="rationale"><span class="who">Rubric rationale</span> — {{ c.rationale }}</p>
  {% endif %}
  {% if c.resolved_defects %}
  <p class="meta">{{ labels.baseline }} defects not re-observed at {{ labels.followup | lower }}:
    {{ c.resolved_defects | join("; ") }}</p>
  {% endif %}
  {% endfor %}{% endfor %}
  {% if not result.totals.changed %}<p class="meta">Nothing to show.</p>{% endif %}

  <h2>3. Items not located at {{ labels.followup | lower }}</h2>
  {% if result.totals.removed %}
  <table class="delta">
    <thead><tr><th>Item</th><th>Room</th><th>{{ labels.baseline }} condition</th>
      <th>{{ labels.baseline }} defects</th><th>{{ labels.baseline }} evidence</th></tr></thead>
    <tbody>
    {% for room in rooms %}{% for it in room.removed %}
      <tr><td>{{ it.name }}</td><td>{{ room.name }}</td>
          <td class="grade">{{ it.condition or "—" }}</td>
          <td>{{ it.defects | join("; ") or "—" }}</td>
          <td class="meta">{{ it.photo_ids | join(", ") }}</td></tr>
    {% endfor %}{% endfor %}
    </tbody>
  </table>
  <p class="meta">“Not located” is an alignment verdict, not a liability
  verdict: confirm each before treating it as a loss.</p>
  {% else %}<p class="meta">None — every {{ labels.baseline | lower }} item was matched.</p>{% endif %}

  <h2>4. Items new at {{ labels.followup | lower }}</h2>
  {% if result.totals.added %}
  <table class="delta">
    <thead><tr><th>Item</th><th>Room</th><th>{{ labels.followup }} condition</th>
      <th>{{ labels.followup }} defects</th><th>{{ labels.followup }} evidence</th></tr></thead>
    <tbody>
    {% for room in rooms %}{% for it in room.added %}
      <tr><td>{{ it.name }}</td><td>{{ room.name }}</td>
          <td class="grade">{{ it.condition or "—" }}</td>
          <td>{{ it.defects | join("; ") or "—" }}</td>
          <td class="meta">{{ it.photo_ids | join(", ") }}</td></tr>
    {% endfor %}{% endfor %}
    </tbody>
  </table>
  {% else %}<p class="meta">None.</p>{% endif %}

  <footer class="meta" style="margin-top:36px; text-align:center;">
    homeinventory compare &middot; alignment is lexical (room + head-noun
    match, no API calls) &middot; classifications are AI-suggested and
    require human review before any deduction discussion.
  </footer>
</main>
</body>
</html>
