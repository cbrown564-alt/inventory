    function doSign() {
      flush({ manual: true }).then(function () {
        return api("POST", "/api/sign", { name: name, role: role });
      }).then(function () {
        toast("Signed — the signature pins the saved inventory hash");
        return reload();
      }).then(function () { showFinish(true); })
      .catch(function (e) {
