<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ inv.report_type }} — {{ inv.property_address or "Property" }}</title>
<style>
  :root {
    --ink: #1a1a1a; --muted: #5a5f6a; --rule: #d8dbe0; --accent: #15406b;
    --band: #f3f5f8; --paper: #ffffff;
    /* review instrument palette */
    --confirm: #0e6b46; --confirm-soft: #e7f3ed;
    --reject: #a3231f; --reject-soft: #f9ecec;
    --pend: #8a6d1f; --pend-soft: #faf4e3;
    --ui: "Segoe UI Variable Text", "Segoe UI", "Avenir Next", "Helvetica Neue", sans-serif;
    --mono: "Cascadia Code", "JetBrains Mono", Consolas, monospace;
  }
  * { box-sizing: border-box; }
  body {
    font-family: Georgia, "Times New Roman", serif;
    color: var(--ink); margin: 0; font-size: 11pt; line-height: 1.45;
    background: var(--paper);
  }
  main { max-width: 820px; margin: 0 auto; padding: 24px; }
  h1, h2, h3 { font-weight: 600; color: var(--accent); }
  .cover {
    text-align: center; padding: 120px 24px 60px; page-break-after: always;
  }
  .cover h1 { font-size: 26pt; margin-bottom: 4px; }
  .cover .addr { font-size: 16pt; margin: 18px 0 40px; }
  .cover table { margin: 0 auto; border-collapse: collapse; font-size: 11pt; }
  .cover td { padding: 5px 14px; text-align: left; }
  .cover td:first-child { color: var(--muted); }
  .kicker { letter-spacing: .22em; text-transform: uppercase; font-size: 9pt;
            color: var(--muted); }
  section.room { page-break-before: always; }
  h2 { font-size: 15pt; border-bottom: 2px solid var(--accent);
       padding-bottom: 4px; margin-top: 28px; }
  .summary { background: var(--band); padding: 10px 14px; border-left: 3px solid
             var(--accent); margin: 12px 0 18px; }
  table.items { width: 100%; border-collapse: collapse; font-size: 9.5pt; }
  table.items th {
    text-align: left; background: var(--accent); color: #fff; padding: 6px 8px;
    font-weight: 600;
  }
  table.items td { border-bottom: 1px solid var(--rule); padding: 6px 8px;
                   vertical-align: top; }
  table.items tr { page-break-inside: avoid; }
  .grade { white-space: nowrap; font-variant: small-caps; }
  .grade.poor { color: #a3231f; font-weight: 700; }
  .grade.fair { color: #9a6200; }
  .defects { color: var(--reject); }
  .defects li { margin: 0; }
  ul { margin: 2px 0 2px 16px; padding: 0; }
  .photos { display: flex; flex-wrap: wrap; gap: 8px; margin: 14px 0; }
  .photos figure { margin: 0; width: 31%; page-break-inside: avoid; }
  .photos .frame { position: relative; }
  .photos img { width: 100%; height: 150px; object-fit: cover; display: block;
                border: 1px solid var(--rule); }
  .photos figcaption { font-size: 8pt; color: var(--muted);
                       font-family: var(--mono); }
  .region { position: absolute; border: 2px solid var(--reject);
            background: rgba(163,35,31,.08); pointer-events: none; }
  .region::after {
    content: attr(data-label); position: absolute; left: -2px; bottom: 100%;
    background: var(--reject); color: #fff; font-family: var(--ui);
    font-size: 7.5pt; padding: 1px 5px; white-space: nowrap; max-width: 220px;
    overflow: hidden; text-overflow: ellipsis;
  }
  .meta { color: var(--muted); font-size: 9pt; }
  .appendix table { width: 100%; border-collapse: collapse; font-size: 8pt;
                    font-family: var(--mono); }
  .appendix td, .appendix th { border-bottom: 1px solid var(--rule);
                               padding: 3px 6px; text-align: left; }
  .declaration { border: 1px solid var(--rule); padding: 16px; margin-top: 24px; }
  .sigline { display: inline-block; width: 250px; border-bottom: 1px solid
             var(--ink); margin: 28px 16px 4px 0; }
  .sigcard { border-left: 3px solid var(--confirm); background: var(--confirm-soft);
             padding: 8px 12px; margin: 10px 0; font-size: 9.5pt; }
  .sigcard .hash { font-family: var(--mono); font-size: 7.5pt;
                   color: var(--muted); word-break: break-all; }
  footer { color: var(--muted); font-size: 8pt; text-align: center;
           margin-top: 40px; }

  /* ---------- PDF / clerk layout (WeasyPrint) ---------- */
  .print-only { display: none; }
  .screen-only { }
  .page-break { page-break-before: always; }
  .cover-logo { max-height: 52px; margin: 0 auto 20px; display: block; }
  .agent-name { font: 600 11pt var(--ui); letter-spacing: .08em;
                text-transform: uppercase; color: var(--accent); margin-bottom: 8px; }
  .property-type { font-size: 12pt; color: var(--muted); margin: 8px 0 24px; }
  .toc-list { list-style: none; padding: 0; margin: 16px 0; }
  .toc-list li { display: flex; justify-content: space-between; gap: 12px;
                 border-bottom: 1px dotted var(--rule); padding: 5px 0; font-size: 10pt; }
  .toc-list a { color: var(--ink); text-decoration: none; flex: 1; }
  .category-row td { background: var(--band); font: 600 9pt var(--ui);
                     text-transform: uppercase; letter-spacing: .06em; padding: 7px 8px; }
  .cond-merged { white-space: pre-line; line-height: 1.35; }
  .photo-sheet { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin: 14px 0; }
  .photo-sheet figure { margin: 0; page-break-inside: avoid; }
  .photo-sheet img { width: 100%; height: auto; max-height: 170px; object-fit: contain;
                     border: 1px solid var(--rule); display: block; background: #fff; }
  .photo-sheet figcaption { font: 8pt var(--ui); text-align: center; margin-top: 3px; }
  .photo-sheet .ref-tag { font-weight: 600; }
  .initials-note { font-size: 9pt; color: var(--muted); margin-top: 18px; }
  .pdf-brand { font: 7.5pt var(--ui); color: var(--muted); text-align: center; }

  @page {
    size: A4;
    margin: 16mm 14mm 22mm 14mm;
    @bottom-center {
      content: "Page " counter(page) " of " counter(pages);
      font: 8pt var(--ui); color: #5a5f6a;
    }
    @bottom-right {
      {% if uc.initials_note %}
      content: "Tenant initials: __________";
      {% else %}
      content: none;
      {% endif %}
      font: 8pt var(--ui); color: #5a5f6a;
    }
  }
  @page :first {
    margin: 0;
    @bottom-center { content: none; }
    @bottom-right { content: none; }
  }

  @media print {
    body { font-size: 10pt; }
    main { max-width: none; padding: 0; }
    .cover { min-height: 297mm; padding: 90px 24px 60px; }
    .screen-only, .review-flag, tr.comment-row, footer .tool-meta,
    tr.item-rejected, #docket, #toast, tr.rv-evidence { display: none !important; }
    .print-only { display: block !important; }
    table.items { font-family: var(--ui); font-size: 9pt; }
    table.items th { background: #e8ebf0; color: var(--ink); border: 1px solid var(--rule); }
    table.items td { border: 1px solid var(--rule); }
    h2 { font-family: var(--ui); font-size: 13pt; border-bottom: 1px solid var(--ink); }
    .photos.screen-only { display: none !important; }
    .photo-sheet { page-break-inside: auto; }
    .photo-sheet .sheet-break { page-break-after: always; }
    footer.doc-footer { margin-top: 24px; }
    .toc-list a::after {
      content: leader(".") target-counter(attr(href url), page);
      color: var(--muted);
    }
  }

  /* ---------- static review-state rendering ---------- */
  tr.item-rejected td, tr.item-rejected .defects { color: var(--muted); }
  tr.item-rejected td.name-cell .item-name { text-decoration: line-through; }
  .review-flag { display: inline-block; font-family: var(--ui); font-size: 7.5pt;
                 letter-spacing: .08em; text-transform: uppercase;
                 padding: 1px 6px; border-radius: 2px; vertical-align: 1px; }
  .review-flag.ok { color: var(--confirm); background: var(--confirm-soft); }
  .review-flag.no { color: var(--reject); background: var(--reject-soft); }
  .review-flag.pending { color: var(--pend); background: var(--pend-soft); }
  .defects li.struck { text-decoration: line-through; color: var(--muted); }
  .defects li.struck::after { content: " — reviewer rejected"; font-size: 8pt;
                              text-decoration: none; font-style: italic; }
  tr.comment-row td { background: var(--band); font-size: 9pt; padding: 5px 10px; }
  tr.comment-row .who { font-family: var(--ui); font-weight: 600;
                        font-size: 8pt; color: var(--accent); }
  .ref-mono { font-family: var(--mono); font-size: 8.5pt; }

  /* ---------- the review docket (JS-revealed instrument layer) ---------- */
  #docket {
    display: none; position: fixed; left: 0; right: 0; bottom: 0; z-index: 40;
    font-family: var(--ui); font-size: 13px; color: #20242b;
    background: #fcfcfb; border-top: 1px solid #c9cdd4;
    box-shadow: 0 -8px 24px -16px rgba(21, 64, 107, .45);
  }
  #docket.on { display: block; }
  #docket .bar { max-width: 1240px; margin: 0 auto; padding: 9px 18px;
                 display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
  #docket .brand { letter-spacing: .18em; text-transform: uppercase;
                   font-size: 10px; color: var(--accent); font-weight: 600; }
  #progress { flex: 1 1 180px; min-width: 140px; }
  #progress .track { height: 4px; background: #e3e6ea; border-radius: 2px;
                     overflow: hidden; margin-top: 4px; }
  #progress .fill { height: 100%; width: 0; background: var(--confirm);
                    transition: width .35s cubic-bezier(.16,1,.3,1); }
  #progress .label { font-size: 11px; color: var(--muted);
                     font-variant-numeric: tabular-nums; }
  .dk-btn {
    font: 600 12px var(--ui); color: #20242b; background: #fff;
    border: 1px solid #c9cdd4; border-radius: 3px; padding: 6px 12px;
    cursor: pointer; transition: border-color .15s, background .15s;
  }
  .dk-btn:hover { border-color: var(--accent); }
  .dk-btn:active { transform: translateY(1px); }
  .dk-btn.primary { background: var(--accent); border-color: var(--accent);
                    color: #fff; }
  .dk-btn.primary:hover { background: #0f3257; }
  .dk-btn[aria-pressed="true"] { background: var(--accent); color: #fff;
                                 border-color: var(--accent); }
  #dirty-dot { width: 8px; height: 8px; border-radius: 50%;
               background: transparent; }
  #dirty-dot.dirty { background: var(--pend); }
  .kbd-hint { font-size: 10px; color: var(--muted); }
  @media (max-width: 1100px) { #docket .kbd-hint { display: none; } }
  .kbd-hint kbd { font-family: var(--mono); background: #eef0f3;
                  border: 1px solid #d4d8de; border-radius: 2px;
                  padding: 0 4px; font-size: 10px; }

  /* ---------- in-place review controls ---------- */
  body.reviewing main { padding-bottom: 96px; }
  body.reviewing tr.item-row { cursor: pointer; }
  body.reviewing tr.item-row.active td { background: #f6f9fc;
      border-top: 1px solid var(--accent); border-bottom: 1px solid var(--accent); }
  body.reviewing tr.item-row.pending-mark td:first-child {
      box-shadow: inset 3px 0 0 var(--pend); }
  body.reviewing tr.item-row.done-mark td:first-child {
      box-shadow: inset 3px 0 0 var(--confirm); }
  body.reviewing tr.item-row.reject-mark td:first-child {
      box-shadow: inset 3px 0 0 var(--reject); }
  .rv-select { font: 12px var(--ui); padding: 2px 4px; border: 1px solid #c9cdd4;
               border-radius: 3px; background: #fff; max-width: 100%; }
  .rv-edit[contenteditable="true"] { outline: 1px dashed #b7bdc6;
      outline-offset: 2px; min-width: 40px; display: inline-block; }
  .rv-edit[contenteditable="true"]:focus { outline: 1.5px solid var(--accent); }
  .chip {
    display: inline-flex; align-items: center; gap: 5px; margin: 1px 3px 1px 0;
    font: 12px var(--ui); color: var(--reject); background: var(--reject-soft);
    border: 1px solid #e4c6c5; border-radius: 999px; padding: 1px 8px;
    cursor: pointer; user-select: none;
  }
  .chip:active { transform: scale(.97); }
  .chip.struck { color: var(--muted); background: #f1f2f4;
                 border-color: #d8dbe0; text-decoration: line-through; }
  .chip .x { font-size: 10px; opacity: .65; }
  .chip-add { background: #fff; color: var(--muted); border-style: dashed;
              text-decoration: none; }
  tr.rv-evidence td {
    background: #f8f9fa; border-bottom: 2px solid var(--accent);
    padding: 10px 12px;
  }
  .rv-actions { display: flex; gap: 8px; align-items: center; flex-wrap: wrap;
                font-family: var(--ui); margin-bottom: 8px; }
  .rv-actions .spacer { flex: 1; }
  .ev-strip { display: flex; gap: 8px; flex-wrap: wrap; }
  .ev-strip a { display: block; position: relative; }
  .ev-strip img { height: 96px; width: auto; border: 1px solid var(--rule);
                  display: block; }
  .ev-strip .pid { position: absolute; left: 0; bottom: 0; background:
                   rgba(26,26,26,.78); color: #fff; font: 9px var(--mono);
                   padding: 1px 5px; }
  .ev-none { font: italic 12px var(--ui); color: var(--muted); }
  .rv-comments { margin-top: 8px; font-family: var(--ui); font-size: 12px; }
  .rv-comments .c { padding: 3px 0; border-top: 1px dotted var(--rule); }
  .rv-comments .who { font-weight: 600; color: var(--accent); font-size: 11px; }
  .rv-comment-box { display: flex; gap: 6px; margin-top: 6px; }
  .rv-comment-box input { flex: 1; font: 12px var(--ui); padding: 5px 8px;
                          border: 1px solid #c9cdd4; border-radius: 3px; }
  @keyframes ev-flash {
    0% { outline: 4px solid var(--accent); outline-offset: 3px; }
    100% { outline: 4px solid transparent; outline-offset: 3px; }
  }
  .flash { animation: ev-flash 1.6s ease-out 2; }
  #toast {
    position: fixed; bottom: 76px; left: 50%; transform: translateX(-50%) translateY(8px);
    background: #20242b; color: #fff; font: 13px var(--ui); padding: 8px 16px;
    border-radius: 4px; opacity: 0; pointer-events: none;
    transition: opacity .25s, transform .25s; z-index: 50;
  }
  #toast.show { opacity: .96; transform: translateX(-50%) translateY(0); }

  @media print {
    .photos img { height: 130px; }
    #docket, #toast, tr.rv-evidence { display: none !important; }
    body.reviewing main { padding-bottom: 0; }
  }
</style>
</head>
<body>
<div class="cover">
  {% if inv.agent_name %}<div class="agent-name">{{ inv.agent_name }}</div>{% endif %}
  <div class="kicker">{{ uc.report_kicker }}</div>
  <h1>{{ inv.report_type }}</h1>
  <div class="addr">{{ inv.property_address or "Address not specified" }}</div>
  {% if inv.property_type %}<div class="property-type">{{ inv.property_type }}</div>{% endif %}
  <table>
    <tr><td>Date of inspection</td><td><strong>{{ inv.inspected_at }}</strong></td></tr>
    <tr><td>Prepared by</td><td><strong>{{ inv.inspected_by or "—" }}</strong></td></tr>
    {% for row in cover_rows %}
    <tr><td>{{ row.label }}</td><td><strong>{{ row.value }}</strong></td></tr>
    {% endfor %}
    <tr><td>Rooms inspected</td><td><strong>{{ inv.rooms | length }}</strong></td></tr>
    <tr><td>Items recorded</td><td><strong>{{ total_items }}</strong></td></tr>
    <tr><td>Photographs</td><td><strong>{{ total_photos }}</strong></td></tr>
    {% if reviewed_items %}
    <tr class="screen-only"><td>Human-reviewed</td><td><strong>{{ reviewed_items }} of {{ total_items }} items</strong></td></tr>
    {% endif %}
  </table>
</div>

<section class="toc page-break">
  <h2>Contents</h2>
  <ol class="toc-list">
    {% if uc.summary_section_title %}
    <li><span>1. {{ uc.summary_section_title }}</span></li>
    {% endif %}
    {% for section in room_sections %}
    <li><a href="#room-{{ section.number }}">{{ section.number }}. {{ section.name }}</a></li>
    {% endfor %}
    <li><span>Appendix A — Photographic evidence manifest</span></li>
    <li><span>Appendix B — Room photographs</span></li>
    <li><span>Declaration</span></li>
  </ol>
</section>

<main>
<h2>Contents &amp; condition key</h2>
<p><strong>Condition:</strong> New &middot; Excellent &middot; Good (sound, light wear)
&middot; Fair (visible wear or marks) &middot; Poor (damaged or heavily worn).
Items the inspection could not assess are marked <em>not tested</em> or
<em>not visible</em>.<br>
<strong>Cleanliness:</strong> Professionally cleaned &middot; Cleaned to domestic
standard &middot; Requires cleaning.</p>
<p>This report records the contents and internal condition of the property at the
date of inspection, supported by the embedded photographs. Original image files are
identified by SHA-256 checksum in Appendix A; any party holding the original files
can re-compute the checksums to confirm the photographic record is unaltered.
AI-drafted entries that the reviewer rejected remain visible, struck through,
rather than silently deleted.</p>
{% if inv.notes %}<p class="summary">{{ inv.notes }}</p>{% endif %}

{% if uc.summary_section_title %}
<section class="schedule-summary page-break" id="schedule">
  <h2>1. {{ uc.summary_section_title }}</h2>
  <table class="items">
    <thead><tr><th style="width:9%">Ref</th><th style="width:28%">Name</th><th>Condition</th></tr></thead>
    <tbody>
    {% for row in schedule_summary %}
      <tr><td class="ref-mono">{{ row.ref }}</td><td>{{ row.name }}</td>
          <td class="cond-merged">{{ row.condition }}</td></tr>
    {% endfor %}
    </tbody>
  </table>
</section>
{% endif %}

{% for section in room_sections %}
<section class="room" id="room-{{ section.number }}" data-room="{{ section.name }}">
  <h2>{{ section.number }}. {{ section.name }}</h2>
  {% if section.summary %}<div class="summary">{{ section.summary }}</div>{% endif %}

  <table class="items">
    <thead>
      <tr><th style="width:9%">Ref</th><th style="width:18%">Item</th>
          <th>Description</th><th style="width:22%">Condition</th>
          <th class="screen-only" style="width:13%">Cleanliness</th>
          <th class="screen-only" style="width:18%">Defects noted</th>
          <th class="screen-only" style="width:8%">Photos</th></tr>
    </thead>
    <tbody>
    {% for group in section.groups %}
      {% if group.heading %}
      <tr class="category-row"><td colspan="7"><strong>{{ group.heading }}</strong></td></tr>
      {% endif %}
      {% for row in group.rows %}
      {% set item = row.item %}
      <tr class="item-row{% if item.rejected %} item-rejected{% endif %}"
          data-item-id="{{ item.id }}" data-ref="{{ row.ref }}" data-room="{{ section.name }}">
        <td class="ref-cell"><span class="ref-mono">{{ row.ref }}</span>
          <span class="screen-only ref-internal ref-mono">{{ item.id }}</span>
          {% if item.rejected %}<br><span class="review-flag no">rejected</span>
          {% elif item.reviewed %}<br><span class="review-flag ok">reviewed</span>
          {% elif reviewed_items %}<br><span class="review-flag pending">unreviewed</span>{% endif %}
          {% if item.added_by %}<br><span class="meta">added by {{ item.added_by }}</span>{% endif %}
        </td>
        <td class="name-cell"><strong class="item-name">{{ item.name }}</strong>{% if item.quantity > 1 %} &times;{{ item.quantity }}{% endif %}
          {% if item.rejected %}<br><span class="meta">AI suggested — reviewer rejected</span>{% endif %}
        </td>
        <td class="desc-cell">{{ item.description }}</td>
        <td class="cond-cell grade {{ item.condition or '' }}">
          <span class="screen-only">{{ item.not_inspected or item.condition or "—" }}</span>
          <span class="print-only cond-merged">{{ row.condition_text }}</span>
        </td>
        <td class="clean-cell screen-only grade">{{ item.cleanliness or "—" }}</td>
        <td class="def-cell screen-only">
          {% if item.defects or item.rejected_defects %}<ul class="defects">
            {% for d in item.defects %}<li>{{ d }}</li>{% endfor %}
            {% for d in item.rejected_defects %}<li class="struck">{{ d }}</li>{% endfor %}
          </ul>{% else %}<span class="meta">None noted</span>{% endif %}
        </td>
        <td class="photo-cell screen-only meta ref-mono">{{ item.photo_ids | join(", ") }}</td>
      </tr>
      {% for c in item.comments %}
      <tr class="comment-row screen-only" data-for="{{ item.id }}">
        <td></td><td colspan="6"><span class="who">{{ c.author or "?" }}
          ({{ c.role or "reviewer" }}{% if c.at %}, {{ c.at[:10] }}{% endif %}):</span>
          {{ c.text }}</td>
      </tr>
      {% endfor %}
      {% endfor %}
    {% endfor %}
    </tbody>
  </table>

  {% if section.photos %}
  <h3 class="screen-only">Photographs — {{ section.name }}</h3>
  <div class="photos screen-only">
    {% for photo in section.photos %}
    <figure id="photo-{{ photo.id }}" data-photo-id="{{ photo.id }}">
      <div class="frame">
        <img src="{{ photo_src[photo.id] }}" alt="{{ photo.id }}" loading="lazy">
        {% for group in section.groups %}{% for row in group.rows %}{% set it = row.item %}{% for reg in it.defect_regions %}
          {% if reg.photo_id == photo.id %}
          <span class="region" data-label="{{ it.id }} · {{ reg.defect }}"
                style="left:{{ '%.2f' | format(reg.x * 100) }}%;top:{{ '%.2f' | format(reg.y * 100) }}%;width:{{ '%.2f' | format(reg.w * 100) }}%;height:{{ '%.2f' | format(reg.h * 100) }}%;"></span>
          {% endif %}
        {% endfor %}{% endfor %}{% endfor %}
      </div>
      <figcaption>{{ photo.id }}{% if photo.captured_at %} &middot; {{ photo.captured_at }}{% endif %}
        {% if photo.source_video %}&middot; frame of {{ photo.source_video }}{% endif %}</figcaption>
    </figure>
    {% endfor %}
  </div>
  {% endif %}
</section>
{% endfor %}

{% if total_photos %}
<section class="room appendix-photos print-only page-break" id="appendix-photos">
  <h2>Appendix B — Room photographs</h2>
  {% for section in room_sections %}
  {% if section.photos %}
  <h3>{{ section.number }}. {{ section.name }}</h3>
  <div class="photo-sheet">
    {% for photo in section.photos %}
    <figure id="pdf-photo-{{ photo.id }}" data-photo-id="{{ photo.id }}"
            {% if loop.index % 12 == 0 %}class="sheet-break"{% endif %}>
      <img src="{{ photo_src[photo.id] }}" alt="{{ photo.id }}">
      <figcaption>
        <div class="ref-tag">Ref #{{ section.number }}</div>
        <div>{{ photo.captured_at or inv.inspected_at }}</div>
      </figcaption>
    </figure>
    {% endfor %}
  </div>
  {% endif %}
  {% endfor %}
</section>
{% endif %}

<section class="room appendix page-break">
  <h2>Appendix A — Photographic evidence manifest (SHA-256)</h2>
  <table>
    <thead><tr><th>ID</th><th>Room</th><th>File</th><th>Captured</th><th>SHA-256</th></tr></thead>
    <tbody>
    {% for room in inv.rooms %}{% for photo in room.photos %}
      <tr><td>{{ photo.id }}</td><td>{{ room.name }}</td><td>{{ photo.path }}</td>
          <td>{{ photo.captured_at or "—" }}</td><td>{{ photo.sha256[:32] }}&hellip;</td></tr>
    {% endfor %}{% endfor %}
    </tbody>
  </table>
</section>

<section class="declaration page-break">
  <h3>Declaration</h3>
  <p>{{ uc.declaration_text }}</p>
  {% if uc.initials_note %}
  <p class="initials-note print-only">{{ uc.initials_note }}</p>
  {% endif %}
  {% if inv.signatures %}
  <div id="signatures">
    {% for sig in inv.signatures %}
    <div class="sigcard">
      <strong>{{ sig.name }}</strong> — {{ sig.role }} — signed {{ sig.signed_at }}
      {% if sig.via %}<span class="meta">({{ sig.via }})</span>{% endif %}
      {% if sig.inventory_sha256 %}<div class="hash">attests content sha256
        {{ sig.inventory_sha256 }}</div>{% endif %}
    </div>
    {% endfor %}
  </div>
  {% else %}<div id="signatures"></div>{% endif %}
  <div>
    <span class="sigline"></span><span class="sigline"></span><br>
    <span class="meta">{% if uc.agent_role %}{{ uc.owner_role.label }} / {{ uc.agent_role.label }}{% else %}{{ uc.owner_role.label }}{% endif %} &nbsp; — date</span>
    &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;
    <span class="meta">{{ uc.counterparty_role.label }} &nbsp; — date</span>
  </div>
</section>

<footer class="doc-footer">
  <div class="pdf-brand print-only">{{ agent_display }}{% if inv.agent_phone %} &middot; {{ inv.agent_phone }}{% endif %}</div>
  <span class="tool-meta screen-only">Generated by homeinventory v{{ inv.tool_version }}
  ({{ inv.describe_backend }} backend) &middot; {{ inv.inspected_at }}</span>
</footer>
</main>

<div id="docket" aria-label="Review controls">
  <div class="bar">
    <span class="brand">Review docket</span>
    <button class="dk-btn" id="btn-review" aria-pressed="false">Review mode</button>
    <div id="progress">
      <div class="label"><span id="prog-n">0</span> of <span id="prog-d">0</span> items confirmed</div>
      <div class="track"><div class="fill" id="prog-fill"></div></div>
    </div>
    <span class="kbd-hint"><kbd>j</kbd>/<kbd>k</kbd> item &nbsp;<kbd>space</kbd> confirm
      &nbsp;<kbd>x</kbd> reject &nbsp;<kbd>1–5</kbd> grade</span>
    <span id="dirty-dot" title="Unsaved review changes"></span>
    <button class="dk-btn" id="btn-sign">Sign</button>
    <button class="dk-btn primary" id="btn-export">Download reviewed inventory.json</button>
  </div>
</div>
<div id="toast" role="status"></div>

<script type="application/json" id="hi-data">{{ payload | tojson }}</script>
<script>
"use strict";
/* Level 1 review layer (docs/05-review-experience.md).
   The report degrades to a plain document with JS off; everything below only
   decorates the static HTML and serialises edits back to inventory.json. */
(function () {
  var dataEl = document.getElementById("hi-data");
  if (!dataEl) return;
  var payload = JSON.parse(dataEl.textContent);
  var inv = payload.inventory;
  var photoSrc = payload.photo_src || {};
  var ownerRoleKey = payload.owner_role || "landlord";
  var counterpartyRoleKey = payload.counterparty_role || "tenant";
  var signingRoles = payload.signing_roles || ["landlord", "agent", "tenant"];

  var CONDITIONS = ["new", "excellent", "good", "fair", "poor"];
  var CLEANS = ["professionally cleaned", "cleaned to domestic standard",
                "requires cleaning"];
  var NOT_INSPECTED = ["not tested", "not visible"];

  /* ---- state ---- */
  var itemsById = {};
  var photosById = {};
  inv.rooms.forEach(function (room) {
    (room.items || []).forEach(function (it) { itemsById[it.id] = it; });
    (room.photos || []).forEach(function (p) { photosById[p.id] = p; });
  });
  var reviewing = false;
  var dirty = false;
  var activeId = null;

  var storeKey = "hi-review:" + (inv.property_address || "?") + ":" +
    (inv.inspected_at || "?") + ":" + Object.keys(itemsById).sort().join(",");

  /* ---- tiny dom helpers ---- */
  function el(tag, attrs, children) {
    var n = document.createElement(tag);
    Object.keys(attrs || {}).forEach(function (k) {
      if (k === "text") n.textContent = attrs[k];
      else if (k.slice(0, 2) === "on") n.addEventListener(k.slice(2), attrs[k]);
      else n.setAttribute(k, attrs[k]);
    });
    (children || []).forEach(function (c) { n.appendChild(c); });
    return n;
  }
  function toast(msg) {
    var t = document.getElementById("toast");
    t.textContent = msg;
    t.classList.add("show");
    clearTimeout(toast._t);
    toast._t = setTimeout(function () { t.classList.remove("show"); }, 2200);
  }
  function markDirty() {
    dirty = true;
    document.getElementById("dirty-dot").classList.add("dirty");
    try { localStorage.setItem(storeKey, JSON.stringify(inv)); } catch (e) {}
    updateProgress();
  }

  /* ---- restore an in-progress review from localStorage ---- */
  (function restore() {
    var saved = null;
    try { saved = localStorage.getItem(storeKey); } catch (e) {}
    if (!saved) return;
    try {
      var prev = JSON.parse(saved);
      var ids = [];
      prev.rooms.forEach(function (r) {
        (r.items || []).forEach(function (i) { ids.push(i.id); });
      });
      // only restore when it is clearly the same inventory shape
      if (ids.sort().join(",") !== Object.keys(itemsById).sort().join(",")) return;
      inv = prev;
      itemsById = {};
      photosById = {};
      inv.rooms.forEach(function (room) {
        (room.items || []).forEach(function (it) { itemsById[it.id] = it; });
        (room.photos || []).forEach(function (p) { photosById[p.id] = p; });
      });
      dirty = true;
      document.getElementById("dirty-dot").classList.add("dirty");
      toast("Restored review in progress — export when done");
    } catch (e) { /* corrupt save: ignore */ }
  })();

  /* ---- progress ---- */
  function counts() {
    var total = 0, done = 0;
    Object.keys(itemsById).forEach(function (id) {
      total += 1;
      if (itemsById[id].reviewed || itemsById[id].rejected) done += 1;
    });
    return { total: total, done: done };
  }
  function updateProgress() {
    var c = counts();
    document.getElementById("prog-n").textContent = c.done;
    document.getElementById("prog-d").textContent = c.total;
    document.getElementById("prog-fill").style.width =
      c.total ? (100 * c.done / c.total) + "%" : "0";
  }

  /* ---- static cell renderers (used after edits & when leaving review mode) ---- */
  function renderStaticRow(tr, it) {
    tr.classList.toggle("item-rejected", !!it.rejected);
    var ref = tr.querySelector(".ref-cell");
    ref.innerHTML = "";
    var displayRef = tr.getAttribute("data-ref") || it.id;
    ref.appendChild(el("span", { "class": "ref-mono", text: displayRef }));
    var flag = it.rejected ? ["no", "rejected"] :
               it.reviewed ? ["ok", "reviewed"] : null;
    if (flag) {
      ref.appendChild(document.createElement("br"));
      ref.appendChild(el("span", { "class": "review-flag " + flag[0], text: flag[1] }));
    }
    if (it.added_by) {
      ref.appendChild(document.createElement("br"));
      ref.appendChild(el("span", { "class": "meta", text: "added by " + it.added_by }));
    }
    var name = tr.querySelector(".name-cell");
    name.innerHTML = "";
    name.appendChild(el("strong", { "class": "item-name", text: it.name }));
    if ((it.quantity || 1) > 1) {
      name.appendChild(document.createTextNode(" ×" + it.quantity));
    }
    if (it.rejected) {
      name.appendChild(document.createElement("br"));
      name.appendChild(el("span", { "class": "meta",
        text: "AI suggested — reviewer rejected" }));
    }
    tr.querySelector(".desc-cell").textContent = it.description || "";
    var cond = tr.querySelector(".cond-cell");
    cond.textContent = it.not_inspected || it.condition || "—";
    cond.className = "cond-cell grade " + (it.condition || "");
    tr.querySelector(".clean-cell").textContent = it.cleanliness || "—";
    renderDefectsStatic(tr.querySelector(".def-cell"), it);
    tr.querySelector(".photo-cell").textContent = (it.photo_ids || []).join(", ");
  }
  function renderDefectsStatic(td, it) {
    td.innerHTML = "";
    var live = it.defects || [], dead = it.rejected_defects || [];
    if (!live.length && !dead.length) {
      td.appendChild(el("span", { "class": "meta", text: "None noted" }));
      return;
    }
    var ul = el("ul", { "class": "defects" });
    live.forEach(function (d) { ul.appendChild(el("li", { text: d })); });
    dead.forEach(function (d) { ul.appendChild(el("li", { "class": "struck", text: d })); });
    td.appendChild(ul);
  }

  /* ---- review-mode cell renderers ---- */
  function gradeSelect(it, kind) {
    var opts, current;
    if (kind === "condition") {
      opts = CONDITIONS.concat(NOT_INSPECTED);
      current = it.not_inspected || it.condition || "";
    } else {
      opts = CLEANS;
      current = it.cleanliness || "";
    }
    var sel = el("select", { "class": "rv-select" });
    sel.appendChild(el("option", { value: "", text: "—" }));
    opts.forEach(function (o) {
      var op = el("option", { value: o, text: o });
      if (o === current) op.setAttribute("selected", "");
      sel.appendChild(op);
    });
    sel.addEventListener("change", function () {
      var v = sel.value || null;
      if (kind === "condition") {
        if (v && NOT_INSPECTED.indexOf(v) >= 0) {
          it.not_inspected = v; it.condition = null;
        } else { it.condition = v; it.not_inspected = null; }
      } else { it.cleanliness = v; }
      markDirty();
    });
    sel.addEventListener("click", function (e) { e.stopPropagation(); });
    return sel;
  }
  function defectChips(td, it) {
    td.innerHTML = "";
    function chip(text, struck) {
      var c = el("span", { "class": "chip" + (struck ? " struck" : ""),
                           title: struck ? "Click to restore" :
                                  "Click to strike — kept as “reviewer rejected”" });
      c.appendChild(el("span", { text: text }));
      c.appendChild(el("span", { "class": "x", text: struck ? "↩" : "✕" }));
      c.addEventListener("click", function (e) {
        e.stopPropagation();
        var from = struck ? it.rejected_defects : it.defects;
        var to = struck ? it.defects : it.rejected_defects;
        var i = from.indexOf(text);
        if (i >= 0) { from.splice(i, 1); to.push(text); }
        defectChips(td, it);
        markDirty();
      });
      return c;
    }
    it.defects = it.defects || [];
    it.rejected_defects = it.rejected_defects || [];
    it.defects.forEach(function (d) { td.appendChild(chip(d, false)); });
    it.rejected_defects.forEach(function (d) { td.appendChild(chip(d, true)); });
    var add = el("span", { "class": "chip chip-add", text: "+ defect" });
    add.addEventListener("click", function (e) {
      e.stopPropagation();
      var t = prompt("Defect noted (e.g. “scuff to lower left door panel”):");
      if (t && t.trim()) { it.defects.push(t.trim()); defectChips(td, it); markDirty(); }
    });
    td.appendChild(add);
  }
  function editable(node, get, set) {
    node.setAttribute("contenteditable", "true");
    node.classList.add("rv-edit");
    node.addEventListener("click", function (e) { e.stopPropagation(); });
    node.addEventListener("blur", function () {
      var v = node.textContent.trim();
      if (v !== get()) { set(v); markDirty(); }
    });
    node.addEventListener("keydown", function (e) {
      if (e.key === "Enter") { e.preventDefault(); node.blur(); }
    });
  }
  function renderReviewRow(tr, it) {
    renderStaticRow(tr, it);  // base, then graft controls on top
    var name = tr.querySelector(".item-name");
    editable(name, function () { return it.name; },
             function (v) { it.name = v; });
    var desc = tr.querySelector(".desc-cell");
    editable(desc, function () { return it.description || ""; },
             function (v) { it.description = v; });
    var cond = tr.querySelector(".cond-cell");
    cond.innerHTML = ""; cond.appendChild(gradeSelect(it, "condition"));
    var clean = tr.querySelector(".clean-cell");
    clean.innerHTML = ""; clean.appendChild(gradeSelect(it, "cleanliness"));
    defectChips(tr.querySelector(".def-cell"), it);
    var pc = tr.querySelector(".photo-cell");
    pc.innerHTML = "";
    (it.photo_ids || []).forEach(function (pid, i) {
      if (i) pc.appendChild(document.createTextNode(", "));
      var a = el("a", { href: "#photo-" + pid, text: pid });
      a.addEventListener("click", function (e) {
        e.preventDefault(); e.stopPropagation(); flashPhoto(pid);
      });
      pc.appendChild(a);
    });
    markRow(tr, it);
  }
  function markRow(tr, it) {
    tr.classList.toggle("done-mark", !!it.reviewed && !it.rejected);
    tr.classList.toggle("reject-mark", !!it.rejected);
    tr.classList.toggle("pending-mark", !it.reviewed && !it.rejected);
  }
  function flashPhoto(pid) {
    var fig = document.getElementById("photo-" + pid);
    if (!fig) { toast(pid + " — photo not embedded in this report"); return; }
    fig.scrollIntoView({ behavior: "smooth", block: "center" });
    fig.classList.remove("flash");
    void fig.offsetWidth;  // restart the animation
    fig.classList.add("flash");
  }

  /* ---- the evidence drawer under the active row ---- */
  function closeDrawer() {
    var d = document.querySelector("tr.rv-evidence");
    if (d) d.parentNode.removeChild(d);
    var a = document.querySelector("tr.item-row.active");
    if (a) a.classList.remove("active");
    activeId = null;
  }
  function openDrawer(tr) {
    var it = itemsById[tr.getAttribute("data-item-id")];
    if (!it) return;
    closeDrawer();
    tr.classList.add("active");
    activeId = it.id;
    var td = el("td", { colspan: "7" });

    var actions = el("div", { "class": "rv-actions" });
    function actBtn(label, primary, fn) {
      var b = el("button", { "class": "dk-btn" + (primary ? " primary" : ""),
                             text: label });
      b.addEventListener("click", function (e) { e.stopPropagation(); fn(); });
      return b;
    }
    actions.appendChild(actBtn(it.reviewed ? "✓ Confirmed" : "✓ Confirm", true,
      function () {
        it.reviewed = true; it.rejected = false;
        markDirty(); renderReviewRow(tr, it);
        stepRow(1);  // openDrawer() on the next row closes this drawer
      }));
    actions.appendChild(actBtn(it.rejected ? "Restore item" : "✕ Reject item", false,
      function () {
        it.rejected = !it.rejected;
        if (it.rejected) it.reviewed = false;
        markDirty(); renderReviewRow(tr, it); closeDrawer();
      }));
    actions.appendChild(el("span", { "class": "spacer" }));
    if (typeof it.confidence === "number") {
      actions.appendChild(el("span", { "class": "kbd-hint",
        text: "model confidence " + Math.round(it.confidence * 100) + "%" }));
    }
    td.appendChild(actions);

    var strip = el("div", { "class": "ev-strip" });
    var shown = 0;
    (it.photo_ids || []).forEach(function (pid) {
      var src = photoSrc[pid];
      if (!src) return;
      shown += 1;
      var a = el("a", { href: "#photo-" + pid });
      a.addEventListener("click", function (e) {
        e.preventDefault(); e.stopPropagation(); flashPhoto(pid);
      });
      a.appendChild(el("img", { src: src, alt: pid, loading: "lazy" }));
      a.appendChild(el("span", { "class": "pid", text: pid }));
      strip.appendChild(a);
    });
    if (!shown) {
      strip.appendChild(el("span", { "class": "ev-none",
        text: "No evidence photos cited — treat this claim with suspicion." }));
    }
    td.appendChild(strip);

    var cwrap = el("div", { "class": "rv-comments" });
    (it.comments || []).forEach(function (c) {
      var line = el("div", { "class": "c" });
      line.appendChild(el("span", { "class": "who",
        text: (c.author || "?") + " (" + (c.role || "reviewer") + "): " }));
      line.appendChild(document.createTextNode(c.text || ""));
      cwrap.appendChild(line);
    });
    var box = el("div", { "class": "rv-comment-box" });
    var input = el("input", { type: "text",
      placeholder: "Add a comment on this item…" });
    input.addEventListener("click", function (e) { e.stopPropagation(); });
    input.addEventListener("keydown", function (e) {
      if (e.key !== "Enter") { e.stopPropagation(); return; }
      e.stopPropagation();
      var t = input.value.trim();
      if (!t) return;
      it.comments = it.comments || [];
      it.comments.push({ author: inv.inspected_by || "reviewer",
        role: ownerRoleKey, text: t, at: new Date().toISOString() });
      input.value = "";
      markDirty(); openDrawer(tr);
    });
    box.appendChild(input);
    cwrap.appendChild(box);
    td.appendChild(cwrap);

    var drawer = el("tr", { "class": "rv-evidence" }, [td]);
    drawer.addEventListener("click", function (e) { e.stopPropagation(); });
    tr.parentNode.insertBefore(drawer, tr.nextSibling);
  }

  function allRows() {
    return Array.prototype.slice.call(
      document.querySelectorAll("tr.item-row"));
  }
  function stepRow(delta) {
    var rows = allRows();
    if (!rows.length) return;
    var idx = -1;
    rows.forEach(function (r, i) {
      if (r.getAttribute("data-item-id") === activeId) idx = i;
    });
    var next = rows[Math.max(0, Math.min(rows.length - 1, idx + delta))];
    if (idx === -1) next = rows[0];
    next.scrollIntoView({ behavior: "smooth", block: "center" });
    openDrawer(next);
  }

  /* ---- review mode toggle ---- */
  function setReviewing(on) {
    reviewing = on;
    document.body.classList.toggle("reviewing", on);
    document.getElementById("btn-review")
      .setAttribute("aria-pressed", on ? "true" : "false");
    closeDrawer();
    allRows().forEach(function (tr) {
      var it = itemsById[tr.getAttribute("data-item-id")];
      if (!it) return;
      if (on) renderReviewRow(tr, it);
      else {
        renderStaticRow(tr, it);
        tr.classList.remove("done-mark", "reject-mark", "pending-mark");
      }
    });
    if (on) toast("Review mode — click an item, or use j / k");
  }

  /* ---- export ---- */
  function exportJson() {
    var blob = new Blob([JSON.stringify(inv, null, 2)],
                        { type: "application/json" });
    var a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = "inventory.json";
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    setTimeout(function () { URL.revokeObjectURL(a.href); }, 4000);
    dirty = false;
    document.getElementById("dirty-dot").classList.remove("dirty");
    try { localStorage.removeItem(storeKey); } catch (e) {}
    var c = counts();
    toast("Saved — drop it in the report folder and run: homeinventory render" +
          (c.done < c.total ? " (" + (c.total - c.done) + " items unreviewed)" : ""));
  }

  /* ---- signing (landlord/agent side; tenant countersigns via Level 3) ---- */
  function canonicalHash(obj) {
    // sha256 over the same canonical form as Inventory.content_sha256()
    function sortKeys(v) {
      if (Array.isArray(v)) return v.map(sortKeys);
      if (v && typeof v === "object") {
        var out = {};
        Object.keys(v).sort().forEach(function (k) { out[k] = sortKeys(v[k]); });
        return out;
      }
      return v;
    }
    var body = sortKeys(JSON.parse(JSON.stringify(obj)));
    delete body.signatures;
    var text = JSON.stringify(body);
    if (!(window.crypto && crypto.subtle)) {
      return Promise.resolve("");
    }
    return crypto.subtle.digest("SHA-256",
        new TextEncoder().encode(text))
      .then(function (buf) {
        return Array.prototype.map.call(new Uint8Array(buf), function (b) {
          return b.toString(16).padStart(2, "0");
        }).join("");
      });
  }
  function sign() {
    var c = counts();
    if (c.done < c.total &&
        !confirm(c.total - c.done + " items are still unreviewed. Sign anyway?")) {
      return;
    }
    var name = prompt("Sign as (full name):", inv.inspected_by || "");
    if (!name || !name.trim()) return;
    var role = prompt('Role — "' + ownerRoleKey + '" or "agent":', ownerRoleKey);
    if (!role || !role.trim()) return;
    canonicalHash(inv).then(function (hash) {
      inv.signatures = inv.signatures || [];
      inv.signatures.push({
        role: role.trim().toLowerCase(), name: name.trim(),
        signed_at: new Date().toISOString(),
        inventory_sha256: hash, via: "interactive report (level 1)"
      });
      markDirty();
      var holder = document.getElementById("signatures");
      var s = inv.signatures[inv.signatures.length - 1];
      var card = el("div", { "class": "sigcard" });
      card.appendChild(el("strong", { text: s.name }));
      card.appendChild(document.createTextNode(
        " — " + s.role + " — signed " + s.signed_at + " "));
      if (s.inventory_sha256) {
        card.appendChild(el("div", { "class": "hash",
          text: "attests content sha256 " + s.inventory_sha256 }));
      }
      holder.appendChild(card);
      toast("Signed. Export the reviewed JSON to make it permanent.");
    });
  }

  /* ---- wire-up ---- */
  document.getElementById("docket").classList.add("on");
  document.getElementById("btn-review").addEventListener("click", function () {
    setReviewing(!reviewing);
  });
  document.getElementById("btn-export").addEventListener("click", exportJson);
  document.getElementById("btn-sign").addEventListener("click", sign);
  document.addEventListener("click", function (e) {
    if (!reviewing) return;
    var tr = e.target.closest ? e.target.closest("tr.item-row") : null;
    if (tr) {
      if (tr.classList.contains("active")) closeDrawer();
      else openDrawer(tr);
    }
  });
  document.addEventListener("keydown", function (e) {
    if (!reviewing) return;
    var t = e.target;
    if (t && (t.tagName === "INPUT" || t.tagName === "SELECT" ||
              t.isContentEditable)) return;
    var it = activeId ? itemsById[activeId] : null;
    var tr = activeId ? document.querySelector(
      'tr.item-row[data-item-id="' + activeId + '"]') : null;
    if (e.key === "j") { e.preventDefault(); stepRow(1); }
    else if (e.key === "k") { e.preventDefault(); stepRow(-1); }
    else if (e.key === " " && it && tr) {
      e.preventDefault();
      it.reviewed = true; it.rejected = false;
      markDirty(); renderReviewRow(tr, it); stepRow(1);
    } else if (e.key === "x" && it && tr) {
      e.preventDefault();
      it.rejected = !it.rejected;
      if (it.rejected) it.reviewed = false;
      markDirty(); renderReviewRow(tr, it);
    } else if (it && tr && "12345".indexOf(e.key) >= 0) {
      e.preventDefault();
      it.condition = CONDITIONS[Number(e.key) - 1];
      it.not_inspected = null;
      markDirty(); renderReviewRow(tr, it);
    }
  });
  window.addEventListener("beforeunload", function (e) {
    if (dirty) { e.preventDefault(); e.returnValue = ""; }
  });
  updateProgress();
})();
</script>
</body>
</html>
