<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Review — {{ inv.property_address or "Property inventory" }}</title>
{% include "_favicon.j2" %}
<style>
{% include "_theme.css.j2" %}

  html, body { height: 100%; }
  body { display: flex; flex-direction: column; }

  /* ---------- header ---------- */
  .app-header {
    padding: 12px 22px; gap: 12px 18px; flex-wrap: nowrap;
  }
  .app-nav a { font-size: var(--fs-sm); padding: 5px 11px; border-radius: var(--r-sm); }
  .app-nav a[aria-current="page"] {
    background: transparent; color: var(--ink); font-weight: 600;
    box-shadow: inset 0 -2px 0 var(--brass);
  }
  .header-end {
    display: flex; align-items: center; gap: var(--sp-2); margin-left: auto;
    flex-shrink: 0;
  }
  .addr { display: none; }
  #progress { flex: 1 1 auto; min-width: 120px; max-width: 320px; margin: 0 auto; }
  #progress .label { font-size: var(--fs-sm); font-weight: 500; color: var(--muted);
                     font-variant-numeric: tabular-nums; }
  #progress .track { height: 3px; background: var(--line); border-radius: 2px;
                     overflow: hidden; margin-top: 6px; }
  #progress .fill { height: 100%; width: 0; background: var(--confirm);
                    transition: width .35s cubic-bezier(.16,1,.3,1); }
  #save-state { font-size: var(--fs-xs); color: var(--faint); white-space: nowrap; }
  #save-state.err { color: var(--danger); }
  .share { display: none; }
  #btn-queue { display: none; font-size: var(--fs-sm); }

  /* X5: mobile overflow menu when shell nav collapses */
  .header-more { display: none; position: relative; flex-shrink: 0; }
  .header-more > summary { list-style: none; cursor: pointer; }
  .header-more > summary::-webkit-details-marker { display: none; }
  .header-more-btn {
    font-size: 18px; line-height: 1; padding: 4px 10px; letter-spacing: .12em;
  }
  .header-more-panel {
    display: none; position: absolute; top: calc(100% + 6px); right: 0;
    z-index: 50; min-width: 200px; flex-direction: column; align-items: stretch;
    gap: 4px; padding: 10px; background: var(--panel);
    border: 1px solid var(--line-strong); border-radius: 10px;
    box-shadow: var(--shadow);
  }
  .header-more[open] .header-more-panel { display: flex; }
  .header-more-shell a {
    font-size: 13px; font-weight: 500; color: var(--muted);
    text-decoration: none; padding: 6px 10px; border-radius: 6px;
  }
  .header-more-shell a:hover { color: var(--ink); background: var(--panel-2); }
  .header-more-shell a[aria-current="page"] {
    color: var(--brass-bright); background: var(--brass-soft);
  }
  .header-more-finish {
    font-size: 13px; font-weight: 500; color: var(--muted);
    text-decoration: none; padding: 6px 10px; border-radius: 6px;
    border-top: 1px solid var(--line); margin-top: 4px;
  }
  .header-more-finish:hover { color: var(--ink); background: var(--panel-2); }

  /* ---------- layout ---------- */
  #app { flex: 1; display: grid; grid-template-columns: 300px 1fr;
         min-height: 0; }

  /* ---------- queue rail (de-densified — docs/25 Workstream B) ---------- */
  #rail { border-right: 1px solid var(--line); background: var(--paper);
          overflow-y: auto; }
  #rail .tools { position: sticky; top: 0; background: var(--paper);
                 padding: var(--sp-4) var(--sp-4) var(--sp-3);
                 border-bottom: 1px solid var(--line); z-index: 5; }
  #q-search { width: 100%; font: var(--fs-base) var(--ui);
              padding: 10px 12px; margin-bottom: var(--sp-3);
              border: 1px solid var(--line); border-radius: var(--r-sm);
              background: var(--panel); color: var(--ink); }
  #q-search::placeholder { color: var(--faint); }
  #q-search:focus { outline: none; border-color: var(--brass); }
  .filters { display: flex; gap: 6px; flex-wrap: wrap; }
  .filters button {
    border: 1px solid transparent; background: transparent;
    color: var(--faint); border-radius: var(--r-pill); font-size: var(--fs-xs);
    font-weight: 500; padding: 5px 11px; cursor: pointer;
  }
  .filters button:hover { color: var(--muted); background: var(--panel); }
  .filters button[aria-pressed="true"] {
    background: var(--panel); border-color: var(--line);
    color: var(--ink); font-weight: 600;
  }
  .tools .row2 { display: flex; gap: var(--sp-2); margin-top: var(--sp-3);
                 align-items: center; }
  .tools-more { margin-top: var(--sp-3); border-top: 1px solid var(--line);
                padding-top: var(--sp-3); }
  .tools-more > summary {
    font-size: var(--fs-xs); font-weight: 500; color: var(--faint);
    cursor: pointer; list-style: none; padding: 2px 0; user-select: none;
  }
  .tools-more > summary::-webkit-details-marker { display: none; }
  .tools-more > summary::before {
    content: "▸"; display: inline-block; width: 12px; color: var(--faint);
    transition: transform .15s;
  }
  .tools-more[open] > summary::before { transform: rotate(90deg); }
  .tools select { flex: 1; font: var(--fs-sm) var(--ui);
                  border: 1px solid var(--line); border-radius: var(--r-sm);
                  padding: 8px 10px; background: var(--panel); color: var(--muted); }
  #bulk { font-size: var(--fs-sm); padding: 8px 12px; white-space: nowrap; }

  .room-group { border-bottom: 1px solid var(--line); }
  .room-group:last-child { border-bottom: none; }
  .room-head {
    padding: 14px 18px 12px; font-size: var(--fs-xs); font-weight: 600;
    letter-spacing: .1em; text-transform: uppercase; color: var(--faint);
    cursor: pointer; user-select: none;
    display: flex; align-items: center; gap: var(--sp-2); flex-wrap: wrap;
  }
  .room-head .chev {
    font-size: var(--fs-2xs); color: var(--faint); width: 10px; flex-shrink: 0;
    transition: transform .15s;
  }
  .room-group.collapsed .room-head .chev { transform: rotate(-90deg); }
  .room-group.collapsed .room-items { display: none; }
  .room-head:hover { color: var(--muted); background: var(--panel); }
  .room-head .n { font-family: var(--mono); font-size: var(--fs-xs);
                  letter-spacing: 0; text-transform: none; margin-left: auto;
                  color: var(--faint); }
  .room-head .meter { height: 2px; background: var(--line); margin-top: 8px;
                      border-radius: 1px; overflow: hidden; width: 100%;
                      flex-basis: 100%; }
  .room-head .meter i { display: block; height: 100%;
                        background: var(--confirm); }
  .q-item {
    display: grid; grid-template-columns: 8px 1fr auto; gap: 12px;
    align-items: start; padding: 12px 18px; cursor: pointer;
    border-radius: 0; transition: background .12s ease;
  }
  .q-item:hover { background: var(--panel); }
  .q-item.active {
    background: var(--brass-soft);
  }
  .q-item.active .name { color: var(--ink); }
  .q-item.active .name .item-title { font-weight: 600; }
  .q-item .dot { width: 7px; height: 7px; border-radius: 50%;
                 border: 1.5px solid var(--line-strong); flex-shrink: 0;
                 margin-top: 6px; }
  .q-item.done .dot { background: var(--confirm); border-color: var(--confirm); }
  .q-item.bad .dot { background: var(--danger); border-color: var(--danger); }
  .q-item .name { font-weight: 400; font-size: var(--fs-base); line-height: 1.4;
                  overflow: hidden; color: var(--muted); min-width: 0; }
  .q-item .name .item-title { display: block; overflow: hidden;
                              text-overflow: ellipsis; white-space: nowrap; }
  .q-item .name .ref { display: block; font-family: var(--mono);
                       font-size: var(--fs-2xs); color: var(--faint);
                       margin-bottom: 2px; }
  .q-item .name .sub { display: block; font-size: var(--fs-xs); color: var(--faint);
                       font-weight: 400; margin-top: 2px; }
  .q-item.bad .name { text-decoration: line-through; color: var(--faint); }
  .conf { width: 36px; flex-shrink: 0; padding-top: 5px; }
  .conf .t { height: 2px; background: var(--line); border-radius: 1px;
             overflow: hidden; }
  .conf .f { height: 100%; background: var(--pend); }
  .conf .v { font-family: var(--mono); font-size: var(--fs-2xs); color: var(--faint);
             text-align: right; display: block; margin-top: 2px; }
  .empty-queue { padding: var(--sp-7) var(--sp-5); color: var(--muted);
                 font-size: var(--fs-base); line-height: 1.5; text-align: center; }
  #rail-backdrop { display: none; }

  /* ---------- detail pane ---------- */
  #detail { overflow-y: auto; padding: var(--sp-5) var(--sp-6) var(--sp-8);
            min-width: 0; }
  .work { display: grid; grid-template-columns: minmax(0, 1fr) 440px;
          gap: var(--sp-6); align-items: start;
          transition: grid-template-columns .35s cubic-bezier(.16, 1, .3, 1); }

  /* ----- the evidence stage ----- */
  .stage-col {
    min-width: 0; border: 1px solid var(--line); border-radius: var(--r-lg);
    overflow: hidden; background: var(--panel);
  }
  #stage { position: relative; background: #05070b;
           border: none; border-radius: 0; overflow: hidden;
           height: clamp(280px, 52vh, 520px); }
  #stage .media { width: 100%; height: 100%; display: flex;
                  align-items: center; justify-content: center; }
  #stage img, #stage video { width: 100%; height: 100%;
                             max-width: 100%; max-height: 100%;
                             object-fit: contain; display: block; }
  #stage img { cursor: zoom-in; }
  #stage .media.fading img { animation: stage-in .22s ease; }
  @keyframes stage-in { from { opacity: .25; } to { opacity: 1; } }
  .hud { position: absolute; display: flex; gap: 6px; align-items: center;
         z-index: 4; }
  .hud.tl { top: 12px; left: 12px; }
  .hud.tr { top: 12px; right: 12px; }
  .hud.bl { bottom: 12px; left: 12px; }
  .hud.br { bottom: 12px; right: 12px; }
  .hud-chip { background: rgba(8, 10, 14, .82); color: #c8d0da;
              font: 11px var(--mono); padding: 4px 10px; border-radius: 999px;
              border: 1px solid rgba(255,255,255,.1); backdrop-filter: blur(4px); }
  .hud-chip .tc { color: var(--brass-bright); }
  .hud-btn { background: rgba(8, 10, 14, .82); color: #eef1f4;
             border: 1px solid rgba(255,255,255,.14); border-radius: 999px;
             font: 500 12px var(--ui); padding: 6px 12px; cursor: pointer;
             backdrop-filter: blur(4px); }
  .hud-btn:hover { border-color: var(--brass); color: var(--brass-bright); }
  .hud-btn.on { background: var(--brass); border-color: var(--brass);
                color: #14100a; }
  .stage-empty { color: var(--muted); font-size: 13px; line-height: 1.55;
                 text-align: center; padding: 48px 28px; max-width: 360px;
                 margin: 0 auto; }
  .stage-empty b { color: var(--ink); display: block; font-size: 14px;
                   font-weight: 600; margin-bottom: 8px; }

  /* ----- filmstrip of cited frames ----- */
  .strip { display: flex; gap: 8px; overflow-x: auto; padding-bottom: 2px;
           scrollbar-width: thin; }
  .strip button { flex: 0 0 auto; padding: 0; border: 2px solid transparent;
                  border-radius: 8px; overflow: hidden; background: #05070b;
                  cursor: pointer; position: relative; line-height: 0; }
  .strip button:hover { border-color: var(--line-strong); }
  .strip button.active { border-color: var(--brass); }
  .strip img { height: 52px; width: auto; display: block; opacity: .9; }
  .strip button.active img { opacity: 1; }
  .strip .pin-n { position: absolute; right: 3px; bottom: 3px;
                  background: var(--danger); color: #fff;
                  font: 9px var(--ui); line-height: 1.5; padding: 0 5px;
                  border-radius: 4px; }
  .strip .tag { position: absolute; left: 3px; top: 3px;
                background: rgba(8,10,14,.8); color: #cfd6de;
                font: 9px var(--mono); padding: 1px 5px; border-radius: 4px; }
  .strip .hero-star { position: absolute; right: 3px; top: 2px;
                      color: var(--brass-bright); font-size: 10px; }

  /* ----- the walkthrough spine ----- */
  #spine { margin-top: 4px; user-select: none; }
  #spine .chapters { display: flex; gap: 2px; height: 18px;
                     margin-bottom: 8px; }
  #spine .chap { position: relative; border-radius: 3px; overflow: hidden;
                 background: var(--panel-2); cursor: pointer; min-width: 4px; }
  #spine .chap span { position: absolute; inset: 0; display: block;
                      font: 9px/18px var(--ui); letter-spacing: .04em;
                      text-transform: uppercase; color: var(--faint);
                      padding: 0 6px; white-space: nowrap; overflow: hidden;
                      text-overflow: ellipsis; }
  #spine .chap:hover span { color: var(--muted); }
  #spine .chap.here { background: var(--brass-soft); }
  #spine .chap.here span { color: var(--brass-bright); }
  #spine .scrub { position: relative; height: 28px; cursor: pointer; }
  #spine .scrub .rail-line { position: absolute; left: 0; right: 0;
                             top: 13px; height: 1px; background: var(--line); }
  #spine .tick { position: absolute; top: 10px; width: 1px; height: 8px;
                 background: var(--faint); opacity: .45;
                 transform: translateX(-1px); }
  #spine .tick.cited { background: var(--brass); opacity: .9; top: 8px;
                       height: 12px; }
  #spine .tick.flag { background: var(--danger); opacity: .9; top: 8px;
                      height: 12px; }
  #spine .playhead { position: absolute; top: 5px; width: 1px; height: 18px;
                     background: var(--brass-bright);
                     transform: translateX(-1px);
                     transition: left .25s cubic-bezier(.16,1,.3,1); }
  #spine .playhead::after { content: ""; position: absolute; top: -3px;
                            left: -3px; width: 7px; height: 7px; border-radius: 50%;
                            background: var(--brass-bright); }
  #spine.live .playhead { transition: none; }
  #spine .peek { position: absolute; bottom: 32px; z-index: 6;
                 transform: translateX(-50%); display: none;
                 background: #05070b; border: 1px solid var(--line);
                 border-radius: 8px; padding: 4px; pointer-events: none; }
  #spine .peek img { display: block; width: 120px; height: auto;
                     border-radius: 6px; }
  #spine .peek .t { display: block; text-align: center;
                    font: 10px var(--mono); color: var(--brass-bright);
                    padding: 4px 0 2px; }
  .prov { font-size: 12px; line-height: 1.45; color: var(--faint);
          padding: 12px 22px; border-bottom: 1px solid var(--line);
          display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
  .stage-foot { margin-top: 0; }
  .stage-foot .spine-pinned { padding: 0 22px 12px; }
  .stage-foot .disclosure > summary { padding: 12px 22px; }
  .stage-foot .disclosure-body { padding: 0 22px 16px 44px; }
  .rail-overview {
    display: block; padding: 14px 18px 12px; font-size: var(--fs-sm);
    font-weight: 600; color: var(--brass-bright); text-decoration: none;
    border-bottom: 1px solid var(--line);
  }
  .rail-overview:hover { color: var(--ink); background: var(--panel); }
  .stage-toggle {
    display: block; width: calc(100% - 44px); margin: 0 22px 14px;
    text-align: center; font-size: var(--fs-sm);
  }
  .prov .tc { font-family: var(--mono); color: var(--muted); }
  .prov .vid { font-family: var(--mono); color: var(--faint); }

  /* ----- claim card (readable type + spacing — docs/25 B) ----- */
  .claim { background: var(--panel); border: 1px solid var(--line);
           border-radius: var(--r-lg); position: sticky; top: 12px;
           max-height: calc(100vh - 90px); display: flex;
           flex-direction: column; min-width: 0; overflow: hidden;
           box-shadow: var(--e-1); }
  .claim-verdict {
    padding: var(--sp-5) var(--sp-5) var(--sp-5); flex-shrink: 0;
  }
  .claim-meta { display: flex; gap: var(--sp-2); align-items: center;
                flex-wrap: wrap; margin-bottom: var(--sp-4); }
  .claim-loc { font-family: var(--mono); font-size: var(--fs-xs);
               color: var(--faint); letter-spacing: .02em; }
  .claim-loc .sep { color: var(--line-strong); margin: 0 4px; }
  /* .badge — shared component (see _theme.css.j2) */
  .claim-warn {
    font-size: var(--fs-sm); line-height: 1.5; color: var(--muted);
    background: var(--pend-soft); border-radius: var(--r-sm);
    padding: 10px 12px; margin: 0 0 var(--sp-4);
  }
  .claim-warn b { color: var(--ink); font-weight: 600; }
  .claim-identity { margin-bottom: 0; }
  #d-name {
    display: block; font: 600 22px/1.3 var(--display); letter-spacing: -.015em;
    color: var(--ink); border: none; background: transparent; width: 100%;
    margin: 0; padding: 0; resize: none; overflow: hidden;
    field-sizing: content; min-height: 1.3em;
  }
  #d-name:hover { opacity: .92; }
  #d-name:focus { outline: none; opacity: 1; }
  #d-desc {
    display: block; font: var(--fs-md)/1.6 var(--ui); color: var(--muted);
    width: 100%; min-height: 0; border: none; background: transparent;
    resize: none; padding: 0; margin: 12px 0 0; overflow: visible;
    field-sizing: content;
  }
  #d-desc:hover { color: var(--ink); }
  #d-desc:focus { outline: none; color: var(--ink); }
  #actions {
    margin: var(--sp-5) 0 0; padding: var(--sp-4) 0 0;
    border-top: 1px solid var(--line);
  }
  #actions .row { display: flex; gap: 10px; }
  #actions .row .btn {
    flex: 1; padding: 13px 14px; font-size: var(--fs-base); font-weight: 600;
    border-radius: var(--r-sm);
  }
  .claim .scroll {
    overflow-y: auto; padding: 0; flex: 1; min-height: 0;
    display: flex; flex-direction: column;
    border-top: 1px solid var(--line);
  }
  .disclosure {
    border: none; border-radius: 0; background: transparent;
    border-bottom: 1px solid var(--line);
  }
  .disclosure:last-child { border-bottom: none; }
  .disclosure > summary {
    display: grid; grid-template-columns: 12px 1fr; gap: 4px 12px;
    align-items: start; padding: 15px 22px; cursor: pointer;
    list-style: none; user-select: none;
  }
  .disclosure > summary::-webkit-details-marker { display: none; }
  .disclosure > summary::before {
    content: "▸"; font-size: var(--fs-xs); color: var(--faint); grid-row: 1 / -1;
    align-self: start; margin-top: 2px; transition: transform .15s;
  }
  .disclosure[open] > summary::before { transform: rotate(90deg); }
  .disclosure-title {
    font-size: var(--fs-xs); font-weight: 600; letter-spacing: .07em;
    text-transform: uppercase; color: var(--faint); grid-column: 2;
  }
  .disclosure-hint {
    font-size: var(--fs-base); line-height: 1.45; color: var(--muted);
    grid-column: 2; white-space: normal; overflow: visible;
    word-break: break-word;
  }
  .disclosure-hint.em { color: var(--danger); }
  .disclosure-hint.ok { color: var(--confirm); }
  .disclosure-body { padding: 0 22px 18px 44px; }
  .disclosure-body .grades { margin: 0; padding: 0; border: none; }
  .grades { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-3); }
  .grades label { display: block; font-size: var(--fs-xs); font-weight: 600;
    letter-spacing: .1em; text-transform: uppercase; color: var(--faint);
    margin-bottom: 6px; }
  .grades select { width: 100%; font: var(--fs-base) var(--ui);
    padding: 9px 10px; border: 1px solid var(--line); border-radius: var(--r-sm);
    background: var(--paper); color: var(--ink); }
  .sec-empty { font-size: var(--fs-sm); color: var(--faint); font-style: italic; }

  /* .chip — shared component (see _theme.css.j2) */
  .def-add { display: flex; gap: 6px; margin-top: 10px; }
  .def-add input { flex: 1; font: var(--fs-sm) var(--ui); padding: 8px 11px;
    border: 1px solid var(--line); border-radius: var(--r-sm);
    background: var(--paper); color: var(--ink); }
  .def-add input::placeholder { color: var(--faint); }

  .ev-missing {
    font-size: var(--fs-base); line-height: 1.5; color: var(--muted);
    background: var(--pend-soft); border-radius: var(--r-sm);
    padding: 10px 12px; margin: 0;
  }

  /* comments */
  .c-line { padding: 12px 0; border-top: 1px solid var(--line);
            font-size: var(--fs-base); line-height: 1.5; }
  .c-line:first-child { border-top: none; padding-top: 0; }
  .c-line .who { font-weight: 600; font-size: var(--fs-sm); }
  .c-line .who.tenant { color: var(--tenant); }
  .c-line .who.landlord, .c-line .who.agent { color: var(--brass-bright); }
  .c-line .at { font-family: var(--mono); font-size: var(--fs-2xs);
                color: var(--faint); margin-left: 8px; }
  .c-add { display: flex; gap: 6px; margin-top: 10px; }
  .c-add input { flex: 1; font: var(--fs-sm) var(--ui); padding: 8px 11px;
    border: 1px solid var(--line); border-radius: var(--r-sm);
    background: var(--paper); color: var(--ink); }
  .c-add input::placeholder { color: var(--faint); }

  /* claim card actions — separated from claim text above */
  .claim-foot { padding: 0; border-top: 1px solid var(--line); flex-shrink: 0; }
  .claim-foot .disclosure > summary { padding: 12px 22px; }
  .claim-foot .disclosure-body { padding: 0 22px 14px 44px; }
  .claim-foot .disclosure-title {
    font-size: var(--fs-xs); color: var(--faint); text-transform: none;
    letter-spacing: 0; font-weight: 500;
  }
  .kbd-row { display: flex; gap: 8px 14px; flex-wrap: wrap; }
  .kbd { font-family: var(--mono); font-size: var(--fs-2xs); color: var(--faint);
         background: var(--panel-2); border: 1px solid var(--line);
         border-radius: 4px; padding: 2px 6px; }
  .kbd-label { font-size: var(--fs-xs); color: var(--faint); opacity: .8; }

  /* ---------- review nav banner (items + rooms) ---------- */
  .review-nav {
    display: flex; align-items: center; gap: var(--sp-3); flex-wrap: wrap;
    background: var(--panel); border: 1px solid var(--line);
    border-radius: var(--r-md); padding: 12px 16px; margin-bottom: var(--sp-5);
  }
  .review-nav-back {
    font-size: var(--fs-base); color: var(--muted); text-decoration: none;
    flex-shrink: 0;
  }
  .review-nav-back:hover { color: var(--brass-bright); }
  .review-nav-controls {
    display: flex; align-items: center; justify-content: center;
    gap: 10px; flex: 1; min-width: 0;
  }
  .review-nav-center {
    text-align: center; min-width: 0; flex: 1 1 auto;
  }
  .review-nav-title {
    font: 600 20px/1.25 var(--display); letter-spacing: -.015em;
    margin: 0 0 2px; white-space: nowrap; overflow: hidden;
    text-overflow: ellipsis;
  }
  .review-nav-pos {
    font-size: var(--fs-sm); color: var(--faint);
    font-variant-numeric: tabular-nums;
  }
  .review-nav-btn {
    font-size: var(--fs-sm); padding: 7px 12px; white-space: nowrap;
    flex-shrink: 0; max-width: 34%;
    overflow: hidden; text-overflow: ellipsis;
  }
  .review-nav-btn:disabled { opacity: .35; cursor: default; }
  .room-grid { display: grid; grid-template-columns: minmax(0, 1fr) 440px;
               gap: var(--sp-6); align-items: start; }
  .room-panel {
    background: var(--panel); border: 1px solid var(--line);
    border-radius: var(--r-lg); overflow: hidden; position: sticky; top: 12px;
    max-height: calc(100vh - 90px); display: flex; flex-direction: column;
    box-shadow: var(--e-1);
  }
  .room-panel-body {
    overflow-y: auto; flex: 1; min-height: 0;
  }
  .panel-note { font-size: var(--fs-base); line-height: 1.5; color: var(--muted);
                margin: 0 0 var(--sp-3); }
  .room-summary { width: 100%; min-height: 80px; font: var(--fs-md)/1.55 var(--ui);
    border: 1px solid var(--line); border-radius: var(--r-sm); padding: 10px 12px;
    background: var(--paper); color: var(--ink); resize: vertical; }
  .add-form { display: grid; gap: 10px; }
  .add-form + .add-form { margin-top: 10px; }
  .add-form input, .add-form select { font: var(--fs-base) var(--ui);
    padding: 10px 12px; border: 1px solid var(--line); border-radius: var(--r-sm);
    background: var(--paper); color: var(--ink); }
  .add-form input::placeholder { color: var(--faint); }
  .uncited { display: flex; gap: 8px; flex-wrap: wrap; }
  .uncited button { padding: 0; border: 2px solid transparent;
    border-radius: 8px; overflow: hidden; background: #05070b;
    cursor: pointer; line-height: 0; }
  .uncited button:hover { border-color: var(--brass); }
  .uncited img { height: 56px; width: auto; display: block; }
  .uncited figure { margin: 0; }
  .uncited figcaption { font: 10px var(--mono); color: var(--faint);
                        padding-top: 4px; }
  #redesc-status { font-size: 13px; line-height: 1.45; color: var(--muted);
                   margin-top: 10px; }
  #redesc-status details { margin-top: 8px; }
  #redesc-status pre { font: 11px var(--mono); white-space: pre-wrap;
    background: var(--paper); border: 1px solid var(--line);
    border-radius: 8px; padding: 10px 12px; max-height: 220px;
    overflow: auto; }

  /* ---------- overview — deed / catalogue register (Craft C1-A) ---------- */
  .review-subnav {
    display: flex; gap: 2px; flex-shrink: 0;
    border-left: 1px solid var(--line); padding-left: 12px; margin-left: 4px;
  }
  .review-subnav a {
    font-size: var(--fs-sm); padding: 5px 11px; border-radius: var(--r-sm);
    color: var(--faint); text-decoration: none; white-space: nowrap;
  }
  .review-subnav a:hover { color: var(--muted); background: var(--panel); }
  .review-subnav a[aria-current="page"] {
    color: var(--ink); font-weight: 600;
    box-shadow: inset 0 -2px 0 var(--brass);
  }
  .overview {
    width: 100%; max-width: 1200px; margin: 0 auto;
  }
  .deed-masthead {
    margin: 2px 0 0; padding-bottom: 22px;
    border-bottom: 2px solid var(--ink);
  }
  .deed-kicker {
    display: flex; align-items: center; justify-content: space-between;
    gap: 12px; flex-wrap: wrap; margin-bottom: 14px;
  }
  .deed-kicker .kind {
    font: 600 var(--fs-xs)/1 var(--mono); letter-spacing: .16em;
    text-transform: uppercase; color: var(--brass);
  }
  .deed-masthead .overview-title {
    font: 600 clamp(30px, 4.2vw, 46px)/1.05 var(--display);
    letter-spacing: -.02em; margin: 0 0 12px; color: var(--ink);
    max-width: 22ch;
  }
  .deed-meta {
    display: flex; flex-wrap: wrap; gap: 6px 18px; align-items: baseline;
    font: var(--fs-sm)/1.6 var(--mono); color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
  .deed-meta .walkthrough { color: var(--faint); }
  .deed-seal-row {
    display: flex; flex-wrap: wrap; gap: 10px; align-items: center;
    margin-top: 14px;
  }
  .overview-ctas {
    display: flex; gap: 10px; flex-wrap: wrap; align-items: center;
    margin: 22px 0 20px;
  }
  .overview-ctas .btn.primary {
    padding: 12px 22px; font-size: var(--fs-base);
  }
  .overview-ctas .btn.ghost { color: var(--muted); }
  /* overview walkthrough spine (Craft C2-D) */
  .overview-spine {
    margin: 0 0 28px; padding: 14px 16px 12px;
    background: var(--panel); border: 1px solid var(--line);
    border-radius: var(--r-md); box-shadow: var(--e-1);
  }
  .overview-spine .spine-label {
    font: 600 var(--fs-xs)/1 var(--mono); letter-spacing: .12em;
    text-transform: uppercase; color: var(--faint); margin: 0 0 10px;
  }
  .overview-spine #spine { margin-top: 0; }
  .overview-spine #spine .chapters { height: 22px; margin-bottom: 6px; }
  .overview-spine #spine .chap span { font: 10px/22px var(--ui); }
  .register-label {
    font: 600 var(--fs-xs)/1 var(--mono); letter-spacing: .14em;
    text-transform: uppercase; color: var(--faint); margin: 0 0 16px;
  }
  /* establishing frame on the masthead (composite move B) */
  .deed-hero {
    position: relative; border-radius: var(--r-lg); overflow: hidden;
    aspect-ratio: 21 / 9; margin-bottom: 18px; box-shadow: var(--e-2);
    background: var(--panel-2);
  }
  .deed-hero img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .deed-hero .scrim {
    position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(0deg, rgba(18,12,3,.86) 0%,
      rgba(18,12,3,.34) 40%, rgba(18,12,3,0) 68%);
  }
  .deed-hero .deed-overlay {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: clamp(16px, 3.2vw, 32px);
  }
  .deed-hero .deed-kicker { margin-bottom: 8px; }
  .deed-hero .deed-kicker .kind { color: #ecca88; }
  .deed-hero .overview-title {
    margin: 0; max-width: 20ch; color: #fffdf8;
    text-shadow: 0 2px 26px rgba(0,0,0,.45);
  }
  .deed-hero-cap { display: block; margin-top: 11px; }
  .deed-hero-cap .exhibit { color: rgba(255,253,248,.82); }
  .deed-hero-cap .exhibit .tc { color: #ecca88; }
  .deed-hero-cap .exhibit .room { color: rgba(255,253,248,.92); }
  .deed-hero-cap .exhibit .pid { color: rgba(255,253,248,.6); }
  @media (max-width: 620px) { .deed-hero { aspect-ratio: 16 / 9; } }

  /* coverage candour seals (composite move C) */
  .deed-seal-row .exhibit-seal.ok {
    color: var(--confirm); border-color: #bfdccb;
    background: var(--confirm-soft);
  }
  .deed-seal-row .exhibit-seal.flag {
    color: var(--brass-bright); border-color: var(--line-strong);
    background: var(--brass-soft);
  }

  /* plate provenance stamp — every cover sourced to a moment (move D) */
  .room-card .prov {
    position: absolute; left: 7px; bottom: 7px; z-index: 2;
    display: inline-flex; align-items: center; gap: 5px;
    font: 600 var(--fs-2xs)/1 var(--mono); letter-spacing: .04em;
    color: #fffdf8; background: rgba(14,10,3,.6);
    padding: 3px 8px 3px 6px; border-radius: var(--r-pill);
    font-variant-numeric: tabular-nums;
  }
  .room-card .prov::before {
    content: ""; width: 5px; height: 5px; border-radius: 50%;
    background: #e6be6c; box-shadow: 0 0 0 2px rgba(230,190,108,.3);
  }

  /* flagged cover states its weakness plainly (composite move D / H) */
  .room-card.cover-warn .thumb {
    border-color: var(--brass); box-shadow: 0 0 0 1px var(--brass-soft);
  }
  .room-card .cover-flag {
    display: inline-block; margin-top: 7px;
    font: 600 var(--fs-2xs)/1.3 var(--ui); letter-spacing: .03em;
    text-transform: uppercase; color: var(--brass-bright);
    background: var(--brass-soft); padding: 3px 8px; border-radius: var(--r-pill);
  }
  /* two orientations, one register grammar (docs/25 Ledger) */
  .overview-features {
    display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 34px;
  }
  .overview-features:empty { display: none; margin: 0; }
  .overview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 30px 22px;
  }
  @media (max-width: 620px) {
    .overview-features { grid-template-columns: 1fr; gap: 26px; }
  }
  @media (max-width: 520px) {
    .overview { max-width: none; }
    .overview-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px;
    }
    .overview-ctas .btn { flex: 1 1 auto; min-width: 0; font-size: 12px;
                           padding: 10px 12px; }
    .deed-masthead .overview-title { font-size: var(--fs-xl); }
  }
  /* catalogue plate: bordered figure, caption always beneath */
  .room-card {
    border: 0; background: none; cursor: pointer; text-align: left;
    padding: 0; font: inherit; color: inherit;
    display: flex; flex-direction: column; min-width: 0;
    opacity: 0; transform: translateY(10px);
    animation: plate-in .55s cubic-bezier(.16, 1, .3, 1) forwards;
  }
  @keyframes plate-in {
    to { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .room-card { opacity: 1; transform: none; animation: none; }
  }
  .room-card .thumb {
    position: relative;
    aspect-ratio: 4 / 5; background: var(--panel-2); overflow: hidden;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid var(--line-strong); border-radius: 4px;
    transition: transform .4s cubic-bezier(.16,1,.3,1),
                box-shadow .3s ease, border-color .3s ease;
  }
  .room-card.land .thumb { aspect-ratio: 3 / 2; }
  .room-card .thumb img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .room-card:hover .thumb, .room-card:focus-visible .thumb {
    transform: translateY(-4px); box-shadow: var(--e-2);
    border-color: var(--brass);
  }
  .room-card .thumb-empty {
    color: var(--faint); font-size: var(--fs-xs); letter-spacing: .06em;
    text-transform: uppercase;
  }
  .room-card .body { flex-shrink: 0; padding: 12px 2px 0; }
  .room-card .pno {
    display: block; font: 600 var(--fs-2xs)/1 var(--mono); color: var(--brass);
    letter-spacing: .14em; text-transform: uppercase; margin-bottom: 6px;
  }
  .room-card .name {
    font: 600 var(--fs-lg)/1.14 var(--display); margin: 0;
    letter-spacing: -.01em; color: var(--ink);
  }
  .room-card.land .name { font-size: var(--fs-xl); }
  .room-card .meta {
    margin-top: 6px; font: var(--fs-sm)/1.5 var(--mono); color: var(--muted);
    letter-spacing: .01em;
  }
  .room-card .warn {
    color: var(--danger); font-weight: 600; font-variant-numeric: tabular-nums;
  }
  .room-card .meter {
    height: 2px; background: var(--line);
    overflow: hidden; margin-top: 11px;
  }
  .room-card .meter i {
    display: block; height: 100%; background: var(--confirm);
    transition: width .35s cubic-bezier(.16,1,.3,1);
  }
  .room-breadcrumb { margin-bottom: 14px; font-size: 13px; }
  .room-breadcrumb a {
    color: var(--muted); text-decoration: none;
  }
  .room-breadcrumb a:hover { color: var(--brass-bright); }
  .room-breadcrumb .sep { color: var(--faint); margin: 0 6px; }
  .coach-mark {
    flex-shrink: 0;
    background: var(--brass-soft); border: 1px solid var(--brass);
    border-radius: 10px; padding: 14px 16px; margin-bottom: 20px;
    font-size: 13px; line-height: 1.5; color: var(--ink);
    display: flex; gap: 12px; align-items: flex-start;
  }
  .coach-mark p { margin: 0; flex: 1; }
  .coach-mark button {
    border: none; background: transparent; color: var(--faint);
    cursor: pointer; font-size: 18px; line-height: 1; padding: 0 2px;
  }
  .wt-player {
    margin-bottom: 20px; border: 1px solid var(--line); border-radius: 12px;
    overflow: hidden; background: #05070b;
  }
  .wt-player video { width: 100%; display: block; max-height: 360px; }
  .wt-player .bar {
    display: flex; align-items: center; gap: 10px; padding: 10px 14px;
    background: var(--panel); font-size: 12px; color: var(--muted);
  }


  /* ---------- finish checklist — closing ceremony (Craft C1-G) ---------- */
  .finish { max-width: 720px; }
  .finish-deed {
    margin: 0 0 var(--sp-6); padding-bottom: 20px;
    border-bottom: 2px solid var(--ink);
  }
  .finish-deed .kind {
    font: 600 var(--fs-xs)/1 var(--mono); letter-spacing: .16em;
    text-transform: uppercase; color: var(--brass); margin: 0 0 10px;
  }
  .finish h1 { font: 600 clamp(26px, 3.5vw, 36px)/1.12 var(--display);
               letter-spacing: -.015em; margin: 0 0 10px; }
  .finish-intro { font-size: var(--fs-md); line-height: 1.6; color: var(--muted);
                  margin: 0; max-width: 48ch; }
  .finish-seal-row { margin-top: 14px; }
  .finish-checklist { list-style: none; padding: 0; margin: 0; }
  .finish-step { border: 1px solid var(--line); border-radius: var(--r-lg);
                 margin-bottom: var(--sp-3); background: var(--panel);
                 overflow: hidden; box-shadow: var(--e-1); }
  .finish-step-head { display: flex; align-items: flex-start; gap: var(--sp-3);
                      padding: 16px 18px; }
  .finish-step-icon { flex-shrink: 0; width: 24px; height: 24px;
                      border-radius: 50%; display: flex; align-items: center;
                      justify-content: center; font-size: var(--fs-sm);
                      font-weight: 700; background: var(--line); color: var(--faint); }
  .finish-step.ok .finish-step-icon { background: var(--confirm-soft); color: var(--confirm); }
  .finish-step.warn .finish-step-icon { background: var(--pend-soft); color: var(--pend); }
  .finish-step.blocker .finish-step-icon { background: var(--danger-soft); color: var(--danger); }
  .finish-step-title { font: 600 var(--fs-md)/1.35 var(--ui); margin: 0; }
  .finish-step-note { font-size: var(--fs-sm); line-height: 1.5; color: var(--muted);
                      margin: 5px 0 0; }
  .finish-step-body { padding: 0 18px 18px 50px; border-top: 1px solid var(--line); }
  .finish-step-body:empty { display: none; }
  .finish-fields { display: grid; gap: var(--sp-3); padding-top: 16px; }
  .finish-fields label { display: block; font-size: var(--fs-xs); font-weight: 600;
    letter-spacing: .08em; text-transform: uppercase; color: var(--muted);
    margin-bottom: 5px; }
  .finish-fields input, .finish-fields select { width: 100%;
    font: var(--fs-base) var(--ui); padding: 10px 12px;
    border: 1px solid var(--line); border-radius: var(--r-sm);
    background: var(--paper); color: var(--ink); }
  .finish-actions { display: flex; gap: var(--sp-2); flex-wrap: wrap;
                    margin-top: var(--sp-3); }
  .finish-sig-list { font-size: var(--fs-sm); color: var(--muted); margin: 0 0 12px; }
  /* closing seal — paper + ink rule + brass, not mint-on-brass */
  .finish-handoff {
    margin-top: var(--sp-7); padding: 0; border-radius: var(--r-lg);
    background: var(--panel); border: 1px solid var(--line-strong);
    box-shadow: var(--e-2); overflow: hidden;
  }
  .finish-handoff-inner { padding: 22px 24px 20px; }
  .finish-handoff-mark {
    display: flex; align-items: center; gap: 10px; margin-bottom: 12px;
  }
  .finish-handoff-mark .seal {
    flex-shrink: 0; width: 28px; height: 28px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: var(--brass); color: #14100a; font: 700 14px/1 var(--ui);
  }
  .finish-handoff-mark .kind {
    font: 600 var(--fs-xs)/1 var(--mono); letter-spacing: .14em;
    text-transform: uppercase; color: var(--brass-bright);
  }
  .finish-handoff h2 {
    font: 600 clamp(22px, 2.8vw, 28px)/1.2 var(--display);
    letter-spacing: -.015em; margin: 0 0 8px; color: var(--ink);
  }
  .finish-handoff p {
    font-size: var(--fs-base); line-height: 1.55; color: var(--muted);
    margin: 0 0 18px; max-width: 46ch;
  }
  .finish-handoff-actions {
    display: flex; gap: 10px; flex-wrap: wrap; align-items: center;
    padding: 14px 24px 18px; background: var(--panel-2);
    border-top: 1px solid var(--line);
  }
  .finish-handoff-actions .btn {
    text-decoration: none; padding: 11px 18px; font-size: var(--fs-base);
  }
  .finish-handoff-actions a.btn { text-decoration: none; }
  .finish-handoff-actions .btn.primary { min-width: 10em; }
  @media (max-width: 480px) {
    .finish { max-width: none; }
    .finish-step-head { padding: 14px; }
    .finish-fields input, .finish-fields select { font-size: 16px; }
    .finish-handoff-inner { padding: 18px 16px 16px; }
    .finish-handoff-actions { padding: 12px 16px 14px; }
    .finish-handoff-actions .btn { flex: 1 1 auto; min-width: 0; text-align: center; }
  }

  /* ---------- claim conveyor + evidence expand (Craft C1-B / E) ---------- */
  .work {
    transition: grid-template-columns .35s cubic-bezier(.16, 1, .3, 1);
  }
  .work.evidence-focus {
    grid-template-columns: minmax(0, 1fr) 280px;
  }
  .work.evidence-focus .claim { opacity: .72; }
  .work.evidence-focus #stage {
    height: clamp(320px, 62vh, 640px);
  }
  .claim {
    transition: opacity .28s ease, transform .32s cubic-bezier(.16, 1, .3, 1);
  }
  .claim.conveyor-out {
    opacity: 0; transform: translateX(18px); pointer-events: none;
  }
  .claim.conveyor-in {
    animation: claim-in .34s cubic-bezier(.16, 1, .3, 1);
  }
  @keyframes claim-in {
    from { opacity: 0; transform: translateX(-14px); }
    to { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .work { transition: none; }
    .claim.conveyor-out { opacity: 1; transform: none; }
    .claim.conveyor-in { animation: none; }
    .work.evidence-focus { grid-template-columns: minmax(0, 1fr) 440px; }
  }

  /* ---------- lightbox (inspect + pin) ---------- */
  #lightbox { position: fixed; inset: 0; z-index: 70;
              background: rgba(5, 7, 11, .96); display: none;
              flex-direction: column; }
  #lightbox.on { display: flex; }
  #lb-top { display: flex; align-items: center; gap: 12px; padding: 12px 20px;
            color: #c8d0da; font-size: 13px; border-bottom: 1px solid #232c38; }
  #lb-top .pid { font-family: var(--mono); font-size: 12px;
                 color: var(--brass-bright); }
  #lb-top .spacer { flex: 1; }
  .lb-btn { border: 1px solid rgba(255,255,255,.16); background: transparent;
            color: #eef1f4; border-radius: 999px; padding: 6px 14px;
            font-size: 12px; cursor: pointer; }
  .lb-btn:hover { border-color: var(--brass); color: var(--brass-bright); }
  .lb-btn[aria-pressed="true"] { background: var(--danger);
                                 border-color: var(--danger); color: #fff; }
  #lb-stage { flex: 1; position: relative; overflow: hidden; cursor: grab; }
  #lb-stage.pinning { cursor: crosshair; }
  #lb-stage.dragging { cursor: grabbing; }
  #lb-canvas { position: absolute; transform-origin: 0 0; }
  #lb-canvas img { display: block; user-select: none; -webkit-user-drag: none; }
  #lb-canvas .box { position: absolute; border: 2px solid var(--danger);
    background: rgba(224,100,89,.12); }
  #lb-canvas .box .lbl { position: absolute; left: -2px; bottom: 100%;
    background: var(--danger); color: #fff; font: 11px var(--ui);
    padding: 1px 6px; white-space: nowrap; max-width: 280px; overflow: hidden;
    text-overflow: ellipsis; }
  #lb-canvas .box .lbl .ex {
    font-family: var(--mono); font-weight: 700; margin-right: 4px;
    opacity: .95;
  }
  #lb-canvas .box.draft { border-style: dashed;
                          background: rgba(224,100,89,.07); }
  #lb-bottom { display: flex; align-items: center; justify-content: center;
               gap: 10px; padding: 12px 20px; color: #7f8fa3; font-size: 12px;
               flex-wrap: wrap; border-top: 1px solid #232c38; }
  #lb-zoom { font-family: var(--mono); min-width: 46px; text-align: center;
             color: #c8d0da; }
  #lb-hint { font-size: 11px; color: #5f6c7c; }

  /* annotation label popover (shared by lightbox pins) */
  #anno-form { position: fixed; z-index: 95; background: var(--panel);
    border: 1px solid var(--line); border-radius: 12px; padding: 14px;
    display: none; width: 280px; }
  #anno-form select, #anno-form input { width: 100%; font: 13px var(--ui);
    padding: 8px 10px; margin-bottom: 8px; border: 1px solid var(--line);
    border-radius: 8px; background: var(--paper); color: var(--ink); }
  #anno-form .row { display: flex; gap: 6px; justify-content: flex-end; }

  /* ---------- responsive ---------- */
  @media (max-width: 1220px) {
    .work, .room-grid { grid-template-columns: 1fr; }
    .claim, .room-panel { position: static; max-height: none; }
    #stage { height: clamp(280px, 48vh, 520px); }
  }
  @media (max-width: 900px) {
    #app { grid-template-columns: 1fr; }
    #btn-queue { display: inline-block; }
    .app-header { flex-wrap: wrap; padding: 10px 16px; }
    .review-subnav {
      order: 2; flex: 1 1 100%; border-left: none; padding-left: 0;
      margin-left: 0; padding-top: 4px;
    }
    .overview-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
    #progress { order: 3; flex: 1 1 100%; max-width: none; margin: 0; }
    .header-end { margin-left: 0; }
    #rail { position: fixed; top: 0; bottom: 0; left: 0; width: 82vw;
            max-width: 360px; z-index: 60; transform: translateX(-103%);
            transition: transform .22s ease; border-right: 1px solid var(--line); }
    #rail.open { transform: none; }
    #rail-backdrop { display: none; position: fixed; inset: 0; z-index: 55;
                     background: rgba(5,7,11,.55); }
    #rail-backdrop.on { display: block; }
    .addr { display: none; }
    #detail { padding: 14px 12px 40px; }
    #stage { height: clamp(240px, 42vh, 420px); border-radius: 10px; }
  }
  @media (hover: none), (pointer: coarse) {
    .claim-foot { display: none; }
    #lb-hint { display: none; }
  }
  @media (max-width: 480px) {
    .app-header {
      display: grid; grid-template-columns: auto 1fr auto;
      grid-template-areas:
        "queue brand more"
        "modes modes modes"
        "progress progress progress";
      gap: 6px 8px; padding: 8px 10px; align-items: center;
    }
    #btn-queue { grid-area: queue; margin: 0; }
    .wordmark { grid-area: brand; font-size: 11px;
                          letter-spacing: .28em; min-width: 0; }
    .app-nav { display: none; }
    .header-more { display: block; grid-area: more; margin-left: 0; }
    .header-more-btn { display: inline-block; }
    .header-more-shell { display: flex; flex-direction: column; gap: 2px; }
    .header-end { display: none; }
    .review-subnav {
      grid-area: modes; order: unset; flex: unset; width: 100%;
      border-left: none; padding: 0; margin: 0;
      overflow-x: auto; flex-wrap: nowrap; scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    .review-subnav::-webkit-scrollbar { display: none; }
    .review-subnav a { flex-shrink: 0; }
    #progress { grid-area: progress; order: unset; flex: unset; width: 100%;
                max-width: none; margin: 0; }
    .addr { display: none; }
    .deed-meta { font-size: 12px; gap: 4px 12px; }
    .coach-mark { font-size: 12px; padding: 12px; }
    .room-card .body { padding: 10px; }
    .room-card .name { font-size: 14px; }
    .review-nav { padding: 8px 10px; gap: 8px; }
    .review-nav-btn .review-nav-btn-label { display: none; }
    .review-nav-title { font-size: 16px; }
    #detail { padding: 10px 10px 28px; }
  }
</style>
</head>
<body>
<header class="app-header">
  <button class="btn ghost" id="btn-queue" aria-label="Show item list">☰ Items</button>
  {% set shell_base = route_prefix ~ "/" %}{% set shell_active = "review" %}
  {%- include "_shell.html.j2" %}
  <nav class="review-subnav" aria-label="Review mode">
    <a href="#overview" id="nav-overview" aria-current="page">Overview</a>
    <a href="#items" id="nav-items">Items</a>
    <a href="#rooms" id="nav-rooms">Rooms</a>
    <a href="#finish" id="nav-finish">Finish</a>
  </nav>
  <span class="addr" id="hdr-addr">{{ inv.property_address or "No address yet" }}</span>
  <div id="progress">
    <div class="label"><span id="prog-n">0</span> of <span id="prog-d">0</span>
      items confirmed</div>
    <div class="track"><div class="fill" id="prog-fill"></div></div>
  </div>
  {% if share_url %}<span class="share" id="share-link-label">{{ payload.share.link_noun }} link:
    <a href="{{ share_url }}" id="share-url">{{ share_url }}</a></span>{% endif %}
  <div class="header-end">
    <span id="save-state" role="status">All changes saved</span>
  </div>
  <details class="header-more">
    <summary class="btn ghost header-more-btn" aria-label="Navigation menu">⋯</summary>
    <div class="header-more-panel">
      <nav class="header-more-shell" aria-label="Sections">
        <a href="{{ route_prefix ~ '/' }}"{% if shell_active == "review" %} aria-current="page"{% endif %}>Review</a>
        <a href="{{ route_prefix ~ '/report' }}"{% if shell_active == "report" %} aria-current="page"{% endif %}>Report</a>
        <a href="{{ route_prefix ~ '/issue' }}"{% if shell_active == "issue" %} aria-current="page"{% endif %}>Final issue</a>
      </nav>
      <a href="#finish" class="header-more-finish">Finish checklist</a>
    </div>
  </details>
</header>

<div id="app">
  <nav id="rail" aria-label="Item queue">
    <a href="#overview" class="rail-overview" id="rail-overview">Overview</a>
    <div class="tools">
      <input type="search" id="q-search"
             placeholder="Search items…"
             data-placeholder-kbd="Search items · ⌘K or /"
             aria-label="Search items" autocomplete="off">
      <div class="filters" id="filters">
        <button data-f="all" aria-pressed="true">All</button>
        <button data-f="pending" aria-pressed="false">Unreviewed</button>
        <button data-f="defects" aria-pressed="false">Defects</button>
        <button data-f="noev" aria-pressed="false">No evidence</button>
      </div>
      <details class="tools-more">
        <summary>Sort &amp; bulk</summary>
        <div class="row2">
          <select id="sort" aria-label="Sort order">
            <option value="conf" selected>Least confident first</option>
            <option value="room">By room</option>
          </select>
          <button class="btn" id="bulk">Accept remaining</button>
        </div>
      </details>
    </div>
    <div id="queue"></div>
  </nav>
  <div id="rail-backdrop"></div>
  <section id="detail"></section>
</div>

<div id="lightbox" role="dialog" aria-modal="true" aria-label="Photo inspector">
  <div id="lb-top">
    <span class="pid" id="lb-pid"></span>
    <span id="lb-title"></span>
    <span class="spacer"></span>
    <button class="lb-btn" id="lb-play" hidden>▶ Play this moment</button>
    <button class="lb-btn" id="lb-pin" aria-pressed="false">Pin defect</button>
    <button class="lb-btn" id="lb-close" aria-label="Close">✕ Close</button>
  </div>
  <div id="lb-stage">
    <div id="lb-canvas"><img id="lb-img" alt=""></div>
  </div>
  <div id="lb-bottom">
    <button class="lb-btn" id="lb-prev" aria-label="Previous photo">‹</button>
    <button class="lb-btn" id="lb-out" aria-label="Zoom out">−</button>
    <span id="lb-zoom">100%</span>
    <button class="lb-btn" id="lb-in" aria-label="Zoom in">+</button>
    <button class="lb-btn" id="lb-fit">Fit</button>
    <button class="lb-btn" id="lb-next" aria-label="Next photo">›</button>
    <span id="lb-hint">Scroll to zoom · drag to pan · double-click a pin to remove it</span>
  </div>
</div>

<div id="anno-form">
  <select id="anno-pick"></select>
  <input id="anno-new" type="text" placeholder="…or describe a new defect">
  <div class="row">
    <button class="btn ghost" id="anno-cancel">Cancel</button>
    <button class="btn primary" id="anno-ok">Pin defect</button>
  </div>
</div>
<div id="toast" role="status"></div>

<script type="application/json" id="hi-data">{{ payload | tojson }}</script>
<script>
{% include "_ui.js.j2" %}
</script>
<script>
"use strict";
(function () {
  var payload = JSON.parse(document.getElementById("hi-data").textContent);
  var PREFIX = {{ route_prefix|default("", true) | tojson }};
  var inv = payload.inventory;
  var photoSrc = payload.photo_src || {};
  var cropSrc = payload.crop_src || {};
  var videos = payload.videos || {};
  var photoTime = payload.photo_time || {};
  var signingRoles = payload.signing_roles || ["landlord", "agent"];
  var coverFields = payload.cover_fields || [];
  var rolesMeta = payload.roles || {};
  var shareSpec = payload.share || {};
  var SHARE_URL = {{ share_url | tojson }};
  var pdfMeta = payload.pdf_meta || { ready: false, stale: true };
  var pdfStatus = "idle";
  var pdfExportStarted = false;
  var finishHost = null;

  var CONDITIONS = ["new", "excellent", "good", "fair", "poor"];
  var NOT_INSPECTED = ["not tested", "not visible"];
  var CLEANS = ["professionally cleaned", "cleaned to domestic standard",
                "requires cleaning"];

  var filter = "all";
  var sortMode = "conf";
  var query = "";
  var viewMode = "overview"; // overview | items | room | finish
  var sel = null;            // {type:"item", id} | {type:"room", name}
  var lastRoomName = null;   // last room opened in room view
  var roomShowAll = {};      // room name -> true: disclosed tier revealed
  var collapsedRooms = {};   // room name -> true when collapsed in the rail
  var el = ui.el, toast = ui.toast;

  function disclosure(title, hint, bodyFn, open) {
    var det = el("details", { "class": "disclosure" });
    if (open) det.setAttribute("open", "");
    var sum = el("summary");
    sum.appendChild(el("span", { "class": "disclosure-title", text: title }));
    if (hint) {
      var hintCls = "disclosure-hint";
      var hintText = typeof hint === "string" ? hint : hint.text;
      if (typeof hint === "object") {
        if (hint.em) hintCls += " em";
        else if (hint.ok) hintCls += " ok";
      }
      if (hintText) {
        sum.appendChild(el("span", { "class": hintCls, text: hintText }));
      }
    }
    det.appendChild(sum);
    var body = el("div", { "class": "disclosure-body" });
    bodyFn(body);
    det.appendChild(body);
    return det;
  }
  function gradeSummary(it) {
    var parts = [];
    if (it.not_inspected) parts.push(it.not_inspected);
    else if (it.condition) parts.push(it.condition);
    if (it.cleanliness) parts.push(it.cleanliness);
    return parts.length ? parts.join(" · ") : "Not set";
  }
  function defectSummary(it) {
    var n = (it.defects || []).length;
    var r = (it.rejected_defects || []).length;
    if (n && r) return n + " noted, " + r + " rejected";
    if (n === 1) return it.defects[0];
    if (n) return n + " defects";
    if (r) return r + " rejected";
    return "None";
  }
  function commentSummary(it) {
    var n = (it.comments || []).length;
    return n ? n + (n === 1 ? " comment" : " comments") : "None";
  }
  function autoResize(node) {
    node.style.height = "auto";
    node.style.height = node.scrollHeight + "px";
  }
  function roomCollapsed(name) {
    if (name in collapsedRooms) return collapsedRooms[name];
    if (sel && sel.type === "item") {
      var room = ix.roomOf[sel.id];
      return !room || room.name !== name;
    }
    return true;
  }
  function setRoomCollapsed(name, collapsed) {
    collapsedRooms[name] = collapsed;
    syncRoomCollapse();
  }
  function syncRoomCollapse() {
    document.querySelectorAll(".room-group[data-room]").forEach(function (grp) {
      var name = grp.getAttribute("data-room");
      grp.classList.toggle("collapsed", roomCollapsed(name));
    });
  }
  function expandRoomForItem(it) {
    if (!it) return;
    var room = ix.roomOf[it.id];
    if (room) setRoomCollapsed(room.name, false);
  }

  function index() {
    var items = [], byId = {}, roomOf = {}, photoById = {};
    inv.rooms.forEach(function (room) {
      (room.photos || []).forEach(function (p) { photoById[p.id] = p; });
      (room.items || []).forEach(function (it) {
        items.push(it); byId[it.id] = it; roomOf[it.id] = room;
      });
    });
    return { items: items, byId: byId, roomOf: roomOf, photoById: photoById };
  }
  var ix = index();

  function api(method, url, body) {
    return fetch(PREFIX + url, {
      method: method,
      headers: { "Content-Type": "application/json" },
      body: body === undefined ? undefined : JSON.stringify(body)
    }).then(function (r) {
      return r.json().catch(function () { return {}; }).then(function (j) {
        if (!r.ok) throw new Error(j.error || r.statusText);
        return j;
      });
    });
  }
  function isDone(it) { return it.reviewed || it.rejected; }
  function hasEvidence(it) {
    return (it.photo_ids || []).some(function (p) { return photoSrc[p]; });
  }
  function pad2(n) { return (n < 10 ? "0" : "") + n; }
  function fmtT(s) {
    s = Math.max(0, Math.floor(s || 0));
    var h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60), r = s % 60;
    return h ? h + ":" + pad2(m) + ":" + pad2(r) : m + ":" + pad2(r);
  }
  function shortSha(hex) {
    if (!hex) return "";
    return (hex + "").slice(0, 8);
  }
  function humanDate(iso) {
    if (!iso) return "";
    var s = (iso + "").slice(0, 10);
    try {
      var d = new Date(s + "T12:00:00");
      if (!isNaN(d.getTime())) {
        return d.toLocaleDateString(undefined, {
          day: "numeric", month: "short", year: "numeric"
        });
      }
    } catch (e) {}
    return s;
  }
  /* Exhibit caption: "seen at 04:12 · Kitchen · P042" (docs/14 P2/P6). */
  function exhibitCaption(opts) {
    var parts = [];
    if (opts.t != null && opts.t !== "") {
      parts.push({ kind: "seen", t: opts.t });
    }
    if (opts.room) parts.push({ kind: "room", text: opts.room });
    if (opts.pid) parts.push({ kind: "pid", text: opts.pid });
    if (opts.extra) parts.push({ kind: "extra", text: opts.extra });
    var node = el("span", { "class": "exhibit" });
    parts.forEach(function (p, i) {
      if (i) node.appendChild(document.createTextNode(" \u00b7 "));
      if (p.kind === "seen") {
        node.appendChild(document.createTextNode("seen at "));
        node.appendChild(el("span", { "class": "tc", text: fmtT(p.t) }));
      } else if (p.kind === "room") {
        node.appendChild(el("span", { "class": "room", text: p.text }));
      } else if (p.kind === "pid") {
        node.appendChild(el("span", { "class": "pid", text: p.text }));
      } else {
        node.appendChild(document.createTextNode(p.text));
      }
    });
    return node;
  }
  function contentSeal() {
    var sha = payload.content_sha256 || "";
    if (!sha) return null;
    var seal = el("span", { "class": "exhibit-seal",
      title: "Content SHA-256 " + sha });
    seal.appendChild(el("b", { text: "SHA" }));
    seal.appendChild(document.createTextNode(shortSha(sha)));
    return seal;
  }
  function prefersReducedMotion() {
    try {
      return window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    } catch (e) { return false; }
  }

  /* ---------- autosave ---------- */
  var dirty = false;
  var saving = false;
  var saveTimer = null;
  var saveState = document.getElementById("save-state");
  function setSaveState(text, err) {
    saveState.textContent = text;
    saveState.classList.toggle("err", !!err);
  }
  function scheduleSave() {
    clearTimeout(saveTimer);
    saveTimer = setTimeout(function () { flush(); }, 800);
  }
  function flush(opts) {
    // returns a promise resolving once the current state is on disk
    opts = opts || {};
    clearTimeout(saveTimer);
    if (!dirty && !saving) return Promise.resolve();
    if (saving) {           // let the in-flight save finish, then re-check
      return new Promise(function (res) {
        setTimeout(function () { flush(opts).then(res); }, 250);
      });
    }
    saving = true;
    dirty = false;
    setSaveState("Saving…");
    var url = "/api/inventory" + (opts.manual ? "" : "?autosave=1");
    return api("PUT", url, inv).then(function () {
      saving = false;
      if (dirty) { scheduleSave(); return; }
      setSaveState("All changes saved");
    }).catch(function (e) {
      saving = false;
      dirty = true;
      setSaveState("Save failed — retrying", true);
      if (!flush._warned) {
        flush._warned = true;
        toast("Could not save: " + e.message + " — will keep retrying");
      }
      clearTimeout(saveTimer);
      saveTimer = setTimeout(function () { flush(opts); }, 4000);
    });
  }
  function markDirty() {
    dirty = true;
    pdfMeta.stale = true;
    setSaveState("Unsaved changes…");
    scheduleSave();
    renderProgress();
    if (viewMode === "finish" && finishHost) renderFinish();
  }
  window.addEventListener("beforeunload", function (e) {
    if (dirty || saving) { e.preventDefault(); e.returnValue = ""; }
  });

  /* ---------- undo ---------- */
  var undoStack = [];
  function snapshotOf(obj) {
    var json = JSON.stringify(obj);
    return function restore() {
      var snap = JSON.parse(json);
      Object.keys(obj).forEach(function (k) { delete obj[k]; });
      Object.keys(snap).forEach(function (k) { obj[k] = snap[k]; });
    };
  }
  function pushUndo(label, objs) {
    var restores = (objs || []).map(snapshotOf);
    undoStack.push({ label: label, apply: function () {
      restores.forEach(function (r) { r(); });
    } });
    if (undoStack.length > 50) undoStack.shift();
  }
  function undo() {
    var entry = undoStack.pop();
    if (!entry) { toast("Nothing to undo"); return; }
    entry.apply();
    ix = index();
    markDirty();
    renderProgress(); renderQueue();
    if (sel && sel.type === "item" && ix.byId[sel.id]) renderItem(ix.byId[sel.id]);
    else if (sel && sel.type === "room") {
      var room = inv.rooms.find(function (r) { return r.name === sel.name; });
      if (room) renderRoom(room);
    } else if (viewMode === "overview") renderOverview();
    else if (viewMode === "finish") renderFinish();
    toast("Undid: " + entry.label);
  }

  /* ---------- progress ---------- */
  function filterCounts() {
    var pending = 0, defects = 0, noev = 0;
    ix.items.forEach(function (it) {
      if (!isDone(it)) pending++;
      if ((it.defects || []).length || (it.rejected_defects || []).length) {
        defects++;
      }
      if (!hasEvidence(it)) noev++;
    });
    return { all: ix.items.length, pending: pending, defects: defects,
             noev: noev };
  }
  var FILTER_LABELS = {
    all: "All", pending: "Unreviewed", defects: "Defects", noev: "No evidence"
  };
  function updateFilterBadges() {
    var c = filterCounts();
    document.getElementById("filters").querySelectorAll("button").forEach(
      function (btn) {
        var f = btn.getAttribute("data-f");
        btn.textContent = FILTER_LABELS[f] + " " + c[f];
      });
  }
  function renderProgress() {
    var done = ix.items.filter(isDone).length;
    document.getElementById("prog-n").textContent = done;
    document.getElementById("prog-d").textContent = ix.items.length;
    document.getElementById("prog-fill").style.width =
      ix.items.length ? (100 * done / ix.items.length) + "%" : "0";
    updateFilterBadges();
    if (viewMode === "overview") refreshOverviewMeters();
  }
  function confidenceBands(items) {
    var bands = { low: 0, mid: 0, high: 0, unknown: 0 };
    items.forEach(function (it) {
      if (typeof it.confidence !== "number") bands.unknown++;
      else if (it.confidence < 0.6) bands.low++;
      else if (it.confidence < 0.8) bands.mid++;
      else bands.high++;
    });
    return bands;
  }
  function formatConfidenceBands(bands) {
    var lines = [];
    if (bands.low) lines.push("Below 60%: " + bands.low);
    if (bands.mid) lines.push("60–80%: " + bands.mid);
    if (bands.high) lines.push("80%+: " + bands.high);
    if (bands.unknown) lines.push("No score: " + bands.unknown);
    return lines.join(" · ");
  }

  /* ---------- overview (X1 orient) ---------- */
  var COACH_KEY = "hi-review-overview-coach";
  var overviewHost = null;

  function inventoryStats() {
    var analysed = 0, shown = 0;
    inv.rooms.forEach(function (room) {
      (room.photos || []).forEach(function (p) {
        if (!photoSrc[p.id]) return;
        analysed++;
        if (p.hero) shown++;
      });
    });
    if (!shown) shown = analysed;
    return {
      rooms: inv.rooms.length,
      items: ix.items.length,
      analysed: analysed,
      shown: shown
    };
  }
  function primaryWalkthrough() {
    var keys = Object.keys(videos);
    if (!keys.length) return null;
    var root = keys.filter(function (k) { return k.indexOf("/") < 0; });
    var rel = root.length ? root[0] : keys[0];
    return { rel: rel, meta: videos[rel] };
  }
  function roomHeroPhoto(room) {
    var heroes = (room.photos || [])
      .filter(function (p) { return p.hero && photoSrc[p.id]; })
      .sort(function (a, b) { return a.hero - b.hero; });
    if (heroes.length) return heroes[0];
    return (room.photos || []).filter(function (p) {
      return photoSrc[p.id]; })[0] || null;
  }
  function roomHeroSrc(room) {
    var p = roomHeroPhoto(room);
    return p ? photoSrc[p.id] : null;
  }
  /* Interim bad-hero honesty (C2-H) until pipeline cover_confident lands. */
  function roomCoverWeak(room) {
    var p = roomHeroPhoto(room);
    if (!p) return { weak: true, reason: "No cover frame" };
    if (p.presentation_eligible === false) {
      return { weak: true, reason: "Cover may not establish the room" };
    }
    if (typeof p.quality === "number" && p.quality < 0.25) {
      return { weak: true, reason: "Low-quality cover" };
    }
    return { weak: false, reason: "" };
  }
  function coverageSummary() {
    var confident = 0, weak = 0;
    inv.rooms.forEach(function (room) {
      if (roomCoverWeak(room).weak) weak++; else confident++;
    });
    return { confident: confident, weak: weak, total: inv.rooms.length };
  }
  /* One establishing frame for the masthead — the strongest *confident*
     cover across the property (composite move B). Null → text masthead so a
     property with no dependable cover degrades gracefully. */
  function establishingHero() {
    var best = null;
    inv.rooms.forEach(function (room) {
      var p = roomHeroPhoto(room);
      if (!p || !photoSrc[p.id]) return;
      if (roomCoverWeak(room).weak) return;
      var q = (typeof p.quality === "number") ? p.quality : 0.5;
      var score = q * 100 + Math.min((room.items || []).length, 40);
      if (!best || score > best.score) {
        best = { room: room, photo: p, src: photoSrc[p.id],
          t: photoTime[p.id] ? photoTime[p.id].t : null, score: score };
      }
    });
    return best;
  }
  function pinExhibitIndex(it, reg) {
    var regs = (it.defect_regions || []).slice().sort(function (a, b) {
      if (a.photo_id !== b.photo_id) {
        return (a.photo_id || "").localeCompare(b.photo_id || "");
      }
      return (a.y - b.y) || (a.x - b.x);
    });
    for (var i = 0; i < regs.length; i++) {
      if (regs[i] === reg ||
          (regs[i].photo_id === reg.photo_id &&
           regs[i].x === reg.x && regs[i].y === reg.y &&
           regs[i].w === reg.w && regs[i].h === reg.h &&
           regs[i].defect === reg.defect)) {
        return i + 1;
      }
    }
    return regs.length || 1;
  }
  function openPrintPdfFallback() {
    var url = PREFIX + "/issue";
    var w = window.open(url, "_blank");
    toast("Opened final issue — use Print → Save as PDF");
    if (w) {
      try {
