{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scene-spec.schema.json",
  "type": "object",
  "required": ["id", "room_type", "property_profile", "cleanliness", "lighting", "continuity_requirements", "avoid", "provider_assignments", "views"],
  "properties": {
    "id": {"type": "string", "pattern": "^RP-[0-9]{3}$"},
    "room_type": {"type": "string", "minLength": 1},
    "property_profile": {"type": "string", "minLength": 1},
    "cleanliness": {"type": "string", "minLength": 1},
    "lighting": {"type": "string", "minLength": 1},
    "continuity_requirements": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "avoid": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "provider_assignments": {"type": "array", "minItems": 2, "maxItems": 2, "uniqueItems": true, "items": {"type": "string"}},
    "views": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"$ref": "#/$defs/view"}}
  },
  "$defs": {"view": {"type": "object", "additionalProperties": false, "required": ["id", "viewpoint", "shot_scale", "intended_visible_items", "intended_defects", "intended_negatives"], "properties": {"id": {"enum": ["A-wide", "B-reverse", "C-inventory", "D-condition"]}, "viewpoint": {"type": "string"}, "shot_scale": {"type": "string"}, "intended_visible_items": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "intended_defects": {"type": "array", "items": {"type": "string"}}, "intended_negatives": {"type": "array", "items": {"type": "string"}}}}},
  "additionalProperties": false
}
