{#- Shared design tokens + app chrome for every served surface (start,
    review, tenant). One palette, one type system, no external fonts —
    nothing leaves the machine. The report template keeps its own document
    styling but uses the same palette values. -#}
:root {
  --paper: #f6f7f8; --panel: #ffffff; --ink: #1c2430; --muted: #5b6472;
  --line: #e2e5e9; --line-strong: #c6ccd4;
  --accent: #15406b; --accent-ink: #0f3257; --accent-soft: #e9eff6;
  --confirm: #0e6b46; --confirm-soft: #e7f3ed;
  --danger: #a3231f; --danger-soft: #f9ecec;
  --pend: #8a6d1f; --pend-soft: #faf4e3;
  --tenant: #7a3e8f;
  --ui: -apple-system, BlinkMacSystemFont, "Segoe UI Variable Text",
        "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  --mono: ui-monospace, "SF Mono", "Cascadia Code", Consolas,
          "Liberation Mono", monospace;
}
* { box-sizing: border-box; }
body { margin: 0; font: 14px/1.5 var(--ui); color: var(--ink);
       background: var(--paper); }
button, input, select, textarea { font-family: var(--ui); }
.mono { font-family: var(--mono); }

/* ---------- app header ---------- */
.app-header {
  display: flex; align-items: center; gap: 14px; padding: 10px 20px;
  background: var(--panel); border-bottom: 1px solid var(--line);
  position: sticky; top: 0; z-index: 30; flex-wrap: wrap;
}
.wordmark { font-weight: 700; letter-spacing: .12em; font-size: 11px;
            text-transform: uppercase; color: var(--accent-ink);
            white-space: nowrap; }
.app-nav { display: flex; gap: 2px; }
.app-nav a { font-size: 13px; font-weight: 500; color: var(--muted);
             text-decoration: none; padding: 5px 10px; border-radius: 5px; }
.app-nav a:hover { color: var(--ink); background: var(--paper); }
.app-nav a[aria-current="page"] { color: var(--accent-ink);
                                  background: var(--accent-soft); }
.header-chip { font-size: 12px; color: var(--muted);
               border: 1px solid var(--line); border-radius: 999px;
               padding: 2px 10px; white-space: nowrap; }

/* ---------- buttons ---------- */
.btn {
  border: 1px solid var(--line-strong); background: var(--panel);
  color: var(--ink); border-radius: 6px; padding: 7px 14px; font-size: 13px;
  font-weight: 500; cursor: pointer;
  transition: border-color .15s, background .15s;
}
.btn:hover { border-color: var(--accent); }
.btn:active { transform: translateY(1px); }
.btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 1px; }
.btn.primary { background: var(--accent); border-color: var(--accent);
               color: #fff; }
.btn.primary:hover { background: var(--accent-ink); }
.btn.danger { color: var(--danger); border-color: #ddbdbc; }
.btn.danger:hover { border-color: var(--danger); background: var(--danger-soft); }
.btn.ghost { border-color: transparent; color: var(--muted); }
.btn.ghost:hover { color: var(--ink); border-color: var(--line-strong); }
.btn:disabled { opacity: .5; cursor: default; transform: none; }

/* ---------- modal ---------- */
.ui-modal-backdrop {
  position: fixed; inset: 0; z-index: 90; background: rgba(28,36,48,.45);
  display: flex; align-items: center; justify-content: center; padding: 16px;
}
.ui-modal {
  background: var(--panel); border: 1px solid var(--line); border-radius: 10px;
  width: 460px; max-width: 100%; max-height: 90vh; overflow: auto;
  box-shadow: 0 24px 60px -20px rgba(15,29,46,.5);
}
.ui-modal .ui-title { padding: 18px 20px 0; font-size: 15px; font-weight: 600; }
.ui-modal .ui-body { padding: 10px 20px 4px; font-size: 14px; }
.ui-modal .ui-body .note { color: var(--muted); font-size: 13px; margin: 6px 0; }
.ui-modal .ui-actions { display: flex; justify-content: flex-end; gap: 8px;
                        padding: 12px 20px 16px; }
.ui-field { margin: 10px 0; }
.ui-field label { display: block; font-size: 11px; font-weight: 600;
  letter-spacing: .08em; text-transform: uppercase; color: var(--muted);
  margin-bottom: 4px; }
.ui-field input, .ui-field select {
  width: 100%; font: 14px var(--ui); padding: 8px 10px;
  border: 1px solid var(--line-strong); border-radius: 6px; background: #fff;
  color: var(--ink);
}
.ui-field input:focus, .ui-field select:focus {
  outline: 2px solid var(--accent); outline-offset: -1px;
  border-color: var(--accent);
}

/* ---------- toast ---------- */
#toast {
  position: fixed; bottom: 18px; left: 50%; z-index: 100;
  transform: translateX(-50%) translateY(8px); background: var(--ink);
  color: #fff; font-size: 13px; padding: 9px 18px; border-radius: 6px;
  opacity: 0; pointer-events: none; max-width: 90vw;
  transition: opacity .25s, transform .25s;
}
#toast.show { opacity: .97; transform: translateX(-50%); }
