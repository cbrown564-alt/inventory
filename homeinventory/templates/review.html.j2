  function submitSign(nameInput, roleInput, signBtn) {
    if (signBtn.dataset.inFlight === "1") return;   /* double-click guard (F5) */
    var name = (nameInput.value || "").trim();
    var role = roleInput.value;
    if (!name) { toast("Enter your full name to sign"); nameInput.focus(); return; }
    if (addressMissing()) { toast("Add the property address before signing"); return; }
    signBtn.disabled = true;
    signBtn.dataset.inFlight = "1";
